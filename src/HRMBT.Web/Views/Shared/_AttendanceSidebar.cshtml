@{
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
}

<strong class="sidebar-title">Attendance Menu</strong>
<hr style="border-color: #0d6efd;" />
<ul class="nav flex-column">
    <li class="nav-item">
        <a class="nav-link @(currentAction == "Create" ? "active fw-bold text-primary" : "text-dark")" 
           asp-controller="Attendance" asp-action="Create">
            ➕ Add Attendance
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(currentAction == "Index" ? "active fw-bold text-primary" : "text-dark")" 
           asp-controller="Attendance" asp-action="Index">
            📅 Attendance Today
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(currentAction == "AttendanceByDepartment" ? "active fw-bold text-primary" : "text-dark")" 
           asp-controller="Attendance" asp-action="AttendanceByDepartment">
            🏢 Att. Summary
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(currentAction == "Upload" ? "active fw-bold text-primary" : "text-dark")" 
           asp-controller="Attendance" asp-action="Upload">
            📤 Upload CSV
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(currentAction == "MonthlyReport" ? "active fw-bold text-primary" : "text-dark")" 
           asp-controller="Attendance" asp-action="MonthlyReport">
            📊 Monthly Report
        </a>
    </li>
</ul>
