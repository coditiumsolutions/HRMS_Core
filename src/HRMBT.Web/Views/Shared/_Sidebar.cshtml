@{
    var activeModule = ViewData["Module"]?.ToString() ?? "Home";
    var sidebarLinks = new Dictionary<string, List<(string Icon, string Text, string Action, string Controller)>>
    {
        ["Home"] = new List<(string, string, string, string)>
        {
            ("👥", "Employees", "Index", "Employee"),
            ("💰", "Payroll", "Index", "Payroll"),
            ("➕", "Allowances", "Index", "Allowances"),
            ("➖", "Deductions", "Index", "Deductions"),
            ("📅", "Attendance", "Index", "Attendance"),
            ("📝", "LMS", "Index", "LMS"),
            ("📋", "Tax", "Index", "Tax"),
            ("⚙️", "Setup", "Index", "Setup")
        },
        ["Employees"] = new List<(string, string, string, string)>
        {
            ("📊", "Dashboard", "Dashboard", "Employee"),
            ("➕", "Add Employees", "Create", "Employee"),
            ("👥", "View Employees", "Index", "Employee"),
            ("✓", "Active Employees", "Index", "Employee")
        },
        ["Payroll"] = new List<(string, string, string, string)>
        {
            ("📈", "Dashboard", "Dashboard", "Payroll"),
            ("👥", "Employee Detail", "EmployeeDetail", "Payroll"),
            ("⚙️", "Generate Payroll", "GeneratePayroll", "Payroll"),
            ("💰", "Run Payroll", "GeneratePayslips", "Payroll"),
            ("🧾", "Payroll Slips", "Index", "Payroll"),
            ("📊", "Payroll Status", "PayrollStatus", "Payroll")
        },
        ["Attendance"] = new List<(string, string, string, string)>
        {
            ("📅", "Attendance Today", "Index", "Attendance"),
            ("🏢", "Attendance By Department", "Index", "Attendance"),
            ("📋", "Attendance Summary", "Index", "Attendance"),
            ("🏝️", "Off-Day", "OffDay", "Attendance")
        },
        ["LMS"] = new List<(string, string, string, string)>
        {
            ("➕", "Add Leave", "Create", "LMS"),
            ("📝", "View Leaves", "Index", "LMS"),
            ("⚖️", "Leave Balance", "Index", "LMS"),
            ("📊", "Leave Reports", "Index", "LMS")
        },
        ["Tax"] = new List<(string, string, string, string)>
        {
            ("📑", "Tax Slabs", "Index", "Tax"),
            ("💼", "Employee Tax", "Index", "Tax"),
            ("📊", "Tax Reports", "Index", "Tax")
        },
        ["Allowances"] = new List<(string, string, string, string)>
        {
            ("📋", "Allowances", "Index", "Allowances"),
            ("➕", "Add Allowances", "Add", "Allowances")
        },
        ["Deductions"] = new List<(string, string, string, string)>
        {
            ("📋", "All deductions", "Index", "Deductions"),
            ("📋", "Bulk add", "Add", "Deductions"),
            ("➕", "Single deduction", "Create", "Deductions")
        }
    };

    var links = sidebarLinks.ContainsKey(activeModule) ? sidebarLinks[activeModule] : new List<(string, string, string, string)>();
}

@if (links.Any())
{
    <strong class="sidebar-title mb-3 d-block">@activeModule</strong>
    <nav class="nav flex-column">
        @foreach (var link in links)
        {
            <a class="nav-link" asp-controller="@link.Item4" asp-action="@link.Item3">
                <span style="margin-right: 6px;">@link.Item1</span>@link.Item2
            </a>
        }
    </nav>
}
else
{
    <p class="text-muted">Select a module to see navigation options...</p>
}

