@model HRMBT.Web.Models.PaginatedList<HRMBT.Web.Models.Employee>

@{
    ViewData["Title"] = "Employees";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-12">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h1>Employee Management</h1>
                <a asp-action="Create" class="btn btn-primary">Add New Employee</a>
            </div>
            
            @if (ViewBag.ErrorMessage != null)
            {
                <div class="alert alert-danger mb-3">
                    <h5>Error:</h5>
                    <p>@ViewBag.ErrorMessage</p>
                </div>
            }

            <!-- Filtering form -->
            <div class="card mb-4">
                <div class="card-body">
                    <form asp-action="Index" method="get" class="row g-3">
                        <input type="hidden" name="sortBy" value="@ViewBag.CurrentSortBy" />
                        <input type="hidden" name="sortOrder" value="@ViewBag.CurrentSortOrder" />
                        
                        <div class="col-md-2">
                            <label for="department" class="form-label">Department</label>
                            <select name="department" id="department" class="form-select">
                                <option value="">All Departments</option>
                                @if (ViewBag.Departments != null)
                                {
                                    foreach (var dept in ViewBag.Departments)
                                    {
                                        <option value="@dept.DepartmentName" selected="@(ViewBag.CurrentDepartment == dept.DepartmentName)">@dept.DepartmentName</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label for="designation" class="form-label">Designation</label>
                            <select name="designation" id="designation" class="form-select">
                                <option value="">All Designations</option>
                                @if (ViewBag.Designations != null)
                                {
                                    foreach (var desig in ViewBag.Designations)
                                    {
                                        <option value="@desig" selected="@(ViewBag.CurrentDesignation == desig)">@desig</option>
                                    }
                                }
                            </select>
                        </div>
                        <!-- Removed Year 2024 and Apply Tax filters as requested -->
                        <div class="col-md-2">
                            <label for="employeeName" class="form-label">Employee Name</label>
                            <input type="text" name="employeeName" id="employeeName" class="form-control" value="@ViewBag.CurrentEmployeeName" placeholder="Search by name..." />
                        </div>
                        <div class="col-md-2">
                            <label for="employeeID" class="form-label">Employee ID</label>
                            <input type="text" name="employeeID" id="employeeID" class="form-control" value="@ViewBag.CurrentEmployeeID" placeholder="Search by ID..." />
                        </div>
                        <div class="col-md-2">
                            <label for="pageSize" class="form-label">Page Size</label>
                            <select name="pageSize" id="pageSize" class="form-select">
                                @if (ViewBag.PageSizeOptions != null)
                                {
                                    foreach (var size in ViewBag.PageSizeOptions)
                                    {
                                        <option value="@size" selected="@(ViewBag.CurrentPageSize == size)">@size</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-2 d-flex align-items-end">
                            <button type="submit" class="btn btn-secondary w-100">Filter</button>
                        </div>
                    </form>
                </div>
            </div>
            
            <!-- Record count info -->
            <div class="d-flex justify-content-between align-items-center mb-2">
                <span class="text-muted">
                    Showing @Model.StartRecord to @Model.EndRecord of @Model.TotalCount records
                </span>
            </div>

            <div class="table-responsive">
                <table class="table table-sm table-striped table-bordered align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>
                                <a asp-action="Index" 
                                   asp-route-sortBy="EmployeeID" 
                                   asp-route-sortOrder="@(ViewBag.CurrentSortBy == "EmployeeID" && ViewBag.CurrentSortOrder == "asc" ? "desc" : "asc")"
                                   asp-route-department="@ViewBag.CurrentDepartment"
                                   asp-route-designation="@ViewBag.CurrentDesignation"
                                   asp-route-year2024="@ViewBag.CurrentYear2024"
                                   asp-route-applyTax="@ViewBag.CurrentApplyTax"
                                   asp-route-employeeName="@ViewBag.CurrentEmployeeName"
                                   asp-route-employeeID="@ViewBag.CurrentEmployeeID"
                                   asp-route-pageSize="@ViewBag.CurrentPageSize"
                                   class="text-white text-decoration-none">
                                    Employee ID
                                    @if (ViewBag.CurrentSortBy == "EmployeeID")
                                    {
                                        <span>@(ViewBag.CurrentSortOrder == "asc" ? "↑" : "↓")</span>
                                    }
                                </a>
                            </th>
                            <th>
                                <a asp-action="Index" 
                                   asp-route-sortBy="EmployeeName" 
                                   asp-route-sortOrder="@(ViewBag.CurrentSortBy == "EmployeeName" && ViewBag.CurrentSortOrder == "asc" ? "desc" : "asc")"
                                   asp-route-department="@ViewBag.CurrentDepartment"
                                   asp-route-designation="@ViewBag.CurrentDesignation"
                                   asp-route-year2024="@ViewBag.CurrentYear2024"
                                   asp-route-applyTax="@ViewBag.CurrentApplyTax"
                                   asp-route-employeeName="@ViewBag.CurrentEmployeeName"
                                   asp-route-employeeID="@ViewBag.CurrentEmployeeID"
                                   asp-route-pageSize="@ViewBag.CurrentPageSize"
                                   class="text-white text-decoration-none">
                                    Employee Name
                                    @if (ViewBag.CurrentSortBy == "EmployeeName")
                                    {
                                        <span>@(ViewBag.CurrentSortOrder == "asc" ? "↑" : "↓")</span>
                                    }
                                </a>
                            </th>
                            <th>
                                <a asp-action="Index" 
                                   asp-route-sortBy="Department" 
                                   asp-route-sortOrder="@(ViewBag.CurrentSortBy == "Department" && ViewBag.CurrentSortOrder == "asc" ? "desc" : "asc")"
                                   asp-route-department="@ViewBag.CurrentDepartment"
                                   asp-route-designation="@ViewBag.CurrentDesignation"
                                   asp-route-year2024="@ViewBag.CurrentYear2024"
                                   asp-route-applyTax="@ViewBag.CurrentApplyTax"
                                   asp-route-employeeName="@ViewBag.CurrentEmployeeName"
                                   asp-route-employeeID="@ViewBag.CurrentEmployeeID"
                                   asp-route-pageSize="@ViewBag.CurrentPageSize"
                                   class="text-white text-decoration-none">
                                    Department
                                    @if (ViewBag.CurrentSortBy == "Department")
                                    {
                                        <span>@(ViewBag.CurrentSortOrder == "asc" ? "↑" : "↓")</span>
                                    }
                                </a>
                            </th>
                            <th>
                                <a asp-action="Index" 
                                   asp-route-sortBy="Designation" 
                                   asp-route-sortOrder="@(ViewBag.CurrentSortBy == "Designation" && ViewBag.CurrentSortOrder == "asc" ? "desc" : "asc")"
                                   asp-route-department="@ViewBag.CurrentDepartment"
                                   asp-route-designation="@ViewBag.CurrentDesignation"
                                   asp-route-year2024="@ViewBag.CurrentYear2024"
                                   asp-route-applyTax="@ViewBag.CurrentApplyTax"
                                   asp-route-employeeName="@ViewBag.CurrentEmployeeName"
                                   asp-route-employeeID="@ViewBag.CurrentEmployeeID"
                                   asp-route-pageSize="@ViewBag.CurrentPageSize"
                                   class="text-white text-decoration-none">
                                    Designation
                                    @if (ViewBag.CurrentSortBy == "Designation")
                                    {
                                        <span>@(ViewBag.CurrentSortOrder == "asc" ? "↑" : "↓")</span>
                                    }
                                </a>
                            </th>
                            <th>Status</th>
                            <!-- Removed Year 2024 and Apply Tax columns as requested -->
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.EmployeeID</td>
                                <td>@item.EmployeeName</td>
                                <td>@item.Department</td>
                                <td>@item.Designation</td>
                                <td>@item.EmployeeStatus</td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="Edit" asp-route-id="@item.uid" class="btn btn-warning btn-sm">Edit</a>
                                        <a asp-action="Details" asp-route-id="@item.uid" class="btn btn-info btn-sm">Details</a>
                                        <a asp-action="Delete" asp-route-id="@item.uid" class="btn btn-danger btn-sm">Delete</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            
            @if (!Model.Any())
            {
                <div class="alert alert-info">
                    No employees found matching the criteria.
                </div>
            }
            
            <!-- Pagination -->
            @if (Model.TotalPages > 1)
            {
                <nav aria-label="Employee pagination" class="mt-4">
                    <ul class="pagination justify-content-center">
                        @{
                            var prevDisabled = !Model.HasPreviousPage ? "disabled" : "";
                            var nextDisabled = !Model.HasNextPage ? "disabled" : "";
                        }
                        
                        <li class="page-item @prevDisabled">
                            <a class="page-link" asp-action="Index" asp-route-page="1" asp-route-pageSize="@ViewBag.CurrentPageSize" asp-route-department="@ViewBag.CurrentDepartment" asp-route-designation="@ViewBag.CurrentDesignation" asp-route-year2024="@ViewBag.CurrentYear2024" asp-route-applyTax="@ViewBag.CurrentApplyTax" asp-route-employeeName="@ViewBag.CurrentEmployeeName" asp-route-employeeID="@ViewBag.CurrentEmployeeID" asp-route-sortBy="@ViewBag.CurrentSortBy" asp-route-sortOrder="@ViewBag.CurrentSortOrder">&laquo;&laquo;</a>
                        </li>
                        
                        <li class="page-item @prevDisabled">
                            <a class="page-link" asp-action="Index" asp-route-page="@(Model.PageIndex - 1)" asp-route-pageSize="@ViewBag.CurrentPageSize" asp-route-department="@ViewBag.CurrentDepartment" asp-route-designation="@ViewBag.CurrentDesignation" asp-route-year2024="@ViewBag.CurrentYear2024" asp-route-applyTax="@ViewBag.CurrentApplyTax" asp-route-employeeName="@ViewBag.CurrentEmployeeName" asp-route-employeeID="@ViewBag.CurrentEmployeeID" asp-route-sortBy="@ViewBag.CurrentSortBy" asp-route-sortOrder="@ViewBag.CurrentSortOrder">&laquo;</a>
                        </li>
                        
                        @{
                            int startPage = Math.Max(1, Model.PageIndex - 2);
                            int endPage = Math.Min(Model.TotalPages, Model.PageIndex + 2);
                            if (endPage - startPage < 4)
                            {
                                if (startPage == 1) { endPage = Math.Min(Model.TotalPages, startPage + 4); }
                                else if (endPage == Model.TotalPages) { startPage = Math.Max(1, endPage - 4); }
                            }
                        }
                        
                        @for (int i = startPage; i <= endPage; i++)
                        {
                            var active = i == Model.PageIndex ? "active" : "";
                            <li class="page-item @active">
                                <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-pageSize="@ViewBag.CurrentPageSize" asp-route-department="@ViewBag.CurrentDepartment" asp-route-designation="@ViewBag.CurrentDesignation" asp-route-year2024="@ViewBag.CurrentYear2024" asp-route-applyTax="@ViewBag.CurrentApplyTax" asp-route-employeeName="@ViewBag.CurrentEmployeeName" asp-route-employeeID="@ViewBag.CurrentEmployeeID" asp-route-sortBy="@ViewBag.CurrentSortBy" asp-route-sortOrder="@ViewBag.CurrentSortOrder">@i</a>
                            </li>
                        }
                        
                        <li class="page-item @nextDisabled">
                            <a class="page-link" asp-action="Index" asp-route-page="@(Model.PageIndex + 1)" asp-route-pageSize="@ViewBag.CurrentPageSize" asp-route-department="@ViewBag.CurrentDepartment" asp-route-designation="@ViewBag.CurrentDesignation" asp-route-year2024="@ViewBag.CurrentYear2024" asp-route-applyTax="@ViewBag.CurrentApplyTax" asp-route-employeeName="@ViewBag.CurrentEmployeeName" asp-route-employeeID="@ViewBag.CurrentEmployeeID" asp-route-sortBy="@ViewBag.CurrentSortBy" asp-route-sortOrder="@ViewBag.CurrentSortOrder">&raquo;</a>
                        </li>
                        
                        <li class="page-item @nextDisabled">
                            <a class="page-link" asp-action="Index" asp-route-page="@Model.TotalPages" asp-route-pageSize="@ViewBag.CurrentPageSize" asp-route-department="@ViewBag.CurrentDepartment" asp-route-designation="@ViewBag.CurrentDesignation" asp-route-year2024="@ViewBag.CurrentYear2024" asp-route-applyTax="@ViewBag.CurrentApplyTax" asp-route-employeeName="@ViewBag.CurrentEmployeeName" asp-route-employeeID="@ViewBag.CurrentEmployeeID" asp-route-sortBy="@ViewBag.CurrentSortBy" asp-route-sortOrder="@ViewBag.CurrentSortOrder">&raquo;&raquo;</a>
                        </li>
                    </ul>
                </nav>
                
                <div class="text-center text-muted mb-3">
                    Page @Model.PageIndex of @Model.TotalPages
                </div>
            }
        </div>
    </div>
</div>
