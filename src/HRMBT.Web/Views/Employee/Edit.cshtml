@model HRMBT.Web.Models.Employee

@{
    ViewData["Title"] = "Edit Employee";
}

<div class="container">
    <div class="row">
        <div class="col-md-10 offset-md-1">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1>Edit Employee: @Model.EmployeeName</h1>
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>

            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="uid" />

                <div class="card mb-4">
                    <div class="card-header bg-primary text-white">Personal Information</div>
                    <div class="card-body row">
                        <div class="form-group col-md-4 mb-3">
                            <label asp-for="EmployeeID" class="control-label"></label>
                            <input asp-for="EmployeeID" class="form-control" />
                            <span asp-validation-for="EmployeeID" class="text-danger"></span>
                        </div>
                        <div class="form-group col-md-8 mb-3">
                            <label asp-for="EmployeeName" class="control-label"></label>
                            <input asp-for="EmployeeName" class="form-control" />
                            <span asp-validation-for="EmployeeName" class="text-danger"></span>
                        </div>
                        <div class="form-group col-md-6 mb-3">
                            <label asp-for="FatherName" class="control-label"></label>
                            <input asp-for="FatherName" class="form-control" />
                            <span asp-validation-for="FatherName" class="text-danger"></span>
                        </div>
                        <div class="form-group col-md-6 mb-3">
                            <label asp-for="CNIC" class="control-label"></label>
                            <input asp-for="CNIC" class="form-control" />
                            <span asp-validation-for="CNIC" class="text-danger"></span>
                        </div>
                        <div class="form-group col-md-4 mb-3">
                            <label asp-for="DOB" class="control-label"></label>
                            <input asp-for="DOB" type="date" class="form-control" />
                            <span asp-validation-for="DOB" class="text-danger"></span>
                        </div>
                        <div class="form-group col-md-4 mb-3">
                            <label asp-for="MobileNo" class="control-label"></label>
                            <input asp-for="MobileNo" class="form-control" />
                            <span asp-validation-for="MobileNo" class="text-danger"></span>
                        </div>
                        <div class="form-group col-md-4 mb-3">
                            <label asp-for="EmployeeStatus" class="control-label"></label>
                            <input asp-for="EmployeeStatus" class="form-control" />
                            <span asp-validation-for="EmployeeStatus" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="card mb-4">
                    <div class="card-header bg-success text-white">Professional Information</div>
                    <div class="card-body row">
                        <div class="form-group col-md-6 mb-3">
                            <label asp-for="Department" class="control-label"></label>
                            <input asp-for="Department" class="form-control" />
                            <span asp-validation-for="Department" class="text-danger"></span>
                        </div>
                        <div class="form-group col-md-6 mb-3">
                            <label asp-for="Designation" class="control-label"></label>
                            <input asp-for="Designation" class="form-control" />
                            <span asp-validation-for="Designation" class="text-danger"></span>
                        </div>
                        <div class="form-group col-md-4 mb-3">
                            <label asp-for="DateOfJoining" class="control-label"></label>
                            <input asp-for="DateOfJoining" type="date" class="form-control" />
                            <span asp-validation-for="DateOfJoining" class="text-danger"></span>
                        </div>
                        <div class="form-group col-md-4 mb-3">
                            <label asp-for="Project" class="control-label"></label>
                            <input asp-for="Project" class="form-control" />
                            <span asp-validation-for="Project" class="text-danger"></span>
                        </div>
                        <div class="form-group col-md-4 mb-3">
                            <label asp-for="ModifiedBy" class="control-label"></label>
                            <input asp-for="ModifiedBy" class="form-control" />
                            <span asp-validation-for="ModifiedBy" class="text-danger"></span>
                        </div>
                        <div class="form-group col-md-12 mb-3">
                            <label asp-for="Details" class="control-label"></label>
                            <textarea asp-for="Details" class="form-control" rows="2"></textarea>
                            <span asp-validation-for="Details" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="card mb-4">
                    <div class="card-header bg-info text-white">Financial & Leaves Information</div>
                    <div class="card-body row">
                        <div class="form-group col-md-4 mb-3">
                            <label asp-for="BasicSalary" class="control-label"></label>
                            <input asp-for="BasicSalary" class="form-control" />
                            <span asp-validation-for="BasicSalary" class="text-danger"></span>
                        </div>
                        <div class="form-group col-md-4 mb-3">
                            <label asp-for="CarryForwardLeaves" class="control-label"></label>
                            <input asp-for="CarryForwardLeaves" class="form-control" />
                            <span asp-validation-for="CarryForwardLeaves" class="text-danger"></span>
                        </div>
                        <div class="form-group col-md-3 mb-3">
                            <label asp-for="Year2022" class="control-label"></label>
                            <input asp-for="Year2022" class="form-control" />
                            <span asp-validation-for="Year2022" class="text-danger"></span>
                        </div>
                        <div class="form-group col-md-3 mb-3">
                            <label asp-for="Year2023" class="control-label"></label>
                            <input asp-for="Year2023" class="form-control" />
                            <span asp-validation-for="Year2023" class="text-danger"></span>
                        </div>
                        <div class="form-group col-md-3 mb-3">
                            <label asp-for="Year2023New" class="control-label"></label>
                            <input asp-for="Year2023New" class="form-control" />
                            <span asp-validation-for="Year2023New" class="text-danger"></span>
                        </div>
                        <div class="form-group col-md-3 mb-3">
                            <label asp-for="AdjustedAjusted" class="control-label"></label>
                            <input asp-for="AdjustedAjusted" class="form-control" />
                            <span asp-validation-for="AdjustedAjusted" class="text-danger"></span>
                        </div>
                        <div class="form-group col-md-6 mb-3">
                            <label asp-for="CarryForwardLeaves1" class="control-label"></label>
                            <input asp-for="CarryForwardLeaves1" class="form-control" />
                            <span asp-validation-for="CarryForwardLeaves1" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="form-group mt-4 mb-5">
                    <input type="submit" value="Save Changes" class="btn btn-warning btn-lg w-100" />
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
