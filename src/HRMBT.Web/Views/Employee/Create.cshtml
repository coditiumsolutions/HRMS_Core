@model HRMBT.Web.Models.Employee

@{
    ViewData["Title"] = "Add Employee";
}

@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="~/css/employee-create.css" asp-append-version="true" />
}

<div class="employee-create-page py-4">
    <div class="container-fluid px-3 px-lg-4">
        <!-- Breadcrumb -->
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb emp-breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index"><i class="fa-solid fa-gauge-high me-1"></i>Dashboard</a></li>
                <li class="breadcrumb-item"><a asp-action="Index"><i class="fa-solid fa-users me-1"></i>Employees</a></li>
                <li class="breadcrumb-item active" aria-current="page">Add Employee</li>
            </ol>
        </nav>

        <!-- Page header -->
        <div class="page-header-card p-4 mb-4">
            <div class="row align-items-center g-3">
                <div class="col">
                    <h1 class="page-title mb-1">
                        <span class="page-title-icon"><i class="fa-solid fa-user-plus"></i></span>
                        Add Employee
                    </h1>
                    <p class="text-muted mb-0">Complete each section below. All fields use your existing employee profile and payroll bindings.</p>
                </div>
            </div>
        </div>

        <form asp-action="Create" method="post" id="employeeCreateForm" data-tab-storage-key="hrms.employeeCreate.activeTab">
            <div asp-validation-summary="All" class="mb-4" role="alert"></div>

            <div class="row g-4">
                <div class="col-12">
                    <div class="card section-card emp-tabs-card shadow-sm">
                        <!-- Tab navigation -->
                        <div class="emp-tabs-nav border-bottom">
                            <ul class="nav nav-tabs emp-nav-tabs flex-nowrap" id="employeeCreateTabs" role="tablist">
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link active" id="tab-personal-btn" data-bs-toggle="tab" data-bs-target="#tab-personal" type="button" role="tab" aria-controls="tab-personal" aria-selected="true" data-tab-key="personal">
                                        <i class="fa-solid fa-id-card"></i><span>Personal Information</span>
                                    </button>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link" id="tab-official-btn" data-bs-toggle="tab" data-bs-target="#tab-official" type="button" role="tab" aria-controls="tab-official" aria-selected="false" data-tab-key="official">
                                        <i class="fa-solid fa-building"></i><span>Official Information</span>
                                    </button>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link" id="tab-salary-btn" data-bs-toggle="tab" data-bs-target="#tab-salary" type="button" role="tab" aria-controls="tab-salary" aria-selected="false" data-tab-key="salary">
                                        <i class="fa-solid fa-money-bill-wave"></i><span>Salary Information</span>
                                    </button>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link" id="tab-leave-btn" data-bs-toggle="tab" data-bs-target="#tab-leave" type="button" role="tab" aria-controls="tab-leave" aria-selected="false" data-tab-key="leave">
                                        <i class="fa-solid fa-calendar-check"></i><span>Leave Balances &amp; Adjustments</span>
                                    </button>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link" id="tab-additional-btn" data-bs-toggle="tab" data-bs-target="#tab-additional" type="button" role="tab" aria-controls="tab-additional" aria-selected="false" data-tab-key="additional">
                                        <i class="fa-solid fa-circle-info"></i><span>Additional Information</span>
                                    </button>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link" id="tab-attachments-btn" data-bs-toggle="tab" data-bs-target="#tab-attachments" type="button" role="tab" aria-controls="tab-attachments" aria-selected="false" data-tab-key="attachments">
                                        <i class="fa-solid fa-paperclip"></i><span>Attachments</span>
                                    </button>
                                </li>
                            </ul>
                        </div>

                        <div class="card-body p-0">
                            <div class="tab-content emp-tab-content" id="employeeCreateTabContent">

                                <!-- Personal Information -->
                                <div class="tab-pane fade show active" id="tab-personal" role="tabpanel" aria-labelledby="tab-personal-btn" tabindex="0" data-tab-panel="personal">
                                    <div class="emp-tab-pane-inner">
                                        <h2 class="emp-section-header"><i class="fa-solid fa-user"></i> Personal Information</h2>
                                        <p class="emp-section-sub">Identity and primary contact details for the employee record.</p>
                                        <div class="table-responsive emp-table-wrap">
                                            <table class="table emp-form-table mb-0">
                                                <tbody>
                                                    <tr class="emp-form-row">
                                                        <th scope="row" class="emp-label-cell"><label asp-for="EmployeeID" class="form-label mb-0"></label></th>
                                                        <td class="emp-field-cell">
                                                            <input asp-for="EmployeeID" class="form-control" placeholder="e.g. EMP-1024" autocomplete="off" />
                                                            <span asp-validation-for="EmployeeID" class="field-validation-error"></span>
                                                        </td>
                                                        <th scope="row" class="emp-label-cell"><label asp-for="EmployeeName" class="form-label mb-0"></label></th>
                                                        <td class="emp-field-cell">
                                                            <input asp-for="EmployeeName" class="form-control" placeholder="Full legal name" autocomplete="name" />
                                                            <span asp-validation-for="EmployeeName" class="field-validation-error"></span>
                                                        </td>
                                                    </tr>
                                                    <tr class="emp-form-row">
                                                        <th scope="row" class="emp-label-cell"><label asp-for="FatherName" class="form-label mb-0"></label></th>
                                                        <td class="emp-field-cell">
                                                            <input asp-for="FatherName" class="form-control" placeholder="Father / guardian name" />
                                                            <span asp-validation-for="FatherName" class="field-validation-error"></span>
                                                        </td>
                                                        <th scope="row" class="emp-label-cell"><label asp-for="CNIC" class="form-label mb-0"></label></th>
                                                        <td class="emp-field-cell">
                                                            <input asp-for="CNIC" class="form-control" placeholder="XXXXX-XXXXXXX-X" />
                                                            <span asp-validation-for="CNIC" class="field-validation-error"></span>
                                                        </td>
                                                    </tr>
                                                    <tr class="emp-form-row">
                                                        <th scope="row" class="emp-label-cell"><label asp-for="DOB" class="form-label mb-0"></label></th>
                                                        <td class="emp-field-cell">
                                                            <input asp-for="DOB" type="date" class="form-control" />
                                                            <span asp-validation-for="DOB" class="field-validation-error"></span>
                                                        </td>
                                                        <th scope="row" class="emp-label-cell"><label asp-for="MobileNo" class="form-label mb-0"></label></th>
                                                        <td class="emp-field-cell">
                                                            <input asp-for="MobileNo" class="form-control" placeholder="Primary mobile number" inputmode="tel" />
                                                            <span asp-validation-for="MobileNo" class="field-validation-error"></span>
                                                        </td>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>

                                <!-- Official Information -->
                                <div class="tab-pane fade" id="tab-official" role="tabpanel" aria-labelledby="tab-official-btn" tabindex="0" data-tab-panel="official">
                                    <div class="emp-tab-pane-inner">
                                        <h2 class="emp-section-header"><i class="fa-solid fa-briefcase"></i> Official Information</h2>
                                        <p class="emp-section-sub">Department, role, project assignment, and employment status.</p>
                                        <div class="table-responsive emp-table-wrap">
                                            <table class="table emp-form-table mb-0">
                                                <tbody>
                                                    <tr class="emp-form-row">
                                                        <th scope="row" class="emp-label-cell"><label asp-for="Department" class="form-label mb-0"></label></th>
                                                        <td class="emp-field-cell">
                                                            <select asp-for="Department" class="form-select">
                                                                <option value="">— Select Department —</option>
                                                                @if (ViewBag.DepartmentOptions is IEnumerable<string> deptOptions)
                                                                {
                                                                    foreach (var dept in deptOptions)
                                                                    {
                                                                        <option value="@dept">@dept</option>
                                                                    }
                                                                }
                                                            </select>
                                                            <span asp-validation-for="Department" class="field-validation-error"></span>
                                                        </td>
                                                        <th scope="row" class="emp-label-cell"><label asp-for="Designation" class="form-label mb-0"></label></th>
                                                        <td class="emp-field-cell">
                                                            <select asp-for="Designation" class="form-select">
                                                                <option value="">— Select Designation —</option>
                                                                @if (ViewBag.DesignationOptions is IEnumerable<string> desigOptions)
                                                                {
                                                                    foreach (var desig in desigOptions)
                                                                    {
                                                                        <option value="@desig">@desig</option>
                                                                    }
                                                                }
                                                            </select>
                                                            <span asp-validation-for="Designation" class="field-validation-error"></span>
                                                        </td>
                                                    </tr>
                                                    <tr class="emp-form-row">
                                                        <th scope="row" class="emp-label-cell"><label asp-for="Project" class="form-label mb-0"></label></th>
                                                        <td class="emp-field-cell">
                                                            <select asp-for="Project" class="form-select">
                                                                <option value="">— Select Project —</option>
                                                                @if (ViewBag.ProjectOptions is IEnumerable<string> projectOptions)
                                                                {
                                                                    foreach (var project in projectOptions)
                                                                    {
                                                                        <option value="@project">@project</option>
                                                                    }
                                                                }
                                                            </select>
                                                            <span asp-validation-for="Project" class="field-validation-error"></span>
                                                        </td>
                                                        <th scope="row" class="emp-label-cell"><label asp-for="DateOfJoining" class="form-label mb-0"></label></th>
                                                        <td class="emp-field-cell">
                                                            <input asp-for="DateOfJoining" type="date" class="form-control" />
                                                            <span asp-validation-for="DateOfJoining" class="field-validation-error"></span>
                                                        </td>
                                                    </tr>
                                                    <tr class="emp-form-row">
                                                        <th scope="row" class="emp-label-cell"><label asp-for="EmployeeStatus" class="form-label mb-0"></label></th>
                                                        <td class="emp-field-cell" colspan="3">
                                                            <select asp-for="EmployeeStatus" class="form-select emp-field-narrow">
                                                                <option value="">— Select Status —</option>
                                                                @if (ViewBag.EmployeeStatusOptions is IEnumerable<string> statusOptions)
                                                                {
                                                                    foreach (var status in statusOptions)
                                                                    {
                                                                        <option value="@status">@status</option>
                                                                    }
                                                                }
                                                            </select>
                                                            <span asp-validation-for="EmployeeStatus" class="field-validation-error"></span>
                                                        </td>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>

                                <!-- Salary Information -->
                                <div class="tab-pane fade" id="tab-salary" role="tabpanel" aria-labelledby="tab-salary-btn" tabindex="0" data-tab-panel="salary">
                                    <div class="emp-tab-pane-inner">
                                        <h2 class="emp-section-header"><i class="fa-solid fa-sack-dollar"></i> Salary Information</h2>
                                        <p class="emp-section-sub">Compensation baseline and tax application for payroll processing.</p>
                                        <div class="table-responsive emp-table-wrap">
                                            <table class="table emp-form-table mb-0">
                                                <tbody>
                                                    <tr class="emp-form-row">
                                                        <th scope="row" class="emp-label-cell"><label asp-for="BasicSalary" class="form-label mb-0"></label></th>
                                                        <td class="emp-field-cell">
                                                            <input asp-for="BasicSalary" class="form-control" type="number" step="0.01" min="0" placeholder="0.00" />
                                                            <span asp-validation-for="BasicSalary" class="field-validation-error"></span>
                                                        </td>
                                                        <th scope="row" class="emp-label-cell"><label asp-for="ApplyTax" class="form-label mb-0"></label></th>
                                                        <td class="emp-field-cell">
                                                            <select asp-for="ApplyTax" class="form-select">
                                                                <option value="">— Select —</option>
                                                                <option value="Yes">Yes</option>
                                                                <option value="No">No</option>
                                                            </select>
                                                            <span asp-validation-for="ApplyTax" class="field-validation-error"></span>
                                                        </td>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>

                                <!-- Leave Balances & Adjustments -->
                                <div class="tab-pane fade" id="tab-leave" role="tabpanel" aria-labelledby="tab-leave-btn" tabindex="0" data-tab-panel="leave">
                                    <div class="emp-tab-pane-inner">
                                        <h2 class="emp-section-header"><i class="fa-solid fa-umbrella-beach"></i> Leave Balances &amp; Adjustments</h2>
                                        <p class="emp-section-sub">Optional carry-forward and historical leave totals.</p>
                                        <div class="table-responsive emp-table-wrap">
                                            <table class="table emp-form-table mb-0">
                                                <tbody>
                                                    <tr class="emp-form-row">
                                                        <th scope="row" class="emp-label-cell"><label asp-for="CarryForwardLeaves" class="form-label mb-0"></label></th>
                                                        <td class="emp-field-cell">
                                                            <input asp-for="CarryForwardLeaves" class="form-control" type="number" step="0.01" placeholder="0" />
                                                            <span asp-validation-for="CarryForwardLeaves" class="field-validation-error"></span>
                                                        </td>
                                                        <th scope="row" class="emp-label-cell"><label asp-for="CarryForwardLeaves1" class="form-label mb-0"></label></th>
                                                        <td class="emp-field-cell">
                                                            <input asp-for="CarryForwardLeaves1" class="form-control" type="number" step="0.01" placeholder="0" />
                                                            <span asp-validation-for="CarryForwardLeaves1" class="field-validation-error"></span>
                                                        </td>
                                                    </tr>
                                                    <tr class="emp-form-row">
                                                        <th scope="row" class="emp-label-cell"><label asp-for="Year2024" class="form-label mb-0"></label></th>
                                                        <td class="emp-field-cell">
                                                            <input asp-for="Year2024" class="form-control" type="number" placeholder="e.g. 2024" />
                                                            <span asp-validation-for="Year2024" class="field-validation-error"></span>
                                                        </td>
                                                        <th scope="row" class="emp-label-cell"><label asp-for="Year2022" class="form-label mb-0"></label></th>
                                                        <td class="emp-field-cell">
                                                            <input asp-for="Year2022" class="form-control" type="number" step="0.01" placeholder="0" />
                                                            <span asp-validation-for="Year2022" class="field-validation-error"></span>
                                                        </td>
                                                    </tr>
                                                    <tr class="emp-form-row">
                                                        <th scope="row" class="emp-label-cell"><label asp-for="Year2023" class="form-label mb-0"></label></th>
                                                        <td class="emp-field-cell">
                                                            <input asp-for="Year2023" class="form-control" type="number" step="0.01" placeholder="0" />
                                                            <span asp-validation-for="Year2023" class="field-validation-error"></span>
                                                        </td>
                                                        <th scope="row" class="emp-label-cell"><label asp-for="Year2023New" class="form-label mb-0"></label></th>
                                                        <td class="emp-field-cell">
                                                            <input asp-for="Year2023New" class="form-control" type="number" step="0.01" placeholder="0" />
                                                            <span asp-validation-for="Year2023New" class="field-validation-error"></span>
                                                        </td>
                                                    </tr>
                                                    <tr class="emp-form-row">
                                                        <th scope="row" class="emp-label-cell"><label asp-for="AdjustedAjusted" class="form-label mb-0"></label></th>
                                                        <td class="emp-field-cell" colspan="3">
                                                            <input asp-for="AdjustedAjusted" class="form-control emp-field-narrow" type="number" placeholder="0" />
                                                            <span asp-validation-for="AdjustedAjusted" class="field-validation-error"></span>
                                                        </td>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>

                                <!-- Additional Information -->
                                <div class="tab-pane fade" id="tab-additional" role="tabpanel" aria-labelledby="tab-additional-btn" tabindex="0" data-tab-panel="additional">
                                    <div class="emp-tab-pane-inner">
                                        <h2 class="emp-section-header"><i class="fa-solid fa-file-lines"></i> Additional Information</h2>
                                        <p class="emp-section-sub">Notes, remarks, and audit fields for HR onboarding context.</p>
                                        <div class="table-responsive emp-table-wrap">
                                            <table class="table emp-form-table mb-0">
                                                <tbody>
                                                    <tr class="emp-form-row">
                                                        <th scope="row" class="emp-label-cell align-top pt-3"><label asp-for="Details" class="form-label mb-0"></label></th>
                                                        <td class="emp-field-cell" colspan="3">
                                                            <textarea asp-for="Details" class="form-control" rows="4" placeholder="Notes, remarks, or onboarding context"></textarea>
                                                            <span asp-validation-for="Details" class="field-validation-error"></span>
                                                        </td>
                                                    </tr>
                                                    <tr class="emp-form-row">
                                                        <th scope="row" class="emp-label-cell"><label asp-for="ModifiedBy" class="form-label mb-0"></label></th>
                                                        <td class="emp-field-cell" colspan="3">
                                                            <input asp-for="ModifiedBy" class="form-control emp-field-narrow" placeholder="Recorder / HR officer name" />
                                                            <span asp-validation-for="ModifiedBy" class="field-validation-error"></span>
                                                        </td>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </div>
                                        <div class="alert alert-light border mt-3 mb-0 d-flex gap-3 align-items-start">
                                            <i class="fa-solid fa-phone text-primary fs-5 flex-shrink-0 mt-1"></i>
                                            <div class="small text-muted mb-0">
                                                <strong class="text-dark d-block mb-1">Primary contact</strong>
                                                Mobile number is recorded under <strong>Personal Information</strong> for SMS, attendance alerts, and HR correspondence.
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Attachments -->
                                <div class="tab-pane fade" id="tab-attachments" role="tabpanel" aria-labelledby="tab-attachments-btn" tabindex="0" data-tab-panel="attachments">
                                    <div class="emp-tab-pane-inner">
                                        <h2 class="emp-section-header"><i class="fa-solid fa-paperclip"></i> Attachments</h2>
                                        <p class="emp-section-sub">Save the employee first, then upload documents from the Edit screen.</p>
                                        <div class="alert alert-info border-0 mb-4">
                                            <i class="fa-solid fa-circle-info me-2"></i>
                                            Document upload is available after the employee record is created (Edit &gt; Attachments tab).
                                        </div>
                                        <div class="row g-4 justify-content-center">
                                            <div class="col-md-8 col-lg-6">
                                                <div class="card border-0 bg-light emp-attachment-card">
                                                    <div class="card-body text-center py-4">
                                                        <div class="photo-preview-wrap mx-auto">
                                                            <img id="employeePhotoPreview" src="@Url.Content("~/images/employee-avatar-placeholder.svg")" data-placeholder-src="@Url.Content("~/images/employee-avatar-placeholder.svg")" alt="Profile preview" />
                                                        </div>
                                                        <input type="file" id="employeePhotoFile" class="d-none" accept="image/*" aria-label="Choose employee photo" />
                                                        <button type="button" class="btn btn-upload w-100 py-2 mt-3 mb-2" id="employeePhotoBrowse">
                                                            <i class="fa-solid fa-upload me-2"></i>Upload photo
                                                        </button>
                                                        <p class="small text-muted mb-0">Preview only — wire-up storage when your API is ready.</p>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="alert alert-warning border-0 mt-4 mb-0 small">
                                            <i class="fa-solid fa-lightbulb me-2"></i>
                                            Double-check <strong>Employee ID</strong> and <strong>CNIC</strong> on the Personal tab before saving — they drive uniqueness and compliance reports.
                                        </div>
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sticky action footer -->
            <div class="employee-create-actions">
                <div class="container-fluid px-3 px-lg-4">
                    <div class="d-flex flex-wrap align-items-center justify-content-between gap-2">
                        <div class="small text-muted d-none d-md-block">
                            <i class="fa-solid fa-floppy-disk me-1"></i>Changes are saved to the employee directory.
                        </div>
                        <div class="d-flex flex-wrap align-items-center gap-2 ms-md-auto">
                            <a asp-action="Index" class="btn btn-action-outline">
                                <i class="fa-solid fa-arrow-left me-1"></i>Back
                            </a>
                            <button type="reset" class="btn btn-action-secondary" id="employeeFormReset">
                                <i class="fa-solid fa-rotate-left me-1"></i>Reset
                            </button>
                            <button type="submit" class="btn btn-action-primary" id="employeeFormSubmit">
                                <span class="spinner-border spinner-border-sm me-2 d-none" id="employeeSaveSpinner" role="status" aria-hidden="true"></span>
                                <i class="fa-solid fa-check me-1" id="employeeSaveIcon"></i>Save
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script src="~/js/employee-create.js" asp-append-version="true"></script>
}
