@model HRMBT.Web.Models.Employee

@{
    ViewData["Title"] = "Add Employee";
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" crossorigin="anonymous" />
    <link rel="stylesheet" href="~/css/employee-create.css" asp-append-version="true" />
}

<div class="employee-create-page py-4">
    <div class="container-fluid px-3 px-lg-4">
        <!-- Breadcrumb -->
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
                <li class="breadcrumb-item"><a asp-action="Index">Employees</a></li>
                <li class="breadcrumb-item active" aria-current="page">Add Employee</li>
            </ol>
        </nav>

        <!-- Page header -->
        <div class="page-header-card p-4 mb-4">
            <div class="row align-items-center g-3">
                <div class="col-lg">
                    <h1 class="h2 mb-1 fw-bold text-dark">Add Employee</h1>
                    <p class="text-muted mb-0">Employee Management System — capture profile, assignment, and compensation in one place.</p>
                </div>
                <div class="col-lg-auto d-none d-lg-block">
                    <span class="badge rounded-pill text-bg-light border px-3 py-2 text-secondary">
                        <i class="bi bi-shield-check me-1 text-success"></i> Secure entry
                    </span>
                </div>
            </div>
        </div>

        <form asp-action="Create" method="post" id="employeeCreateForm">
            <div asp-validation-summary="All" class="mb-4" role="alert"></div>

            <div class="row g-4">
                <!-- Main form column -->
                <div class="col-lg-8">
                    <!-- Personal Information -->
                    <div class="card section-card mb-4">
                        <div class="card-header">
                            <i class="bi bi-person-badge"></i>Personal Information
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label asp-for="EmployeeID" class="form-label"></label>
                                    <input asp-for="EmployeeID" class="form-control" placeholder="e.g. EMP-1024" autocomplete="off" />
                                    <span asp-validation-for="EmployeeID" class="field-validation-error"></span>
                                </div>
                                <div class="col-md-8">
                                    <label asp-for="EmployeeName" class="form-label"></label>
                                    <input asp-for="EmployeeName" class="form-control" placeholder="Full legal name" autocomplete="name" />
                                    <span asp-validation-for="EmployeeName" class="field-validation-error"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="FatherName" class="form-label"></label>
                                    <input asp-for="FatherName" class="form-control" placeholder="Father / guardian name" />
                                    <span asp-validation-for="FatherName" class="field-validation-error"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="CNIC" class="form-label"></label>
                                    <input asp-for="CNIC" class="form-control" placeholder="XXXXX-XXXXXXX-X" />
                                    <span asp-validation-for="CNIC" class="field-validation-error"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="DOB" class="form-label"></label>
                                    <input asp-for="DOB" type="date" class="form-control" />
                                    <span asp-validation-for="DOB" class="field-validation-error"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="MobileNo" class="form-label"></label>
                                    <input asp-for="MobileNo" class="form-control" placeholder="Primary mobile number" inputmode="tel" />
                                    <span asp-validation-for="MobileNo" class="field-validation-error"></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Official Information -->
                    <div class="card section-card mb-4">
                        <div class="card-header">
                            <i class="bi bi-building"></i>Official Information
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label asp-for="Department" class="form-label"></label>
                                    <select asp-for="Department" class="form-select">
                                        <option value="">— Select Department —</option>
                                        @if (ViewBag.DepartmentOptions is IEnumerable<string> deptOptions)
                                        {
                                            foreach (var dept in deptOptions)
                                            {
                                                <option value="@dept">@dept</option>
                                            }
                                        }
                                    </select>
                                    <span asp-validation-for="Department" class="field-validation-error"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="Designation" class="form-label"></label>
                                    <select asp-for="Designation" class="form-select">
                                        <option value="">— Select Designation —</option>
                                        @if (ViewBag.DesignationOptions is IEnumerable<string> desigOptions)
                                        {
                                            foreach (var desig in desigOptions)
                                            {
                                                <option value="@desig">@desig</option>
                                            }
                                        }
                                    </select>
                                    <span asp-validation-for="Designation" class="field-validation-error"></span>
                                </div>
                                <div class="col-md-4">
                                    <label asp-for="Project" class="form-label"></label>
                                    <select asp-for="Project" class="form-select">
                                        <option value="">— Select Project —</option>
                                        @if (ViewBag.ProjectOptions is IEnumerable<string> projectOptions)
                                        {
                                            foreach (var project in projectOptions)
                                            {
                                                <option value="@project">@project</option>
                                            }
                                        }
                                    </select>
                                    <span asp-validation-for="Project" class="field-validation-error"></span>
                                </div>
                                <div class="col-md-4">
                                    <label asp-for="DateOfJoining" class="form-label"></label>
                                    <input asp-for="DateOfJoining" type="date" class="form-control" />
                                    <span asp-validation-for="DateOfJoining" class="field-validation-error"></span>
                                </div>
                                <div class="col-md-4">
                                    <label asp-for="EmployeeStatus" class="form-label"></label>
                                    <select asp-for="EmployeeStatus" class="form-select">
                                        <option value="">— Select Status —</option>
                                        @if (ViewBag.EmployeeStatusOptions is IEnumerable<string> statusOptions)
                                        {
                                            foreach (var status in statusOptions)
                                            {
                                                <option value="@status">@status</option>
                                            }
                                        }
                                    </select>
                                    <span asp-validation-for="EmployeeStatus" class="field-validation-error"></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Salary Information -->
                    <div class="card section-card mb-4">
                        <div class="card-header">
                            <i class="bi bi-cash-stack"></i>Salary Information
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label asp-for="BasicSalary" class="form-label"></label>
                                    <input asp-for="BasicSalary" class="form-control" type="number" step="0.01" min="0" placeholder="0.00" />
                                    <span asp-validation-for="BasicSalary" class="field-validation-error"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="ApplyTax" class="form-label"></label>
                                    <select asp-for="ApplyTax" class="form-select">
                                        <option value="">— Select —</option>
                                        <option value="Yes">Yes</option>
                                        <option value="No">No</option>
                                    </select>
                                    <span asp-validation-for="ApplyTax" class="field-validation-error"></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Contact Information -->
                    <div class="card section-card mb-4">
                        <div class="card-header">
                            <i class="bi bi-telephone"></i>Contact Information
                        </div>
                        <div class="card-body">
                            <div class="alert alert-light border mb-0 d-flex gap-3 align-items-start">
                                <i class="bi bi-info-circle text-primary fs-4 flex-shrink-0"></i>
                                <div>
                                    <strong class="d-block text-dark mb-1">Primary contact</strong>
                                    <p class="small text-muted mb-0">
                                        Mobile number is recorded under <strong>Personal Information</strong>. Use it for SMS, attendance alerts, and HR correspondence.
                                        Additional contact channels (email, extension) can be added to the database when those fields are available.
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Leave balances & adjustments (preserves model binding) -->
                    <div class="card section-card mb-4">
                        <div class="card-header">
                            <i class="bi bi-calendar2-check"></i>Leave balances &amp; adjustments
                        </div>
                        <div class="card-body">
                            <p class="small text-muted mb-3">Optional fields — used for carry-forward and historical leave totals.</p>
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label asp-for="CarryForwardLeaves" class="form-label"></label>
                                    <input asp-for="CarryForwardLeaves" class="form-control" type="number" step="0.01" placeholder="0" />
                                    <span asp-validation-for="CarryForwardLeaves" class="field-validation-error"></span>
                                </div>
                                <div class="col-md-4">
                                    <label asp-for="CarryForwardLeaves1" class="form-label"></label>
                                    <input asp-for="CarryForwardLeaves1" class="form-control" type="number" step="0.01" placeholder="0" />
                                    <span asp-validation-for="CarryForwardLeaves1" class="field-validation-error"></span>
                                </div>
                                <div class="col-md-4">
                                    <label asp-for="Year2024" class="form-label"></label>
                                    <input asp-for="Year2024" class="form-control" type="number" placeholder="e.g. 2024" />
                                    <span asp-validation-for="Year2024" class="field-validation-error"></span>
                                </div>
                                <div class="col-md-4">
                                    <label asp-for="Year2022" class="form-label"></label>
                                    <input asp-for="Year2022" class="form-control" type="number" step="0.01" placeholder="0" />
                                    <span asp-validation-for="Year2022" class="field-validation-error"></span>
                                </div>
                                <div class="col-md-4">
                                    <label asp-for="Year2023" class="form-label"></label>
                                    <input asp-for="Year2023" class="form-control" type="number" step="0.01" placeholder="0" />
                                    <span asp-validation-for="Year2023" class="field-validation-error"></span>
                                </div>
                                <div class="col-md-4">
                                    <label asp-for="Year2023New" class="form-label"></label>
                                    <input asp-for="Year2023New" class="form-control" type="number" step="0.01" placeholder="0" />
                                    <span asp-validation-for="Year2023New" class="field-validation-error"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="AdjustedAjusted" class="form-label"></label>
                                    <input asp-for="AdjustedAjusted" class="form-control" type="number" placeholder="0" />
                                    <span asp-validation-for="AdjustedAjusted" class="field-validation-error"></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Additional Information -->
                    <div class="card section-card mb-4">
                        <div class="card-header">
                            <i class="bi bi-journal-text"></i>Additional Information
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-12">
                                    <label asp-for="Details" class="form-label"></label>
                                    <textarea asp-for="Details" class="form-control" rows="4" placeholder="Notes, remarks, or onboarding context"></textarea>
                                    <span asp-validation-for="Details" class="field-validation-error"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="ModifiedBy" class="form-label"></label>
                                    <input asp-for="ModifiedBy" class="form-control" placeholder="Recorder / HR officer name" />
                                    <span asp-validation-for="ModifiedBy" class="field-validation-error"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Photo & summary column -->
                <div class="col-lg-4">
                    <div class="card section-card photo-card sticky-lg-top mb-4" style="top: 1rem;">
                        <div class="card-header">
                            <i class="bi bi-camera"></i>Employee photo
                        </div>
                        <div class="card-body text-center">
                            <div class="photo-preview-wrap">
                                <img id="employeePhotoPreview" src="~/images/employee-avatar-placeholder.svg" alt="Profile preview" />
                            </div>
                            <input type="file" id="employeePhotoFile" class="d-none" accept="image/*" aria-label="Choose employee photo" />
                            <button type="button" class="btn btn-upload w-100 py-2 mb-2" id="employeePhotoBrowse">
                                <i class="bi bi-cloud-upload me-2"></i>Upload photo
                            </button>
                            <p class="small text-muted mb-0">Preview only — wire-up storage when your API is ready. Does not affect save.</p>
                        </div>
                    </div>

                    <div class="card border-0 shadow-sm bg-white mb-4">
                        <div class="card-body small text-muted">
                            <div class="d-flex align-items-start gap-2 mb-2">
                                <i class="bi bi-lightbulb text-warning fs-5"></i>
                                <div>
                                    <strong class="text-dark d-block">Tip</strong>
                                    Double-check <span class="text-dark fw-semibold">Employee ID</span> and <span class="text-dark fw-semibold">CNIC</span> before saving — they drive uniqueness and compliance reports.
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sticky actions -->
            <div class="employee-create-actions">
                <div class="container-fluid px-3 px-lg-4">
                    <div class="d-flex flex-wrap align-items-center justify-content-between gap-2">
                        <div class="small text-muted d-none d-md-block">
                            <i class="bi bi-save me-1"></i>Changes are saved to the employee directory.
                        </div>
                        <div class="d-flex flex-wrap align-items-center gap-2 ms-md-auto">
                            <a asp-action="Index" class="btn btn-action-outline">
                                <i class="bi bi-arrow-left-short me-1"></i>Back to list
                            </a>
                            <button type="reset" class="btn btn-action-secondary" id="employeeFormReset">
                                <i class="bi bi-arrow-counterclockwise me-1"></i>Reset
                            </button>
                            <button type="submit" class="btn btn-action-primary" id="employeeFormSubmit">
                                <span class="spinner-border spinner-border-sm me-2 d-none" id="employeeSaveSpinner" role="status" aria-hidden="true"></span>
                                <i class="bi bi-check2-circle me-1" id="employeeSaveIcon"></i>Save employee
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        (function () {
            var form = document.getElementById('employeeCreateForm');
            var fileInput = document.getElementById('employeePhotoFile');
            var browseBtn = document.getElementById('employeePhotoBrowse');
            var preview = document.getElementById('employeePhotoPreview');
            var placeholderSrc = '@Url.Content("~/images/employee-avatar-placeholder.svg")';
            var submitBtn = document.getElementById('employeeFormSubmit');
            var spinner = document.getElementById('employeeSaveSpinner');
            var icon = document.getElementById('employeeSaveIcon');

            if (browseBtn && fileInput) {
                browseBtn.addEventListener('click', function () { fileInput.click(); });
                fileInput.addEventListener('change', function () {
                    var f = fileInput.files && fileInput.files[0];
                    if (!f || !f.type.match(/^image\//)) return;
                    var reader = new FileReader();
                    reader.onload = function (e) { preview.src = e.target.result; };
                    reader.readAsDataURL(f);
                });
            }

            var resetBtn = document.getElementById('employeeFormReset');
            if (resetBtn && preview) {
                resetBtn.addEventListener('click', function () {
                    setTimeout(function () {
                        preview.src = placeholderSrc;
                        if (fileInput) fileInput.value = '';
                    }, 0);
                });
            }

            if (form && submitBtn && spinner && icon && window.jQuery) {
                window.jQuery(function ($) {
                    var $form = $(form);
                    $form.on('submit', function () {
                        if (!$form.valid()) {
                            return;
                        }
                        spinner.classList.remove('d-none');
                        icon.classList.add('d-none');
                        submitBtn.disabled = true;
                    });
                });
            }
        })();
    </script>
}
