@model HRMBT.Web.Models.Employee

@{
    ViewData["Title"] = "Employee Details";
}

<div class="container">
    <div class="row">
        <div class="col-md-10 offset-md-1">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1>Employee Details: @Model.EmployeeName</h1>
                <div>
                    <a asp-action="Edit" asp-route-id="@Model.uid" class="btn btn-warning">Edit</a>
                    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header bg-primary text-white">Personal Information</div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.EmployeeID)</dt>
                        <dd class="col-sm-3">@Html.DisplayFor(model => model.EmployeeID)</dd>
                        
                        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.EmployeeName)</dt>
                        <dd class="col-sm-3">@Html.DisplayFor(model => model.EmployeeName)</dd>

                        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.FatherName)</dt>
                        <dd class="col-sm-3">@Html.DisplayFor(model => model.FatherName)</dd>

                        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.CNIC)</dt>
                        <dd class="col-sm-3">@Html.DisplayFor(model => model.CNIC)</dd>

                        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.DOB)</dt>
                        <dd class="col-sm-3">@Html.DisplayFor(model => model.DOB)</dd>

                        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.MobileNo)</dt>
                        <dd class="col-sm-3">@Html.DisplayFor(model => model.MobileNo)</dd>

                        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.EmployeeStatus)</dt>
                        <dd class="col-sm-3">@Html.DisplayFor(model => model.EmployeeStatus)</dd>
                    </dl>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header bg-success text-white">Professional Information</div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Department)</dt>
                        <dd class="col-sm-3">@Html.DisplayFor(model => model.Department)</dd>

                        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Designation)</dt>
                        <dd class="col-sm-3">@Html.DisplayFor(model => model.Designation)</dd>

                        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.DateOfJoining)</dt>
                        <dd class="col-sm-3">@Html.DisplayFor(model => model.DateOfJoining)</dd>

                        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Project)</dt>
                        <dd class="col-sm-3">@Html.DisplayFor(model => model.Project)</dd>

                        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.ModifiedBy)</dt>
                        <dd class="col-sm-3">@Html.DisplayFor(model => model.ModifiedBy)</dd>

                        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.ModifiedOn)</dt>
                        <dd class="col-sm-3">@Html.DisplayFor(model => model.ModifiedOn)</dd>

                        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Details)</dt>
                        <dd class="col-sm-9">@Html.DisplayFor(model => model.Details)</dd>
                    </dl>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header bg-info text-white">Financial & Leaves Information</div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.BasicSalary)</dt>
                        <dd class="col-sm-3">@Html.DisplayFor(model => model.BasicSalary)</dd>

                        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.ApplyTax)</dt>
                        <dd class="col-sm-3">@(Model.ApplyTax == "1" ? "Yes" : "No")</dd>

                        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.CarryForwardLeaves)</dt>
                        <dd class="col-sm-3">@Html.DisplayFor(model => model.CarryForwardLeaves)</dd>

                        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Year2022)</dt>
                        <dd class="col-sm-3">@Html.DisplayFor(model => model.Year2022)</dd>

                        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Year2023)</dt>
                        <dd class="col-sm-3">@Html.DisplayFor(model => model.Year2023)</dd>

                        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Year2023New)</dt>
                        <dd class="col-sm-3">@Html.DisplayFor(model => model.Year2023New)</dd>

                        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.AdjustedAjusted)</dt>
                        <dd class="col-sm-3">@Html.DisplayFor(model => model.AdjustedAjusted)</dd>

                        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Year2024)</dt>
                        <dd class="col-sm-3">@Html.DisplayFor(model => model.Year2024)</dd>

                        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.CarryForwardLeaves1)</dt>
                        <dd class="col-sm-3">@Html.DisplayFor(model => model.CarryForwardLeaves1)</dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>
</div>
