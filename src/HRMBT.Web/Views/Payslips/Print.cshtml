@model HRMBT.Web.Models.Payslip
@{
    Layout = null;
    ViewData["Title"] = "Payslip — Print";
    var allowanceLines = (Model.PayslipDetails ?? Enumerable.Empty<HRMBT.Web.Models.PayslipDetail>())
        .Where(d => string.Equals(d.ItemType, "Allowance", StringComparison.OrdinalIgnoreCase))
        .OrderBy(d => d.SortOrder ?? int.MaxValue)
        .ToList();
    var deductionLines = (Model.PayslipDetails ?? Enumerable.Empty<HRMBT.Web.Models.PayslipDetail>())
        .Where(d => string.Equals(d.ItemType, "Deduction", StringComparison.OrdinalIgnoreCase))
        .OrderBy(d => d.SortOrder ?? int.MaxValue)
        .ToList();
    var payrollDedTotal = deductionLines.Count > 0 ? deductionLines.Sum(l => l.Amount) : Model.TotalDeductions;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Payslip @Model.Id — @Model.Month @Model.Year</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/payslips.css" asp-append-version="true" />
</head>
<body>
    <div class="payslip-print-shell">
        <div class="payslip-print-toolbar">
            <button type="button" class="btn btn-back" onclick="window.close();">
                <i class="bi bi-x-lg me-1"></i>Close
            </button>
            <button type="button" class="btn btn-print" onclick="window.print();">
                <i class="bi bi-printer me-1"></i>Print
            </button>
        </div>

        <div class="payslip-print">
            <div class="pp-header">
                <div class="d-flex flex-wrap align-items-center justify-content-between gap-2">
                    <div>
                        <div class="pp-sub">HRMS · HR Management Bahria Town</div>
                        <h1>Salary Slip</h1>
                        <div class="pp-period">
                            <i class="bi bi-calendar3 me-1"></i>@Model.Month @Model.Year
                        </div>
                    </div>
                    <div class="text-end">
                        <div class="pp-sub">Payslip No.</div>
                        <div class="fs-5 fw-bold">#@Model.Id.ToString("D6")</div>
                    </div>
                </div>
            </div>

            <div class="pp-section">
                <h2>Employee details</h2>
                <div class="pp-grid">
                    <div class="pp-row"><span class="pp-key">Employee ID</span><span class="pp-val">@(Model.Employee?.EmployeeID ?? "—")</span></div>
                    <div class="pp-row"><span class="pp-key">Name</span><span class="pp-val">@(Model.Employee?.EmployeeName ?? "—")</span></div>
                    <div class="pp-row"><span class="pp-key">Department</span><span class="pp-val">@(Model.Employee?.Department ?? "—")</span></div>
                    <div class="pp-row"><span class="pp-key">Designation</span><span class="pp-val">@(Model.Employee?.Designation ?? "—")</span></div>
                    <div class="pp-row"><span class="pp-key">CNIC</span><span class="pp-val">@(Model.Employee?.CNIC ?? "—")</span></div>
                    <div class="pp-row"><span class="pp-key">Status</span><span class="pp-val">@(Model.Employee?.EmployeeStatus ?? "—")</span></div>
                </div>
            </div>

            <div class="pp-section">
                <h2>Attendance &amp; leave</h2>
                <div class="pp-grid">
                    <div class="pp-row"><span class="pp-key">Working days</span><span class="pp-val">@(Model.WorkingDays?.ToString() ?? "—")</span></div>
                    <div class="pp-row"><span class="pp-key">Leave days</span><span class="pp-val">@(Model.LeaveDays?.ToString("0.##") ?? "—")</span></div>
                    <div class="pp-row"><span class="pp-key">Leave balance</span><span class="pp-val">@(string.IsNullOrWhiteSpace(Model.LeaveBalance) ? "—" : Model.LeaveBalance)</span></div>
                </div>
            </div>

            <div class="pp-section">
                <h2>Earnings &amp; deductions</h2>
                <table class="pp-amounts">
                    <thead>
                        <tr>
                            <th>Description</th>
                            <th class="text-end" style="width:9rem;">Amount (PKR)</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Basic Salary</td>
                            <td class="amount">@Model.BasicSalary.ToString("N2")</td>
                        </tr>
                        @foreach (var line in allowanceLines)
                        {
                            <tr>
                                <td>@line.ItemName (@line.ItemCategory)</td>
                                <td class="amount">@line.Amount.ToString("N2")</td>
                            </tr>
                        }
                        @if (Model.TotalAllowances.HasValue || allowanceLines.Count > 0)
                        {
                            <tr class="table-light">
                                <td><strong>Total Allowances</strong></td>
                                <td class="amount"><strong>@(Model.TotalAllowances ?? allowanceLines.Sum(l => l.Amount)).ToString("N2")</strong></td>
                            </tr>
                        }
                        <tr>
                            <td>Gross Salary</td>
                            <td class="amount">@Model.GrossSalary.ToString("N2")</td>
                        </tr>
                        @foreach (var line in deductionLines)
                        {
                            <tr>
                                <td>@line.ItemName (@line.ItemCategory)</td>
                                <td class="amount">- @line.Amount.ToString("N2")</td>
                            </tr>
                        }
                        @if (Model.TotalDeductions > 0 || deductionLines.Count > 0)
                        {
                            <tr class="table-light">
                                <td><strong>Total payroll deductions</strong></td>
                                <td class="amount"><strong>- @payrollDedTotal.ToString("N2")</strong></td>
                            </tr>
                        }
                        @if (Model.TaxAmount > 0)
                        {
                            <tr>
                                <td>Income tax (@Model.TaxPercentage.ToString("N2")% of basic)</td>
                                <td class="amount">- @Model.TaxAmount.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="pp-net">
                <span class="pp-net-label">Net Salary Payable</span>
                <span class="pp-net-value">PKR @Model.NetSalary.ToString("N2")</span>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.Notes))
            {
                <div class="pp-section">
                    <h2>Notes</h2>
                    <div>@Model.Notes</div>
                </div>
            }

            <div class="pp-footer">
                <div>
                    Generated on @Model.GeneratedDate.ToString("dd MMM yyyy HH:mm") by <strong>@(string.IsNullOrWhiteSpace(Model.GeneratedBy) ? "System" : Model.GeneratedBy)</strong>.
                    This is a computer-generated document.
                </div>
                <div class="d-grid gap-3" style="grid-template-columns: 1fr 1fr;">
                    <div class="pp-sign">Employee Signature</div>
                    <div class="pp-sign">Authorized Signatory</div>
                </div>
            </div>
        </div>
    </div>

    <script>
        window.addEventListener('load', function () {
            // auto-launch print dialog
            setTimeout(function () { window.print(); }, 350);
        });
    </script>
</body>
</html>
