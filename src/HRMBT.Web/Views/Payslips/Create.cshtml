@model HRMBT.Web.Models.ViewModels.PayslipCreateVM

@{
    ViewData["Title"] = "Generate Payslip";
    var employees = ViewBag.Employees as IEnumerable<HRMBT.Web.Models.ViewModels.PayslipEmployeeOption>
        ?? Enumerable.Empty<HRMBT.Web.Models.ViewModels.PayslipEmployeeOption>();
    var employeesJson = System.Text.Json.JsonSerializer.Serialize(employees);
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" crossorigin="anonymous" />
    <link rel="stylesheet" href="~/css/payslips.css" asp-append-version="true" />
}

<div class="payslip-page py-4">
    <div class="container-fluid px-3 px-lg-4">

        <!-- Breadcrumb -->
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
                <li class="breadcrumb-item"><a asp-controller="Payroll" asp-action="Index">Payroll</a></li>
                <li class="breadcrumb-item"><a asp-action="Index">Payslips</a></li>
                <li class="breadcrumb-item active" aria-current="page">Generate</li>
            </ol>
        </nav>

        <!-- Header -->
        <div class="page-header-card p-4 mb-4">
            <div class="row align-items-center g-3">
                <div class="col-lg">
                    <h1 class="h2 mb-1 fw-bold text-dark">
                        <i class="bi bi-receipt-cutoff text-primary me-2"></i>Generate Payslip
                    </h1>
                    <p class="text-muted mb-0">Select an employee and pay period — basic salary auto-fills, net salary recalculates as you type.</p>
                </div>
                <div class="col-lg-auto d-none d-lg-block">
                    <span class="badge rounded-pill text-bg-light border px-3 py-2 text-secondary">
                        <i class="bi bi-shield-check me-1 text-success"></i> Single payslip
                    </span>
                </div>
            </div>
        </div>

        <form asp-action="Create" method="post" id="payslipForm">
            <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>

            <div class="row g-4">
                <!-- Main column -->
                <div class="col-lg-8">
                    <!-- Filters -->
                    <div class="section-card mb-4">
                        <div class="card-header">
                            <i class="bi bi-funnel"></i>Filters
                        </div>
                        <div class="card-body p-3 p-lg-4">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label asp-for="Department" class="form-label"></label>
                                    <select asp-for="Department" class="form-select" id="departmentSelect">
                                        <option value="">All departments</option>
                                        @if (ViewBag.Departments != null)
                                        {
                                            foreach (var dept in ViewBag.Departments)
                                            {
                                                <option value="@dept">@dept</option>
                                            }
                                        }
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="EmployeeId" class="form-label">Employee</label>
                                    <select asp-for="EmployeeId" class="form-select" id="employeeSelect">
                                        <option value="">— Select employee —</option>
                                    </select>
                                    <span asp-validation-for="EmployeeId" class="field-validation-error"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="Month" class="form-label"></label>
                                    @{
                                        ViewData["MonthFieldName"] = "Month";
                                        ViewData["MonthFieldId"] = "monthSelect";
                                        ViewData["SelectedMonth"] = Model.Month;
                                        ViewData["MonthRequired"] = true;
                                    }
                                    <partial name="_PayrollMonthSelect" />
                                    <span asp-validation-for="Month" class="field-validation-error"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="Year" class="form-label"></label>
                                    <select asp-for="Year" class="form-select" id="yearSelect">
                                        @for (int y = DateTime.Now.Year - 5; y <= DateTime.Now.Year + 1; y++)
                                        {
                                            <option value="@y" selected="@(Model.Year == y)">@y</option>
                                        }
                                    </select>
                                    <span asp-validation-for="Year" class="field-validation-error"></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Salary -->
                    <div class="section-card mb-4">
                        <div class="card-header">
                            <i class="bi bi-cash-stack"></i>Salary calculation
                        </div>
                        <div class="card-body p-3 p-lg-4">
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label asp-for="BasicSalary" class="form-label"></label>
                                    <div class="input-group">
                                        <span class="input-group-text">PKR</span>
                                        <input asp-for="BasicSalary" class="form-control" id="basicSalary" type="number" step="0.01" min="0" readonly />
                                    </div>
                                    <span asp-validation-for="BasicSalary" class="field-validation-error"></span>
                                </div>
                                <div class="col-md-4">
                                    <label asp-for="GrossSalary" class="form-label"></label>
                                    <div class="input-group">
                                        <span class="input-group-text">PKR</span>
                                        <input asp-for="GrossSalary" class="form-control" id="grossSalary" type="number" step="0.01" min="0" />
                                    </div>
                                    <span asp-validation-for="GrossSalary" class="field-validation-error"></span>
                                </div>
                                <div class="col-md-4">
                                    <label asp-for="TotalDeductions" class="form-label"></label>
                                    <div class="input-group">
                                        <span class="input-group-text">PKR</span>
                                        <input asp-for="TotalDeductions" class="form-control" id="totalDeductions" type="number" step="0.01" min="0" />
                                    </div>
                                    <span asp-validation-for="TotalDeductions" class="field-validation-error"></span>
                                </div>
                                <div class="col-md-4">
                                    <label asp-for="NetSalary" class="form-label"></label>
                                    <div class="input-group">
                                        <span class="input-group-text">PKR</span>
                                        <input asp-for="NetSalary" class="form-control" id="netSalary" type="number" step="0.01" readonly />
                                    </div>
                                </div>
                            </div>

                            <div class="calc-summary">
                                <div class="calc-tile">
                                    <span class="label">Gross</span>
                                    <span class="value" id="summaryGross">0.00</span>
                                </div>
                                <div class="calc-tile">
                                    <span class="label">Deductions</span>
                                    <span class="value" id="summaryDeductions">0.00</span>
                                </div>
                                <div class="calc-tile calc-net">
                                    <span class="label">Net Salary</span>
                                    <span class="value" id="summaryNet">0.00</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Attendance / leave -->
                    <div class="section-card mb-4">
                        <div class="card-header">
                            <i class="bi bi-calendar2-check"></i>Attendance &amp; leave
                        </div>
                        <div class="card-body p-3 p-lg-4">
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label asp-for="WorkingDays" class="form-label"></label>
                                    <input asp-for="WorkingDays" class="form-control" type="number" min="0" max="31" />
                                    <span asp-validation-for="WorkingDays" class="field-validation-error"></span>
                                </div>
                                <div class="col-md-4">
                                    <label asp-for="LeaveDays" class="form-label"></label>
                                    <input asp-for="LeaveDays" class="form-control" type="number" step="0.5" min="0" max="31" />
                                    <span asp-validation-for="LeaveDays" class="field-validation-error"></span>
                                </div>
                                <div class="col-md-4">
                                    <label asp-for="LeaveBalance" class="form-label"></label>
                                    <input asp-for="LeaveBalance" class="form-control" placeholder="e.g. 12 (annual)" />
                                    <span asp-validation-for="LeaveBalance" class="field-validation-error"></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Notes -->
                    <div class="section-card mb-4">
                        <div class="card-header">
                            <i class="bi bi-journal-text"></i>Notes
                        </div>
                        <div class="card-body p-3 p-lg-4">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Optional remarks visible on the payslip."></textarea>
                            <span asp-validation-for="Notes" class="field-validation-error"></span>
                        </div>
                    </div>
                </div>

                <!-- Sidebar: employee summary -->
                <div class="col-lg-4">
                    <div class="section-card sticky-lg-top mb-4" style="top: 1rem;">
                        <div class="card-header">
                            <i class="bi bi-person-vcard"></i>Employee
                        </div>
                        <div class="card-body p-3 p-lg-4">
                            <div id="employeeEmpty" class="text-center text-muted py-3">
                                <i class="bi bi-person-bounding-box fs-1 d-block mb-2 text-secondary"></i>
                                Select a department and employee to load details.
                            </div>

                            <div id="employeeDetails" class="d-none">
                                <div class="emp-card mb-3">
                                    <span class="emp-avatar" id="empAvatar">?</span>
                                    <div>
                                        <div class="emp-name" id="empName">—</div>
                                        <div class="emp-meta" id="empRole">—</div>
                                        <div class="mt-1">
                                            <span class="emp-id-pill"><i class="bi bi-hash"></i><span id="empCode">—</span></span>
                                        </div>
                                    </div>
                                </div>
                                <div class="info-grid">
                                    <div class="info-cell">
                                        <span class="info-label">Department</span>
                                        <span class="info-value" id="empDept">—</span>
                                    </div>
                                    <div class="info-cell">
                                        <span class="info-label">Designation</span>
                                        <span class="info-value" id="empDesignation">—</span>
                                    </div>
                                    <div class="info-cell">
                                        <span class="info-label">Status</span>
                                        <span class="info-value" id="empStatus">—</span>
                                    </div>
                                    <div class="info-cell">
                                        <span class="info-label">Basic Salary</span>
                                        <span class="info-value" id="empBasic">—</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card border-0 shadow-sm bg-white mb-4">
                        <div class="card-body small text-muted">
                            <div class="d-flex align-items-start gap-2 mb-2">
                                <i class="bi bi-shield-lock text-primary fs-5"></i>
                                <div>
                                    <strong class="text-dark d-block">Auto-filled at save</strong>
                                    Generated date = now · Generated by = current user · Locked = no
                                </div>
                            </div>
                            <hr class="my-2" />
                            <div class="d-flex align-items-start gap-2">
                                <i class="bi bi-info-circle text-warning fs-5"></i>
                                <div>
                                    <strong class="text-dark d-block">Duplicate check</strong>
                                    Only one payslip is allowed per employee per month/year.
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sticky actions -->
            <div class="payslip-actions">
                <div class="container-fluid px-3 px-lg-4">
                    <div class="d-flex flex-wrap align-items-center justify-content-between gap-2">
                        <div class="small text-muted d-none d-md-block">
                            <i class="bi bi-save me-1"></i>Payslip will be saved to the directory.
                        </div>
                        <div class="d-flex flex-wrap align-items-center gap-2 ms-md-auto">
                            <a asp-action="Index" class="btn btn-action-outline">
                                <i class="bi bi-arrow-left-short me-1"></i>Back to list
                            </a>
                            <button type="reset" class="btn btn-action-secondary" id="payslipReset">
                                <i class="bi bi-arrow-counterclockwise me-1"></i>Reset
                            </button>
                            <button type="submit" class="btn btn-action-primary" id="payslipSubmit">
                                <span class="spinner-border spinner-border-sm me-2 d-none" id="payslipSpinner" role="status" aria-hidden="true"></span>
                                <i class="bi bi-check2-circle me-1" id="payslipSubmitIcon"></i>Generate payslip
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        (function () {
            var allEmployees = @Html.Raw(employeesJson);
            var $deptSel = document.getElementById('departmentSelect');
            var $empSel = document.getElementById('employeeSelect');
            var $basic = document.getElementById('basicSalary');
            var $gross = document.getElementById('grossSalary');
            var $ded = document.getElementById('totalDeductions');
            var $net = document.getElementById('netSalary');
            var $sumGross = document.getElementById('summaryGross');
            var $sumDed = document.getElementById('summaryDeductions');
            var $sumNet = document.getElementById('summaryNet');
            var $form = document.getElementById('payslipForm');
            var $submit = document.getElementById('payslipSubmit');
            var $spin = document.getElementById('payslipSpinner');
            var $submitIcon = document.getElementById('payslipSubmitIcon');

            function fmt(n) {
                if (isNaN(n) || n === null || n === undefined) n = 0;
                return Number(n).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
            }

            function recalc() {
                var g = parseFloat($gross.value) || 0;
                var d = parseFloat($ded.value) || 0;
                var net = g - d;
                $net.value = net.toFixed(2);
                $sumGross.textContent = fmt(g);
                $sumDed.textContent = fmt(d);
                $sumNet.textContent = fmt(net);
            }

            function getInitials(name) {
                if (!name) return '?';
                var parts = String(name).trim().split(/\s+/);
                if (parts.length === 1) return parts[0].substring(0, Math.min(2, parts[0].length)).toUpperCase();
                return (parts[0][0] + parts[parts.length - 1][0]).toUpperCase();
            }

            function clearEmployeePanel() {
                document.getElementById('employeeEmpty').classList.remove('d-none');
                document.getElementById('employeeDetails').classList.add('d-none');
            }

            function fillEmployeePanel(e) {
                document.getElementById('employeeEmpty').classList.add('d-none');
                document.getElementById('employeeDetails').classList.remove('d-none');
                document.getElementById('empAvatar').textContent = getInitials(e.employeeName || e.name);
                document.getElementById('empName').textContent = e.employeeName || e.name || '—';
                document.getElementById('empCode').textContent = e.employeeID || e.employeeId || '—';
                var role = [];
                if (e.designation) role.push(e.designation);
                if (e.department) role.push(e.department);
                document.getElementById('empRole').textContent = role.join(' · ') || '—';
                document.getElementById('empDept').textContent = e.department || '—';
                document.getElementById('empDesignation').textContent = e.designation || '—';
                document.getElementById('empStatus').textContent = e.status || '—';
                document.getElementById('empBasic').textContent = 'PKR ' + fmt(e.basicSalary || 0);
            }

            function refreshEmployeeDropdown() {
                var dept = $deptSel.value;
                var filtered = allEmployees.filter(function (e) {
                    return !dept || (e.Department || '') === dept;
                });
                var current = $empSel.value;
                $empSel.innerHTML = '<option value="">— Select employee —</option>';
                filtered.forEach(function (e) {
                    var id = e.Uid;
                    var code = e.EmployeeID || '';
                    var name = e.EmployeeName || '';
                    var label = (code ? code + ' — ' : '') + name;
                    var opt = document.createElement('option');
                    opt.value = id;
                    opt.textContent = label;
                    if (String(id) === String(current)) opt.selected = true;
                    $empSel.appendChild(opt);
                });

                if (!Array.from($empSel.options).some(function (o) { return o.value === current; })) {
                    $empSel.value = '';
                    onEmployeeChange();
                }
            }

            function onEmployeeChange() {
                var id = parseInt($empSel.value, 10);
                if (!id) {
                    $basic.value = '';
                    $gross.value = '';
                    clearEmployeePanel();
                    recalc();
                    return;
                }

                fetch('@Url.Action("EmployeeDetails", "Payslips")?id=' + encodeURIComponent(id), { credentials: 'same-origin' })
                    .then(function (r) { return r.json(); })
                    .then(function (data) {
                        if (!data || !data.found) {
                            clearEmployeePanel();
                            return;
                        }
                        fillEmployeePanel(data);
                        var basic = Number(data.basicSalary || 0);
                        $basic.value = basic.toFixed(2);
                        if (!$gross.value || parseFloat($gross.value) === 0) {
                            $gross.value = basic.toFixed(2);
                        }
                        recalc();
                    })
                    .catch(function () { clearEmployeePanel(); });
            }

            $deptSel.addEventListener('change', refreshEmployeeDropdown);
            $empSel.addEventListener('change', onEmployeeChange);
            $gross.addEventListener('input', recalc);
            $ded.addEventListener('input', recalc);

            document.getElementById('payslipReset').addEventListener('click', function () {
                setTimeout(function () {
                    $deptSel.value = '';
                    refreshEmployeeDropdown();
                    clearEmployeePanel();
                    recalc();
                }, 0);
            });

            if (window.jQuery && $form) {
                window.jQuery(function ($) {
                    $($form).on('submit', function () {
                        if (!$(this).valid()) return;
                        $spin.classList.remove('d-none');
                        $submitIcon.classList.add('d-none');
                        $submit.disabled = true;
                    });
                });
            }

            refreshEmployeeDropdown();
            if ($empSel.value) onEmployeeChange();
            recalc();
        })();
    </script>
}
