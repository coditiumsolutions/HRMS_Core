@model HRMBT.Web.Models.Payslip

@{
    ViewData["Title"] = "Payslip Details";
    string MonthName(int m) => m >= 1 && m <= 12 ? System.Globalization.CultureInfo.InvariantCulture.DateTimeFormat.GetMonthName(m) : m.ToString();
    string Show(string? v) => string.IsNullOrWhiteSpace(v) ? "—" : v!;

    string Initials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0].Substring(0, Math.Min(2, parts[0].Length)).ToUpperInvariant();
        return (parts[0][0].ToString() + parts[^1][0].ToString()).ToUpperInvariant();
    }
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" crossorigin="anonymous" />
    <link rel="stylesheet" href="~/css/payslips.css" asp-append-version="true" />
}

<div class="payslip-page py-4">
    <div class="container-fluid px-3 px-lg-4">
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
                <li class="breadcrumb-item"><a asp-controller="Payroll" asp-action="Index">Payroll</a></li>
                <li class="breadcrumb-item"><a asp-action="Index">Payslips</a></li>
                <li class="breadcrumb-item active" aria-current="page">Details</li>
            </ol>
        </nav>

        <div class="page-header-card p-4 mb-4">
            <div class="row align-items-center g-3">
                <div class="col-lg">
                    <h1 class="h2 mb-1 fw-bold text-dark">Payslip Details</h1>
                    <p class="text-muted mb-0">
                        @(Model.Employee?.EmployeeName ?? "—") · <span class="fw-semibold text-dark">@MonthName(Model.Month) @Model.Year</span>
                    </p>
                </div>
                <div class="col-lg-auto">
                    @if (Model.IsLocked)
                    {
                        <span class="status-pill status-locked">Locked</span>
                    }
                    else
                    {
                        <span class="status-pill status-unlocked">Unlocked</span>
                    }
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-8">
                <!-- Salary -->
                <div class="section-card mb-4">
                    <div class="card-header"><i class="bi bi-cash-stack"></i>Salary breakdown</div>
                    <div class="card-body p-3 p-lg-4">
                        <div class="info-grid info-grid-3">
                            <div class="info-cell">
                                <span class="info-label">Basic Salary</span>
                                <span class="info-value">PKR @Model.BasicSalary.ToString("N2")</span>
                            </div>
                            <div class="info-cell">
                                <span class="info-label">Gross Salary</span>
                                <span class="info-value">PKR @Model.GrossSalary.ToString("N2")</span>
                            </div>
                            <div class="info-cell">
                                <span class="info-label">Total Deductions</span>
                                <span class="info-value">PKR @Model.TotalDeductions.ToString("N2")</span>
                            </div>
                        </div>
                        <div class="calc-summary">
                            <div class="calc-tile">
                                <span class="label">Gross</span>
                                <span class="value">@Model.GrossSalary.ToString("N2")</span>
                            </div>
                            <div class="calc-tile">
                                <span class="label">Deductions</span>
                                <span class="value">@Model.TotalDeductions.ToString("N2")</span>
                            </div>
                            <div class="calc-tile calc-net">
                                <span class="label">Net Salary</span>
                                <span class="value">@Model.NetSalary.ToString("N2")</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Attendance -->
                <div class="section-card mb-4">
                    <div class="card-header"><i class="bi bi-calendar2-check"></i>Attendance &amp; leave</div>
                    <div class="card-body p-3 p-lg-4">
                        <div class="info-grid info-grid-3">
                            <div class="info-cell">
                                <span class="info-label">Working days</span>
                                <span class="info-value @(Model.WorkingDays.HasValue ? "" : "text-empty")">@(Model.WorkingDays?.ToString() ?? "—")</span>
                            </div>
                            <div class="info-cell">
                                <span class="info-label">Leave days</span>
                                <span class="info-value @(Model.LeaveDays.HasValue ? "" : "text-empty")">@(Model.LeaveDays?.ToString("0.##") ?? "—")</span>
                            </div>
                            <div class="info-cell">
                                <span class="info-label">Leave balance</span>
                                <span class="info-value @(string.IsNullOrWhiteSpace(Model.LeaveBalance) ? "text-empty" : "")">@Show(Model.LeaveBalance)</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Notes -->
                <div class="section-card mb-4">
                    <div class="card-header"><i class="bi bi-journal-text"></i>Notes &amp; calculation log</div>
                    <div class="card-body p-3 p-lg-4">
                        <div class="info-grid">
                            <div class="info-cell" style="grid-column: 1 / -1;">
                                <span class="info-label">Notes</span>
                                <span class="info-value @(string.IsNullOrWhiteSpace(Model.Notes) ? "text-empty" : "")">@Show(Model.Notes)</span>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(Model.CalculationDetails))
                            {
                                <div class="info-cell" style="grid-column: 1 / -1;">
                                    <span class="info-label">Calculation details</span>
                                    <pre class="info-value mb-0" style="white-space:pre-wrap;font-family:inherit;">@Model.CalculationDetails</pre>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="section-card sticky-lg-top mb-4" style="top: 1rem;">
                    <div class="card-header"><i class="bi bi-person-vcard"></i>Employee</div>
                    <div class="card-body p-3 p-lg-4">
                        <div class="emp-card mb-3">
                            <span class="emp-avatar">@Initials(Model.Employee?.EmployeeName)</span>
                            <div>
                                <div class="emp-name">@(Model.Employee?.EmployeeName ?? "—")</div>
                                <div class="emp-meta">@(Model.Employee?.Designation ?? "—") · @(Model.Employee?.Department ?? "—")</div>
                                <div class="mt-1">
                                    <span class="emp-id-pill"><i class="bi bi-hash"></i>@(Model.Employee?.EmployeeID ?? "—")</span>
                                </div>
                            </div>
                        </div>
                        <div class="info-grid">
                            <div class="info-cell">
                                <span class="info-label">Period</span>
                                <span class="info-value">@MonthName(Model.Month) @Model.Year</span>
                            </div>
                            <div class="info-cell">
                                <span class="info-label">Status</span>
                                <span class="info-value">
                                    @if (Model.IsLocked)
                                    {
                                        <span class="status-pill status-locked">Locked</span>
                                    }
                                    else
                                    {
                                        <span class="status-pill status-unlocked">Unlocked</span>
                                    }
                                </span>
                            </div>
                            <div class="info-cell">
                                <span class="info-label">Generated</span>
                                <span class="info-value">@Model.GeneratedDate.ToString("dd MMM yyyy HH:mm")</span>
                            </div>
                            <div class="info-cell">
                                <span class="info-label">Generated by</span>
                                <span class="info-value @(string.IsNullOrWhiteSpace(Model.GeneratedBy) ? "text-empty" : "")">@Show(Model.GeneratedBy)</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="payslip-actions">
            <div class="container-fluid px-3 px-lg-4">
                <div class="d-flex flex-wrap align-items-center justify-content-between gap-2">
                    <div class="small text-muted d-none d-md-block"><i class="bi bi-eye me-1"></i>Viewing payslip.</div>
                    <div class="d-flex flex-wrap align-items-center gap-2 ms-md-auto">
                        <a asp-action="Index" class="btn btn-action-outline">
                            <i class="bi bi-arrow-left-short me-1"></i>Back to list
                        </a>
                        @if (!Model.IsLocked)
                        {
                            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-action-secondary">
                                <i class="bi bi-trash me-1"></i>Delete
                            </a>
                        }
                        <a asp-action="Print" asp-route-id="@Model.Id" class="btn btn-action-success" target="_blank">
                            <i class="bi bi-printer me-1"></i>Print payslip
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
