@model HRMBT.Web.Models.Payslip

@{
    ViewData["Title"] = "Delete Payslip";
    string MonthName(int m) => m >= 1 && m <= 12 ? System.Globalization.CultureInfo.InvariantCulture.DateTimeFormat.GetMonthName(m) : m.ToString();
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" crossorigin="anonymous" />
    <link rel="stylesheet" href="~/css/payslips.css" asp-append-version="true" />
}

<div class="payslip-page py-4">
    <div class="container-fluid px-3 px-lg-4">
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item"><a asp-action="Index">Payslips</a></li>
                <li class="breadcrumb-item active" aria-current="page">Delete</li>
            </ol>
        </nav>

        <div class="row justify-content-center">
            <div class="col-lg-7">
                <div class="section-card">
                    <div class="card-header"><i class="bi bi-trash3"></i>Confirm delete</div>
                    <div class="card-body p-4">
                        <div class="alert alert-warning d-flex gap-2 mb-4">
                            <i class="bi bi-exclamation-triangle-fill"></i>
                            <div>
                                <strong>This action cannot be undone.</strong>
                                Deleting the payslip will also remove its detail breakdown.
                            </div>
                        </div>

                        <div class="info-grid info-grid-3 mb-3">
                            <div class="info-cell">
                                <span class="info-label">Employee</span>
                                <span class="info-value">@(Model.Employee?.EmployeeName ?? "—")</span>
                            </div>
                            <div class="info-cell">
                                <span class="info-label">Employee ID</span>
                                <span class="info-value">@(Model.Employee?.EmployeeID ?? "—")</span>
                            </div>
                            <div class="info-cell">
                                <span class="info-label">Period</span>
                                <span class="info-value">@MonthName(Model.Month) @Model.Year</span>
                            </div>
                            <div class="info-cell">
                                <span class="info-label">Net salary</span>
                                <span class="info-value">PKR @Model.NetSalary.ToString("N2")</span>
                            </div>
                            <div class="info-cell">
                                <span class="info-label">Status</span>
                                <span class="info-value">
                                    @if (Model.IsLocked)
                                    {
                                        <span class="status-pill status-locked">Locked</span>
                                    }
                                    else
                                    {
                                        <span class="status-pill status-unlocked">Unlocked</span>
                                    }
                                </span>
                            </div>
                            <div class="info-cell">
                                <span class="info-label">Generated</span>
                                <span class="info-value">@Model.GeneratedDate.ToString("dd MMM yyyy HH:mm")</span>
                            </div>
                        </div>

                        @if (Model.IsLocked)
                        {
                            <div class="alert alert-danger mb-0">
                                <i class="bi bi-lock-fill me-1"></i>
                                This payslip is locked and cannot be deleted from this screen.
                            </div>
                        }

                        <form asp-action="Delete" method="post" class="d-flex flex-wrap gap-2 mt-4">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <a asp-action="Index" class="btn btn-action-outline">
                                <i class="bi bi-arrow-left-short me-1"></i>Cancel
                            </a>
                            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-action-secondary">
                                <i class="bi bi-eye me-1"></i>View
                            </a>
                            <button type="submit" class="btn btn-action-primary ms-auto" @(Model.IsLocked ? "disabled" : "")>
                                <i class="bi bi-trash3 me-1"></i>Delete payslip
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
