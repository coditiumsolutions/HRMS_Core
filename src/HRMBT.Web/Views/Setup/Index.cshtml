@{
    ViewData["Title"] = "Setup";
}

<h1 class="h3 mb-3">System setup</h1>
<p class="text-muted mb-4">Manage application users (login accounts) and configuration values.</p>

<div class="row g-3">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <h2 class="h5 card-title">Users</h2>
                <p class="card-text text-muted small">Create and maintain login accounts stored in <code>dbo.Users</code>. Passwords are stored as secure hashes used by the login page.</p>
                <a class="btn btn-dark" asp-action="Users">Open users</a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <h2 class="h5 card-title">Config</h2>
                <p class="card-text text-muted small">View key/value entries from <code>dbo.Configuration</code>.</p>
                <a class="btn btn-outline-secondary" asp-action="Config">Open config</a>
            </div>
        </div>
    </div>
</div>
