@model HRMBT.Web.Models.ViewModels.ConfigEditVm
@{
    ViewData["Title"] = "Edit configuration";
}

<h1 class="h3 mb-3">Edit configuration</h1>
<p class="text-muted small mb-4">UID <strong>@Model.UID</strong> · <code>dbo.Configuration</code></p>

<form asp-action="EditConfig" asp-route-id="@Model.UID" method="post" class="col-lg-8">
    <input type="hidden" asp-for="UID" />
    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
    <div class="mb-3">
        <label asp-for="ConfigKey" class="form-label"></label>
        <input asp-for="ConfigKey" class="form-control" maxlength="50" />
        <span asp-validation-for="ConfigKey" class="text-danger small"></span>
    </div>
    <div class="mb-3">
        <label asp-for="ConfigValue" class="form-label"></label>
        <textarea asp-for="ConfigValue" class="form-control font-monospace" rows="12" spellcheck="false" placeholder="comma-separated values"></textarea>
        <div class="form-text">Supports long comma-separated values (<code>nvarchar(max)</code>).</div>
        <span asp-validation-for="ConfigValue" class="text-danger small"></span>
    </div>
    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-dark">Save</button>
        <a class="btn btn-outline-secondary" asp-action="Config">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
