@model IReadOnlyList<HRMBT.Web.Models.AppUser>
@{
    ViewData["Title"] = "Users";
}

<h1 class="h3 mb-3">Users</h1>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<p class="text-muted small mb-3">Accounts in <code>dbo.Users</code> — used for application login.</p>

<div class="mb-3">
    <a class="btn btn-dark" asp-action="CreateUser">Create user</a>
</div>

<div class="table-responsive bg-white rounded shadow-sm">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th>Username</th>
                <th>Employee ID</th>
                <th>Role</th>
                <th>Created</th>
                <th class="text-end" style="width: 180px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model == null || !Model.Any())
            {
                <tr>
                    <td colspan="5" class="text-muted text-center py-4">No users yet. Create one to enable login.</td>
                </tr>
            }
            else
            {
                foreach (var u in Model)
                {
                    <tr>
                        <td class="fw-semibold">@u.Username</td>
                        <td>@(u.EmployeeId ?? "—")</td>
                        <td><span class="small">@(u.Role ?? "—")</span></td>
                        <td class="small text-muted">@(u.CreatedOn ?? "—")</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary" asp-action="EditUser" asp-route-id="@u.Uid">Edit</a>
                            <a class="btn btn-sm btn-outline-danger" asp-action="DeleteUser" asp-route-id="@u.Uid">Delete</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
