@model IEnumerable<HRMBT.Web.Models.ViewModels.LmsLeaveRowVm>

@{
    ViewData["Title"] = "Leave Management System";
    var filterEmployeeId = ViewBag.CurrentEmployeeId as string;
    var filterStatus = ViewBag.CurrentStatus as string;
    var filterLeaveType = ViewBag.CurrentLeaveType as string;
    var leaveTypesList = ViewBag.LeaveTypes as List<string>;
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2>Leave Management System</h2>
                <a asp-action="Create" class="btn btn-primary">
                    <i class="bi bi-plus-circle"></i> New leave request
                </a>
            </div>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">Filters</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Index" method="get" class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label">Employee ID</label>
                            <input type="text" name="employeeId" class="form-control" value="@filterEmployeeId" placeholder="Match employee code" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Status</label>
                            <select name="status" class="form-select">
                                <option value="" selected="@(string.IsNullOrEmpty(filterStatus))">All Statuses</option>
                                <option value="Applied" selected="@(filterStatus == "Applied")">Applied</option>
                                <option value="Approved" selected="@(filterStatus == "Approved")">Approved</option>
                                <option value="Rejected" selected="@(filterStatus == "Rejected")">Rejected</option>
                                <option value="Cancelled" selected="@(filterStatus == "Cancelled")">Cancelled</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Leave Type</label>
                            <select name="leaveType" class="form-select">
                                <option value="" selected="@(string.IsNullOrEmpty(filterLeaveType))">All Leave Types</option>
                                @if (leaveTypesList != null)
                                {
                                    @foreach (var leaveType in leaveTypesList)
                                    {
                                        <option value="@leaveType" selected="@(leaveType == filterLeaveType)">@leaveType</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-3 d-flex align-items-end">
                            <button type="submit" class="btn btn-primary me-2">Filter</button>
                            <a asp-action="Index" class="btn btn-secondary">Clear</a>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card">
                <div class="card-body">
                    <p class="text-muted small mb-3">Listing <strong>dbo.LeaveRequests</strong> with employee display from <strong>dbo.Employee</strong>.</p>
                    @if (Model != null && Model.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-bordered table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>ID</th>
                                        <th>Employee</th>
                                        <th>Leave type</th>
                                        <th>From</th>
                                        <th>To</th>
                                        <th>Calendar days</th>
                                        <th>Status</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>@item.Id</td>
                                            <td>
                                                <span class="fw-medium">@item.EmployeeCode</span>
                                                @if (!string.IsNullOrEmpty(item.EmployeeName))
                                                {
                                                    <span class="text-muted small d-block">@item.EmployeeName</span>
                                                }
                                            </td>
                                            <td>@item.LeaveType</td>
                                            <td>@item.FromDate.ToString("yyyy-MM-dd")</td>
                                            <td>@item.ToDate.ToString("yyyy-MM-dd")</td>
                                            <td>@item.CalendarDays</td>
                                            <td>
                                                @{
                                                    var statusClass = item.Status switch
                                                    {
                                                        "Approved" => "badge bg-success",
                                                        "Rejected" => "badge bg-danger",
                                                        "Cancelled" => "badge bg-secondary",
                                                        _ => "badge bg-warning"
                                                    };
                                                }
                                                <span class="@statusClass">@(item.Status ?? "—")</span>
                                            </td>
                                            <td>
                                                <div class="btn-group" role="group">
                                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info" title="View">
                                                        <i class="bi bi-eye"></i>
                                                    </a>
                                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning" title="Edit">
                                                        <i class="bi bi-pencil"></i>
                                                    </a>
                                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger" title="Delete">
                                                        <i class="bi bi-trash"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info mb-0">
                            <i class="bi bi-info-circle"></i> No rows in <strong>LeaveRequests</strong>.
                            <a asp-action="Create">Create a leave request</a>.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
