@model HRMBT.Web.Models.LeaveQuota

@{
    ViewData["Title"] = "Add leave quota";
}

<div class="container-fluid py-3">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb mb-0 small">
            <li class="breadcrumb-item"><a asp-action="Index">Leave Management</a></li>
            <li class="breadcrumb-item"><a asp-action="LeaveQuota">Leaves quota</a></li>
            <li class="breadcrumb-item active" aria-current="page">Add</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">Add leave quota</h2>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-4">
            <p class="text-muted small">Define total leave days for a leave type in a calendar year.</p>
            <form asp-action="CreateLeaveQuota" method="post">
                <partial name="_LeaveQuotaForm" model="Model" />
                <div class="d-flex flex-wrap gap-2 mt-4">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg"></i> Save
                    </button>
                    <a asp-action="LeaveQuota" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
