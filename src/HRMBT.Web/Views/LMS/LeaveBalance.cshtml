@model HRMBT.Web.Models.ViewModels.LmsLeaveBalancePageVm

@{
    ViewData["Title"] = "Leave balance";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2>Leave balance report</h2>
                <a asp-action="Index" class="btn btn-outline-secondary">Back to leave requests</a>
            </div>

            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">Filters</h5>
                </div>
                <div class="card-body">
                    <form asp-action="LeaveBalance" method="get" class="row g-3 align-items-end">
                        <div class="col-md-5">
                            <label class="form-label" for="year">Year</label>
                            <select name="year" id="year" class="form-select" required>
                                @foreach (var y in Model.YearChoices)
                                {
                                    var ySel = string.Equals(y, Model.SelectedYear, StringComparison.OrdinalIgnoreCase);
                                    if (ySel)
                                    {
                                        <option value="@y" selected>@y</option>
                                    }
                                    else
                                    {
                                        <option value="@y">@y</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-5">
                            <label class="form-label" for="department">Department</label>
                            <select name="department" id="department" class="form-select">
                                @foreach (var d in Model.DepartmentChoices)
                                {
                                    var dSel = string.Equals(d.Value, Model.SelectedDepartment, StringComparison.OrdinalIgnoreCase);
                                    if (dSel)
                                    {
                                        <option value="@d.Value" selected>@d.Label</option>
                                    }
                                    else
                                    {
                                        <option value="@d.Value">@d.Label</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-2">
                            <button type="submit" class="btn btn-primary w-100">Apply</button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card">
                <div class="card-body">
                    <p class="text-muted small mb-3">
                        For each leave type, <strong>balance</strong> = <strong>available</strong> quota for the year minus leave days from <strong>approved or applied</strong> requests that fall in that year.
                    </p>

                    @if (Model.Rows.Count == 0)
                    {
                        <p class="text-muted mb-0">No rows to show. Check leave quota for the selected year, or choose another department.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-bordered table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Employee</th>
                                        <th>Name</th>
                                        <th>Leave type</th>
                                        <th class="text-end">Available leave</th>
                                        <th class="text-end">Availed leave</th>
                                        <th class="text-end">Balance leave</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var row in Model.Rows)
                                    {
                                        <tr>
                                            <td>@row.EmployeeCode</td>
                                            <td>@(row.EmployeeName ?? "—")</td>
                                            <td>@row.LeaveTypeName</td>
                                            <td class="text-end">@row.AvailableLeaves</td>
                                            <td class="text-end">@row.AvailedLeaves.ToString("0.##")</td>
                                            <td class="text-end">@row.BalanceLeaves.ToString("0.##")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
