@model HRMBT.Web.Models.Allowance

@{
    ViewData["Title"] = "Delete allowance";
    ViewData["Module"] = "Allowances";
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" crossorigin="anonymous" />
    <link rel="stylesheet" href="~/css/payslips.css" asp-append-version="true" />
}

<div class="payslip-page py-4">
    <div class="container-fluid px-3 px-lg-4">
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
                <li class="breadcrumb-item"><a asp-action="Index">Allowances</a></li>
                <li class="breadcrumb-item active" aria-current="page">Delete</li>
            </ol>
        </nav>

        <div class="page-header-card p-4 mb-4">
            <h1 class="h2 mb-1 fw-bold text-danger"><i class="bi bi-exclamation-triangle me-2"></i>Delete allowance</h1>
            <p class="text-muted mb-0">This removes the row from <strong>dbo.Allowances</strong>. This cannot be undone.</p>
        </div>

        <div class="section-card mb-4">
            <div class="card-body p-4">
                <dl class="row mb-0">
                    <dt class="col-sm-3">Id</dt>
                    <dd class="col-sm-9">@Model.Id</dd>
                    <dt class="col-sm-3">Employee</dt>
                    <dd class="col-sm-9">@(Model.Employee?.EmployeeName ?? "—") (@(Model.Employee?.EmployeeID ?? Model.EmployeeId.ToString()))</dd>
                    <dt class="col-sm-3">@Html.DisplayNameFor(m => m.AllowanceType)</dt>
                    <dd class="col-sm-9">@Model.AllowanceType</dd>
                    <dt class="col-sm-3">@Html.DisplayNameFor(m => m.Name)</dt>
                    <dd class="col-sm-9">@Model.Name</dd>
                    <dt class="col-sm-3">@Html.DisplayNameFor(m => m.Amount)</dt>
                    <dd class="col-sm-9">@Model.Amount.ToString("N2")</dd>
                </dl>

                <form asp-action="Delete" method="post" class="mt-4 d-flex flex-wrap gap-2">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Delete</button>
                    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-action-outline">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>
