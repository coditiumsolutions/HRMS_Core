@model HRMBT.Web.Models.Allowance

@{
    ViewData["Title"] = "Allowance details";
    ViewData["Module"] = "Allowances";
    string Show(string? v) => string.IsNullOrWhiteSpace(v) ? "—" : v!;
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" crossorigin="anonymous" />
    <link rel="stylesheet" href="~/css/employee-create.css" asp-append-version="true" />
}

<div class="employee-create-page py-4">
    <div class="container-fluid px-3 px-lg-4">
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
                <li class="breadcrumb-item"><a asp-action="Index">Allowances</a></li>
                <li class="breadcrumb-item active" aria-current="page">Details</li>
            </ol>
        </nav>

        <div class="page-header-card p-4 mb-4">
            <div class="row align-items-center g-3">
                <div class="col-lg">
                    <h1 class="h2 mb-1 fw-bold text-dark">Allowance #@Model.Id</h1>
                    <p class="text-muted mb-0">@Show(Model.Name) · @Show(Model.AllowanceType)</p>
                </div>
                <div class="col-lg-auto d-flex flex-wrap gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-action-primary"><i class="bi bi-pencil me-1"></i>Edit</a>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-action-outline"><i class="bi bi-trash me-1"></i>Delete</a>
                    <a asp-action="Index" class="btn btn-action-secondary">Back to list</a>
                </div>
            </div>
        </div>

        <div class="card section-card mb-4">
            <div class="card-header"><i class="bi bi-person-badge"></i>Employee</div>
            <div class="card-body">
                <div class="info-grid info-grid-3">
                    <div class="info-cell">
                        <span class="info-label">Employee name</span>
                        <span class="info-value">@(Model.Employee?.EmployeeName ?? "—")</span>
                    </div>
                    <div class="info-cell">
                        <span class="info-label">Employee ID</span>
                        <span class="info-value">@(Model.Employee?.EmployeeID ?? Model.EmployeeId.ToString())</span>
                    </div>
                    <div class="info-cell">
                        <span class="info-label">Internal uid</span>
                        <span class="info-value">@Model.EmployeeId</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="card section-card mb-4">
            <div class="card-header"><i class="bi bi-cash-stack"></i>Allowance</div>
            <div class="card-body">
                <div class="info-grid info-grid-3">
                    <div class="info-cell">
                        <span class="info-label">@Html.DisplayNameFor(m => m.AllowanceType)</span>
                        <span class="info-value">@Show(Model.AllowanceType)</span>
                    </div>
                    <div class="info-cell">
                        <span class="info-label">@Html.DisplayNameFor(m => m.Name)</span>
                        <span class="info-value">@Show(Model.Name)</span>
                    </div>
                    <div class="info-cell">
                        <span class="info-label">@Html.DisplayNameFor(m => m.Amount)</span>
                        <span class="info-value">@Model.Amount.ToString("N2")</span>
                    </div>
                    <div class="info-cell">
                        <span class="info-label">@Html.DisplayNameFor(m => m.IsPercentage)</span>
                        <span class="info-value">@(Model.IsPercentage ? "Yes" : "No")</span>
                    </div>
                    <div class="info-cell">
                        <span class="info-label">@Html.DisplayNameFor(m => m.PercentageValue)</span>
                        <span class="info-value">@(Model.PercentageValue?.ToString("N2") ?? "—")</span>
                    </div>
                    <div class="info-cell">
                        <span class="info-label">@Html.DisplayNameFor(m => m.IsActive)</span>
                        <span class="info-value">@(Model.IsActive ? "Yes" : "No")</span>
                    </div>
                    <div class="info-cell">
                        <span class="info-label">@Html.DisplayNameFor(m => m.EffectiveDate)</span>
                        <span class="info-value">@Model.EffectiveDate.ToString("yyyy-MM-dd")</span>
                    </div>
                    <div class="info-cell">
                        <span class="info-label">@Html.DisplayNameFor(m => m.EndDate)</span>
                        <span class="info-value">@(Model.EndDate.HasValue ? Model.EndDate.Value.ToString("yyyy-MM-dd") : "—")</span>
                    </div>
                    <div class="info-cell">
                        <span class="info-label">Created</span>
                        <span class="info-value">@Model.CreatedDate.ToString("g") · @Show(Model.CreatedBy)</span>
                    </div>
                    <div class="info-cell">
                        <span class="info-label">Modified</span>
                        <span class="info-value">@(Model.ModifiedDate.HasValue ? Model.ModifiedDate.Value.ToString("g") + " · " + Show(Model.ModifiedBy) : "—")</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
