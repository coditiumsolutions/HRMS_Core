@model HRMBT.Web.Models.PaginatedList<HRMBT.Web.Models.Allowance>

@{
    ViewData["Title"] = "Allowances";
    ViewData["Module"] = "Allowances";
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" crossorigin="anonymous" />
    <link rel="stylesheet" href="~/css/payslips.css" asp-append-version="true" />
}

<div class="payslip-page py-4">
    <div class="container-fluid px-3 px-lg-4">

        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
                <li class="breadcrumb-item active" aria-current="page">Allowances</li>
            </ol>
        </nav>

        <div class="page-header-card p-4 mb-4">
            <div class="row align-items-center g-3">
                <div class="col-lg">
                    <h1 class="h2 mb-1 fw-bold text-dark">
                        <i class="bi bi-cash-stack text-primary me-2"></i>Allowances
                    </h1>
                    <p class="text-muted mb-0">Filter by <strong>department</strong> and/or one field for <strong>employee ID</strong>, <strong>employee name</strong>, or internal <strong>uid</strong> (e.g. <em>Shahid Ghauri</em> or <em>860</em>).</p>
                </div>
                <div class="col-lg-auto d-flex flex-wrap gap-2 justify-content-lg-end">
                    <a asp-action="Add" class="btn btn-action-primary">
                        <i class="bi bi-ui-checks-grid me-1"></i>Add Allowances
                    </a>
                    <a asp-action="Create" class="btn btn-action-secondary">
                        <i class="bi bi-plus-lg me-1"></i>Single allowance
                    </a>
                </div>
            </div>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show d-flex align-items-center gap-2 mb-4" role="alert">
                <i class="bi bi-check-circle-fill"></i>
                <div>@TempData["SuccessMessage"]</div>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center gap-2 mb-4" role="alert">
                <i class="bi bi-exclamation-triangle-fill"></i>
                <div>@TempData["ErrorMessage"]</div>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="filter-card mb-4">
            <div class="card-header"><i class="bi bi-funnel"></i>Search allowances</div>
            <div class="card-body p-3 p-lg-4">
                <form asp-action="Index" method="get" class="row g-3" onsubmit="document.getElementById('allowPageInput').value = '1';">
                    <input type="hidden" name="page" id="allowPageInput" value="1" />
                    <div class="col-md-4 col-lg-3">
                        <label class="form-label" for="deptId">Department</label>
                        <select name="deptId" id="deptId" class="form-select" asp-items="ViewBag.DepartmentFilterOptions"
                                onchange="document.getElementById('allowPageInput').value = '1'; this.form.submit();"></select>
                    </div>
                    <div class="col-md-5 col-lg-4">
                        <label class="form-label" for="empSearch">Employee ID or name</label>
                        <input type="text" name="empSearch" id="empSearch" class="form-control" value="@ViewBag.CurrentEmpSearch" placeholder="e.g. Shahid Ghauri or 860" />
                    </div>
                    <div class="col-md-3 col-lg-2">
                        <label class="form-label" for="isActive">Status</label>
                        <select name="isActive" id="isActive" class="form-select">
                            @{
                                var cur = ViewBag.CurrentIsActive as bool?;
                            }
                            @if (!cur.HasValue)
                            {
                                <option value="" selected>All</option>
                            }
                            else
                            {
                                <option value="">All</option>
                            }
                            @if (cur == true)
                            {
                                <option value="true" selected>Active only</option>
                            }
                            else
                            {
                                <option value="true">Active only</option>
                            }
                            @if (cur == false)
                            {
                                <option value="false" selected>Inactive only</option>
                            }
                            else
                            {
                                <option value="false">Inactive only</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-12 col-lg-3 d-flex align-items-end gap-2 flex-wrap">
                        <button type="submit" class="btn btn-action-primary"><i class="bi bi-search me-1"></i>Apply</button>
                        <a asp-action="Index" class="btn btn-action-secondary"><i class="bi bi-x-lg me-1"></i>Clear</a>
                        <div class="ms-lg-auto">
                            <label class="form-label small d-block" for="pageSizeTop">Per page</label>
                            <select name="pageSize" id="pageSizeTop" class="form-select form-select-sm" style="min-width:5rem;" onchange="document.getElementById('allowPageInput').value = '1'; this.form.submit();">
                                @if (ViewBag.PageSizeOptions != null)
                                {
                                    foreach (var ps in ViewBag.PageSizeOptions)
                                    {
                                        <option value="@ps" selected="@(ViewBag.CurrentPageSize == ps)">@ps</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <div class="grid-card mb-4">
            <div class="card-header d-flex align-items-center justify-content-between">
                <span><i class="bi bi-table"></i>Results</span>
                @if (Model != null && Model.Any())
                {
                    <span class="small">@Model.StartRecord–@Model.EndRecord of @Model.TotalCount</span>
                }
            </div>
            <div class="card-body">
                @if (Model == null || !Model.Any())
                {
                    <div class="empty-state">
                        <i class="bi bi-inboxes"></i>
                        <h5 class="mb-1">No allowances found</h5>
                        <p class="mb-3">Try another department or employee search, or add allowances from <strong>Add Allowances</strong>.</p>
                        <a asp-action="Add" class="btn btn-action-primary me-2"><i class="bi bi-ui-checks-grid me-1"></i>Add Allowances</a>
                        <a asp-action="Create" class="btn btn-action-secondary"><i class="bi bi-plus-lg me-1"></i>Single allowance</a>
                    </div>
                }
                else
                {
                    <div class="table-wrap table-responsive">
                        <table class="payslip-grid">
                            <thead>
                                <tr>
                                    <th>Employee</th>
                                    <th>Type</th>
                                    <th>Name</th>
                                    <th class="text-end">Amount</th>
                                    <th>%</th>
                                    <th class="text-end">% value</th>
                                    <th>Effective</th>
                                    <th>End</th>
                                    <th>Active</th>
                                    <th class="text-end" style="width:140px;">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">@(item.Employee?.EmployeeName ?? "—")</div>
                                            <div class="text-muted small">@(item.Employee?.EmployeeID ?? item.EmployeeId.ToString())</div>
                                        </td>
                                        <td>@item.AllowanceType</td>
                                        <td>@item.Name</td>
                                        <td class="text-end salary">@item.Amount.ToString("N2")</td>
                                        <td>@(item.IsPercentage ? "Yes" : "No")</td>
                                        <td class="text-end">@(item.PercentageValue?.ToString("N2") ?? "—")</td>
                                        <td class="text-nowrap">@item.EffectiveDate.ToString("yyyy-MM-dd")</td>
                                        <td class="text-nowrap">@(item.EndDate.HasValue ? item.EndDate.Value.ToString("yyyy-MM-dd") : "—")</td>
                                        <td>
                                            @if (item.IsActive)
                                            {
                                                <span class="status-pill status-locked">Yes</span>
                                            }
                                            else
                                            {
                                                <span class="status-pill status-unlocked">No</span>
                                            }
                                        </td>
                                        <td class="text-end">
                                            <div class="row-actions">
                                                <a class="btn btn-view" asp-action="Details" asp-route-id="@item.Id" title="Details"><i class="bi bi-eye"></i></a>
                                                <a class="btn btn-edit" asp-action="Edit" asp-route-id="@item.Id" title="Edit"><i class="bi bi-pencil"></i></a>
                                                <a class="btn btn-delete" asp-action="Delete" asp-route-id="@item.Id" title="Delete"><i class="bi bi-trash"></i></a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    @if (Model.TotalPages > 1)
                    {
                        <nav aria-label="Allowance pagination" class="mt-2 px-3 pb-3">
                            <ul class="pagination justify-content-center mb-2">
                                @{
                                    var prevDisabled = !Model.HasPreviousPage ? "disabled" : "";
                                    var nextDisabled = !Model.HasNextPage ? "disabled" : "";
                                    int startPage = Math.Max(1, Model.PageIndex - 2);
                                    int endPage = Math.Min(Model.TotalPages, Model.PageIndex + 2);
                                    if (endPage - startPage < 4)
                                    {
                                        if (startPage == 1) { endPage = Math.Min(Model.TotalPages, startPage + 4); }
                                        else if (endPage == Model.TotalPages) { startPage = Math.Max(1, endPage - 4); }
                                    }
                                }
                                <li class="page-item @prevDisabled">
                                    <a class="page-link" asp-action="Index" asp-route-page="1" asp-route-pageSize="@ViewBag.CurrentPageSize"
                                       asp-route-deptId="@ViewBag.CurrentDeptId" asp-route-empSearch="@ViewBag.CurrentEmpSearch" asp-route-isActive="@ViewBag.CurrentIsActive">&laquo;&laquo;</a>
                                </li>
                                <li class="page-item @prevDisabled">
                                    <a class="page-link" asp-action="Index" asp-route-page="@(Model.PageIndex - 1)" asp-route-pageSize="@ViewBag.CurrentPageSize"
                                       asp-route-deptId="@ViewBag.CurrentDeptId" asp-route-empSearch="@ViewBag.CurrentEmpSearch" asp-route-isActive="@ViewBag.CurrentIsActive">&laquo;</a>
                                </li>
                                @for (int i = startPage; i <= endPage; i++)
                                {
                                    var active = i == Model.PageIndex ? "active" : "";
                                    <li class="page-item @active">
                                        <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-pageSize="@ViewBag.CurrentPageSize"
                                           asp-route-deptId="@ViewBag.CurrentDeptId" asp-route-empSearch="@ViewBag.CurrentEmpSearch" asp-route-isActive="@ViewBag.CurrentIsActive">@i</a>
                                    </li>
                                }
                                <li class="page-item @nextDisabled">
                                    <a class="page-link" asp-action="Index" asp-route-page="@(Model.PageIndex + 1)" asp-route-pageSize="@ViewBag.CurrentPageSize"
                                       asp-route-deptId="@ViewBag.CurrentDeptId" asp-route-empSearch="@ViewBag.CurrentEmpSearch" asp-route-isActive="@ViewBag.CurrentIsActive">&raquo;</a>
                                </li>
                                <li class="page-item @nextDisabled">
                                    <a class="page-link" asp-action="Index" asp-route-page="@Model.TotalPages" asp-route-pageSize="@ViewBag.CurrentPageSize"
                                       asp-route-deptId="@ViewBag.CurrentDeptId" asp-route-empSearch="@ViewBag.CurrentEmpSearch" asp-route-isActive="@ViewBag.CurrentIsActive">&raquo;&raquo;</a>
                                </li>
                            </ul>
                            <div class="text-center text-muted small">Page @Model.PageIndex of @Model.TotalPages</div>
                        </nav>
                    }
                }
            </div>
        </div>
    </div>
</div>
