@model HRMBT.Web.Models.Allowance

@{
    ViewData["Title"] = "Edit allowance";
    ViewData["Module"] = "Allowances";
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" crossorigin="anonymous" />
    <link rel="stylesheet" href="~/css/employee-create.css" asp-append-version="true" />
}

<div class="employee-create-page py-4">
    <div class="container-fluid px-3 px-lg-4">
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
                <li class="breadcrumb-item"><a asp-action="Index">Allowances</a></li>
                <li class="breadcrumb-item active" aria-current="page">Edit</li>
            </ol>
        </nav>

        <div class="page-header-card p-4 mb-4">
            <h1 class="h2 mb-1 fw-bold text-dark">Edit allowance</h1>
            <p class="text-muted mb-0">Id <strong>@Model.Id</strong></p>
        </div>

        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CreatedDate" />
            <input type="hidden" asp-for="CreatedBy" />
            <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>

            <div class="card section-card mb-4">
                <div class="card-header"><i class="bi bi-cash-stack"></i>Allowance</div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="EmployeeId" class="form-label"></label>
                            <select asp-for="EmployeeId" class="form-select" asp-items="ViewBag.EmployeeOptions"></select>
                            <span asp-validation-for="EmployeeId" class="field-validation-error"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="AllowanceType" class="form-label"></label>
                            <input asp-for="AllowanceType" class="form-control" maxlength="50" />
                            <span asp-validation-for="AllowanceType" class="field-validation-error"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Name" class="form-label"></label>
                            <input asp-for="Name" class="form-control" maxlength="200" />
                            <span asp-validation-for="Name" class="field-validation-error"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Amount" class="form-label"></label>
                            <input asp-for="Amount" class="form-control" type="number" step="0.01" min="0" />
                            <span asp-validation-for="Amount" class="field-validation-error"></span>
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                            <div class="form-check mb-2">
                                <input asp-for="IsPercentage" class="form-check-input" />
                                <label asp-for="IsPercentage" class="form-check-label"></label>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="PercentageValue" class="form-label"></label>
                            <input asp-for="PercentageValue" class="form-control" type="number" step="0.01" min="0" max="100" />
                            <span asp-validation-for="PercentageValue" class="field-validation-error"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="EffectiveDate" class="form-label"></label>
                            <input asp-for="EffectiveDate" class="form-control" type="date" />
                            <span asp-validation-for="EffectiveDate" class="field-validation-error"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="EndDate" class="form-label"></label>
                            <input asp-for="EndDate" class="form-control" type="date" />
                            <span asp-validation-for="EndDate" class="field-validation-error"></span>
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                            <div class="form-check mb-2">
                                <input asp-for="IsActive" class="form-check-input" />
                                <label asp-for="IsActive" class="form-check-label"></label>
                            </div>
                        </div>
                        <div class="col-12 small text-muted">
                            Created @Model.CreatedDate.ToString("g") by @Model.CreatedBy
                            @if (Model.ModifiedDate.HasValue)
                            {
                                <span> · Modified @Model.ModifiedDate.Value.ToString("g") @(Model.ModifiedBy ?? "")</span>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex flex-wrap gap-2">
                <button type="submit" class="btn btn-action-primary"><i class="bi bi-check2 me-1"></i>Save</button>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-action-outline">Details</a>
                <a asp-action="Index" class="btn btn-action-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
