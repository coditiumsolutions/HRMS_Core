@model HRMBT.Web.Models.Allowance

@{
    ViewData["Title"] = "Edit Allowance";
    ViewData["Module"] = "Payroll";
}

<h1>Edit Allowance</h1>

<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <div class="form-group mb-3">
                <label asp-for="EmployeeId" class="control-label">Employee</label>
                <select asp-for="EmployeeId" class="form-control" asp-items="ViewBag.EmployeeId">
                    <option value="">-- Select Employee --</option>
                </select>
                <span asp-validation-for="EmployeeId" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="AllowanceType" class="control-label">Allowance Type</label>
                <select asp-for="AllowanceType" class="form-control" asp-items="ViewBag.AllowanceType">
                    <option value="">-- Select Type --</option>
                </select>
                <span asp-validation-for="AllowanceType" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <div class="form-check">
                    <input type="checkbox" asp-for="IsPercentage" class="form-check-input" id="IsPercentage" />
                    <label class="form-check-label" for="IsPercentage">
                        Is Percentage Based
                    </label>
                </div>
            </div>
            <div class="form-group mb-3" id="amountGroup">
                <label asp-for="Amount" class="control-label">Amount</label>
                <input asp-for="Amount" class="form-control" type="number" step="0.01" min="0" />
                <span asp-validation-for="Amount" class="text-danger"></span>
            </div>
            <div class="form-group mb-3" id="percentageGroup" style="display: none;">
                <label asp-for="PercentageValue" class="control-label">Percentage (%)</label>
                <input asp-for="PercentageValue" class="form-control" type="number" step="0.01" min="0" max="100" />
                <span asp-validation-for="PercentageValue" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="EffectiveDate" class="control-label">Effective Date</label>
                <input asp-for="EffectiveDate" class="form-control" type="date" />
                <span asp-validation-for="EffectiveDate" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="EndDate" class="control-label">End Date (Optional)</label>
                <input asp-for="EndDate" class="form-control" type="date" />
                <span asp-validation-for="EndDate" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <div class="form-check">
                    <input type="checkbox" asp-for="IsActive" class="form-check-input" />
                    <label class="form-check-label" for="IsActive">
                        Is Active
                    </label>
                </div>
            </div>
            <div class="form-group mb-3">
                <input type="submit" value="Save" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.getElementById('IsPercentage').addEventListener('change', function() {
            var isPercentage = this.checked;
            document.getElementById('amountGroup').style.display = isPercentage ? 'none' : 'block';
            document.getElementById('percentageGroup').style.display = isPercentage ? 'block' : 'none';
        });
        // Trigger on page load
        document.getElementById('IsPercentage').dispatchEvent(new Event('change'));
    </script>
}




