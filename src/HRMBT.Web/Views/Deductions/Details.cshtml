@model HRMBT.Web.Models.Deduction

@{
    ViewData["Title"] = "Deduction details";
    ViewData["Module"] = "Deductions";
    var isPct = string.Equals(Model.CalculationMethod, "Percentage", StringComparison.OrdinalIgnoreCase);
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" crossorigin="anonymous" />
    <link rel="stylesheet" href="~/css/payslips.css" asp-append-version="true" />
}

<div class="payslip-page py-4">
    <div class="container-fluid px-3 px-lg-4">
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
                <li class="breadcrumb-item"><a asp-action="Index">Deductions</a></li>
                <li class="breadcrumb-item active" aria-current="page">Details</li>
            </ol>
        </nav>

        <div class="section-card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-eye"></i>Deduction #@Model.Id</span>
                <div class="d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-action-secondary"><i class="bi bi-pencil me-1"></i>Edit</a>
                    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Back</a>
                </div>
            </div>
            <div class="card-body p-3 p-lg-4">
                <dl class="row mb-0">
                    <dt class="col-sm-3">Employee</dt>
                    <dd class="col-sm-9">@(Model.Employee?.EmployeeName ?? "—") <span class="text-muted">(@(Model.Employee?.EmployeeID ?? Model.EmployeeId.ToString()))</span></dd>
                    <dt class="col-sm-3">Deduction type</dt>
                    <dd class="col-sm-9">@Model.DeductionType</dd>
                    <dt class="col-sm-3">Deduction name</dt>
                    <dd class="col-sm-9">@Model.DeductionName</dd>
                    <dt class="col-sm-3">Frequency</dt>
                    <dd class="col-sm-9">@Model.Frequency</dd>
                    <dt class="col-sm-3">Calculation</dt>
                    <dd class="col-sm-9">@Model.CalculationMethod</dd>
                    <dt class="col-sm-3">@(isPct ? "Percentage" : "Fixed (PKR)")</dt>
                    <dd class="col-sm-9">
                        @if (isPct)
                        {
                            @($"{Model.PercentageValue:N2} %")
                        }
                        else
                        {
                            @($"PKR {Model.PercentageValue:N2}")
                        }
                    </dd>
                    <dt class="col-sm-3">Mandatory</dt>
                    <dd class="col-sm-9">@(Model.IsMandatory ? "Yes" : "No")</dd>
                    <dt class="col-sm-3">Effective</dt>
                    <dd class="col-sm-9">@Model.EffectiveDate.ToString("yyyy-MM-dd")</dd>
                    <dt class="col-sm-3">End</dt>
                    <dd class="col-sm-9">@(Model.EndDate?.ToString("yyyy-MM-dd") ?? "—")</dd>
                    <dt class="col-sm-3">Active</dt>
                    <dd class="col-sm-9">@(Model.IsActive ? "Yes" : "No")</dd>
                    <dt class="col-sm-3">Created</dt>
                    <dd class="col-sm-9">@Model.CreatedDate.ToString("yyyy-MM-dd HH:mm") by @Model.CreatedBy</dd>
                    @if (Model.ModifiedDate.HasValue)
                    {
                        <dt class="col-sm-3">Modified</dt>
                        <dd class="col-sm-9">@Model.ModifiedDate.Value.ToString("yyyy-MM-dd HH:mm") by @(Model.ModifiedBy ?? "—")</dd>
                    }
                </dl>
            </div>
        </div>
    </div>
</div>
