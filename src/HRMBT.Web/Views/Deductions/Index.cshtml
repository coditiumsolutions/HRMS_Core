@model IEnumerable<HRMBT.Web.Models.Deduction>

@{
    ViewData["Title"] = "Deductions Management";
    ViewData["Module"] = "Payroll";
}

<div class="container">
    <div class="row">
        <div class="col-md-12">
            <h1>Deductions Management</h1>
            <p>
                <a asp-action="Create" class="btn btn-primary">Create New Deduction</a>
            </p>
            
            <div class="mb-3">
                <form asp-action="Index" method="get" class="form-inline">
                    <div class="row">
                        <div class="col-md-4">
                            <label>Filter by Employee:</label>
                            <select name="employeeId" asp-items="ViewBag.EmployeeId" class="form-control">
                                <option value="">All Employees</option>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <button type="submit" class="btn btn-secondary mt-4">Filter</button>
                        </div>
                    </div>
                </form>
            </div>

            <table class="table table-striped table-bordered">
                <thead>
                    <tr>
                        <th>Employee</th>
                        <th>Type</th>
                        <th>Name</th>
                        <th>Amount/Percentage</th>
                        <th>Calculation Method</th>
                        <th>Mandatory</th>
                        <th>Effective Date</th>
                        <th>End Date</th>
                        <th>Active</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var employee = ViewBag.Employees != null ? 
                            ((List<HRMBT.Web.Models.Employee>)ViewBag.Employees).FirstOrDefault(e => e.uid == item.EmployeeId) : null;
                        <tr>
                            <td>@(employee?.EmployeeName ?? $"ID: {item.EmployeeId}")</td>
                            <td>@Html.DisplayFor(modelItem => item.DeductionType)</td>
                            <td>@Html.DisplayFor(modelItem => item.Name)</td>
                            <td>
                                @if (item.CalculationMethod == "Percentage" && item.PercentageValue.HasValue)
                                {
                                    <text>@item.PercentageValue.Value%</text>
                                }
                                else if (item.Amount.HasValue)
                                {
                                    @Html.DisplayFor(modelItem => item.Amount)
                                }
                                else
                                {
                                    <text>N/A</text>
                                }
                            </td>
                            <td>@Html.DisplayFor(modelItem => item.CalculationMethod)</td>
                            <td>@(item.IsMandatory ? "Yes" : "No")</td>
                            <td>@item.EffectiveDate.ToString("yyyy-MM-dd")</td>
                            <td>@(item.EndDate?.ToString("yyyy-MM-dd") ?? "N/A")</td>
                            <td>@(item.IsActive ? "Yes" : "No")</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            @if (!Model.Any())
            {
                <div class="alert alert-info">
                    No deductions found. <a asp-action="Create">Create a new deduction</a> to get started.
                </div>
            }
        </div>
    </div>
</div>




