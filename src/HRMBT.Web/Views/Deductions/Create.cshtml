@model HRMBT.Web.Models.Deduction

@{
    ViewData["Title"] = "Add deduction";
    ViewData["Module"] = "Deductions";
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" crossorigin="anonymous" />
    <link rel="stylesheet" href="~/css/payslips.css" asp-append-version="true" />
}

<div class="payslip-page py-4">
    <div class="container-fluid px-3 px-lg-4">
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
                <li class="breadcrumb-item"><a asp-action="Index">Deductions</a></li>
                <li class="breadcrumb-item active" aria-current="page">Add</li>
            </ol>
        </nav>

        <div class="section-card mb-4">
            <div class="card-header"><i class="bi bi-plus-lg"></i>Add deduction</div>
            <div class="card-body p-3 p-lg-4">
                <form asp-action="Create" method="post" class="row g-3" style="max-width: 720px;">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="col-12">
                        <label asp-for="EmployeeId" class="form-label">Employee</label>
                        <select asp-for="EmployeeId" class="form-select" asp-items="ViewBag.EmployeeOptions"></select>
                        <span asp-validation-for="EmployeeId" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="DeductionType" class="form-label"></label>
                        <select asp-for="DeductionType" class="form-select" asp-items="ViewBag.DeductionType"></select>
                        <span asp-validation-for="DeductionType" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Frequency" class="form-label"></label>
                        <select asp-for="Frequency" class="form-select" asp-items="ViewBag.Frequency"></select>
                        <span asp-validation-for="Frequency" class="text-danger"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="DeductionName" class="form-label"></label>
                        <input asp-for="DeductionName" class="form-control" maxlength="100" />
                        <span asp-validation-for="DeductionName" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="CalculationMethod" class="form-label"></label>
                        <select asp-for="CalculationMethod" class="form-select" asp-items="ViewBag.CalculationMethod" id="calcMethod"></select>
                        <span asp-validation-for="CalculationMethod" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label for="valueInput" class="form-label" id="valueLabel">Value</label>
                        <input asp-for="PercentageValue" class="form-control" type="number" step="0.01" min="0" id="valueInput" />
                        <div class="form-text" id="valueHint"></div>
                        <span asp-validation-for="PercentageValue" class="text-danger"></span>
                    </div>
                    <div class="col-12">
                        <div class="form-check">
                            <input asp-for="IsMandatory" class="form-check-input" />
                            <label asp-for="IsMandatory" class="form-check-label"></label>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="EffectiveDate" class="form-label"></label>
                        <input asp-for="EffectiveDate" class="form-control" type="date" />
                        <span asp-validation-for="EffectiveDate" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="EndDate" class="form-label"></label>
                        <input asp-for="EndDate" class="form-control" type="date" />
                        <span asp-validation-for="EndDate" class="text-danger"></span>
                    </div>
                    <div class="col-12">
                        <div class="form-check">
                            <input asp-for="IsActive" class="form-check-input" />
                            <label asp-for="IsActive" class="form-check-label"></label>
                        </div>
                    </div>
                    <div class="col-12 d-flex gap-2">
                        <button type="submit" class="btn btn-action-primary"><i class="bi bi-check2 me-1"></i>Save</button>
                        <a asp-action="Index" class="btn btn-action-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        (function () {
            var calc = document.getElementById('calcMethod');
            var label = document.getElementById('valueLabel');
            var hint = document.getElementById('valueHint');
            var input = document.getElementById('valueInput');
            function sync() {
                var m = (calc.value || '').toLowerCase();
                if (m === 'percentage') {
                    label.textContent = 'Percentage (% of gross salary)';
                    hint.textContent = 'Enter 0–100. Applied to gross (basic + allowances) in payroll.';
                    input.max = '100';
                } else {
                    label.textContent = 'Fixed amount (PKR)';
                    hint.textContent = 'Stored in dbo.Deductions.PercentageValue (no separate Amount column).';
                    input.removeAttribute('max');
                }
            }
            calc.addEventListener('change', sync);
            sync();
        })();
    </script>
}
