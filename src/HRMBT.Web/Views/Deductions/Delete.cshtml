@model HRMBT.Web.Models.Deduction

@{
    ViewData["Title"] = "Delete deduction";
    ViewData["Module"] = "Deductions";
    var isPct = string.Equals(Model.CalculationMethod, "Percentage", StringComparison.OrdinalIgnoreCase);
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" crossorigin="anonymous" />
    <link rel="stylesheet" href="~/css/payslips.css" asp-append-version="true" />
}

<div class="payslip-page py-4">
    <div class="container-fluid px-3 px-lg-4">
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
                <li class="breadcrumb-item"><a asp-action="Index">Deductions</a></li>
                <li class="breadcrumb-item active" aria-current="page">Delete</li>
            </ol>
        </nav>

        <div class="section-card mb-4 border-danger">
            <div class="card-header bg-danger text-white"><i class="bi bi-exclamation-triangle me-1"></i>Delete deduction</div>
            <div class="card-body p-3 p-lg-4">
                <p class="lead">Delete this deduction for <strong>@(Model.Employee?.EmployeeName ?? ("#" + Model.EmployeeId))</strong>?</p>
                <dl class="row">
                    <dt class="col-sm-3">Name</dt>
                    <dd class="col-sm-9">@Model.DeductionName</dd>
                    <dt class="col-sm-3">Type</dt>
                    <dd class="col-sm-9">@Model.DeductionType · @Model.Frequency</dd>
                    <dt class="col-sm-3">Value</dt>
                    <dd class="col-sm-9">
                        @if (isPct)
                        {
                            @($"{Model.PercentageValue:N2} %")
                        }
                        else
                        {
                            @($"PKR {Model.PercentageValue:N2}")
                        }
                    </dd>
                </dl>
                <form asp-action="Delete" method="post" class="d-flex gap-2">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Delete</button>
                    <a asp-action="Index" class="btn btn-action-secondary">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>
