@model IEnumerable<HRMBT.Web.Models.Payslip>

@{
    ViewData["Title"] = "Search Payroll";
    ViewData["Module"] = "Payroll";
}

<h2>Search Payroll</h2>

<hr />

<form asp-action="Search" method="get" class="mb-4">
    
    <div class="row">
        <div class="col-md-3">
            <div class="mb-3">
                <label for="month" class="form-label">Month</label>
                <select name="month" id="month" class="form-control">
                    <option value="">All Months</option>
                    @for (int i = 1; i <= 12; i++)
                    {
                        var monthName = System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i);
                        if (ViewBag.Month == i)
                        {
                            <option value="@i" selected>@monthName</option>
                        }
                        else
                        {
                            <option value="@i">@monthName</option>
                        }
                    }
                </select>
            </div>
        </div>
        
        <div class="col-md-3">
            <div class="mb-3">
                <label for="year" class="form-label">Year</label>
                <input type="number" name="year" id="year" class="form-control" 
                       value="@ViewBag.Year" min="2000" max="2100" />
            </div>
        </div>
        
        <div class="col-md-3">
            <div class="mb-3">
                <label for="employeeId" class="form-label">Employee ID</label>
                <input type="text" name="employeeId" id="employeeId" class="form-control" 
                       value="@ViewBag.EmployeeId" placeholder="Enter Employee ID" />
            </div>
        </div>
        
        <div class="col-md-3">
            <div class="mb-3">
                <label for="employeeName" class="form-label">Employee Name</label>
                <input type="text" name="employeeName" id="employeeName" class="form-control" 
                       value="@ViewBag.EmployeeName" placeholder="Enter Employee Name" />
            </div>
        </div>
    </div>
    
    <div class="mb-3">
        <button type="submit" class="btn btn-primary">Search</button>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </div>
</form>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

@if (Model != null && Model.Any())
{
    <div class="table-responsive">
        <table class="table table-striped table-bordered table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Employee ID</th>
                    <th>Employee Name</th>
                    <th>Month / Year</th>
                    <th>Gross Salary</th>
                    <th>Net Salary</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@(item.Employee?.EmployeeID ?? item.EmployeeId.ToString())</td>
                        <td>@(item.Employee?.EmployeeName ?? "N/A")</td>
                        <td>@item.Month / @item.Year</td>
                        <td>@item.GrossSalary.ToString("N2")</td>
                        <td class="fw-bold text-success">@item.NetSalary.ToString("N2")</td>
                        <td>
                            @if (item.IsLocked)
                            {
                                <span class="badge bg-danger">Locked</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Open</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">View Details</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    
    <p class="text-muted">Found @Model.Count() payslip(s)</p>
}
else
{
    <div class="alert alert-info">
        No payslips found matching your search criteria.
    </div>
}

