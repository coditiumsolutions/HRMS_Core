@model IEnumerable<HRMBT.Web.Models.Payslip>

@{
    ViewData["Title"] = "Search Payroll";
    ViewData["Module"] = "Payroll";
    string MonthName(int m) => m >= 1 && m <= 12 ? System.Globalization.CultureInfo.InvariantCulture.DateTimeFormat.GetMonthName(m) : m.ToString();

    string Initials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0].Substring(0, Math.Min(2, parts[0].Length)).ToUpperInvariant();
        return (parts[0][0].ToString() + parts[^1][0].ToString()).ToUpperInvariant();
    }
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" crossorigin="anonymous" />
    <link rel="stylesheet" href="~/css/payslips.css" asp-append-version="true" />
}

<div class="payslip-page py-4">
    <div class="container-fluid px-3 px-lg-4">

        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
                <li class="breadcrumb-item"><a asp-action="Index">Payroll</a></li>
                <li class="breadcrumb-item active" aria-current="page">Search</li>
            </ol>
        </nav>

        <div class="page-header-card p-4 mb-4">
            <div class="row align-items-center g-3">
                <div class="col-lg">
                    <h1 class="h2 mb-1 fw-bold text-dark">
                        <i class="bi bi-search text-primary me-2"></i>Search Payroll
                    </h1>
                    <p class="text-muted mb-0">Find payslips by month, year, employee ID, or employee name.</p>
                </div>
                <div class="col-lg-auto">
                    <div class="d-flex flex-wrap align-items-center gap-2">
                        <a asp-action="Index" class="btn btn-action-outline">
                            <i class="bi bi-arrow-left-short me-1"></i>Back to list
                        </a>
                    </div>
                </div>
            </div>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success d-flex align-items-center gap-2 mb-4">
                <i class="bi bi-check-circle-fill"></i>
                <div>@TempData["SuccessMessage"]</div>
            </div>
        }

        <div class="filter-card mb-4">
            <div class="card-header"><i class="bi bi-funnel"></i>Search filters</div>
            <div class="card-body p-3 p-lg-4">
                <form asp-action="Search" method="get" class="row g-3">
                    <div class="col-md-3">
                        <label for="month" class="form-label">Month</label>
                        @{
                            int? selectedMonth = null;
                            if (ViewBag.Month != null)
                            {
                                int parsedMonth;
                                if (int.TryParse(ViewBag.Month.ToString(), out parsedMonth)) { selectedMonth = parsedMonth; }
                            }
                        }
                        <select name="month" id="month" class="form-select">
                            <option value="">All Months</option>
                            @for (int i = 1; i <= 12; i++)
                            {
                                <option value="@i" selected="@(selectedMonth == i)">@i - @MonthName(i)</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label for="year" class="form-label">Year</label>
                        <input type="number" name="year" id="year" class="form-control" value="@ViewBag.Year" min="2000" max="2100" placeholder="e.g. 2025" />
                    </div>
                    <div class="col-md-3">
                        <label for="employeeId" class="form-label">Employee ID</label>
                        <input type="text" name="employeeId" id="employeeId" class="form-control" value="@ViewBag.EmployeeId" placeholder="EMP-…" />
                    </div>
                    <div class="col-md-3">
                        <label for="employeeName" class="form-label">Employee Name</label>
                        <input type="text" name="employeeName" id="employeeName" class="form-control" value="@ViewBag.EmployeeName" placeholder="Name…" />
                    </div>
                    <div class="col-12 d-flex flex-wrap gap-2">
                        <button type="submit" class="btn btn-action-primary">
                            <i class="bi bi-search me-1"></i>Search
                        </button>
                        <a asp-action="Search" class="btn btn-action-secondary">
                            <i class="bi bi-x-lg me-1"></i>Clear
                        </a>
                    </div>
                </form>
            </div>
        </div>

        <div class="grid-card mb-4">
            <div class="card-header d-flex align-items-center justify-content-between">
                <span><i class="bi bi-table"></i>Results</span>
                @if (Model != null && Model.Any())
                {
                    <span class="small">@Model.Count() payslip(s) found</span>
                }
            </div>
            <div class="card-body">
                @if (Model == null || !Model.Any())
                {
                    <div class="empty-state">
                        <i class="bi bi-inboxes"></i>
                        <h5 class="mb-1">No payslips found</h5>
                        <p class="mb-3">Try adjusting your filters.</p>
                    </div>
                }
                else
                {
                    <div class="table-wrap table-responsive">
                        <table class="payslip-grid">
                            <thead>
                                <tr>
                                    <th style="width:56px;">&nbsp;</th>
                                    <th>Employee</th>
                                    <th>Period</th>
                                    <th class="text-end">Gross</th>
                                    <th class="text-end">Net</th>
                                    <th>Status</th>
                                    <th class="text-end" style="width:120px;">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>
                                            <span class="d-inline-flex align-items-center justify-content-center rounded-circle text-white fw-bold"
                                                  style="width:36px;height:36px;font-size:.85rem;background:linear-gradient(135deg,#336b87 0%,#00203f 100%);">
                                                @Initials(item.Employee?.EmployeeName)
                                            </span>
                                        </td>
                                        <td>
                                            <div class="fw-semibold">@(item.Employee?.EmployeeName ?? "—")</div>
                                            <div class="text-muted small">@(item.Employee?.EmployeeID ?? item.EmployeeId.ToString())</div>
                                        </td>
                                        <td class="text-nowrap">@MonthName(item.Month) @item.Year</td>
                                        <td class="text-end salary">@item.GrossSalary.ToString("N2")</td>
                                        <td class="text-end salary">@item.NetSalary.ToString("N2")</td>
                                        <td>
                                            @if (item.IsLocked)
                                            {
                                                <span class="status-pill status-locked">Locked</span>
                                            }
                                            else
                                            {
                                                <span class="status-pill status-unlocked">Open</span>
                                            }
                                        </td>
                                        <td class="text-end">
                                            <div class="row-actions">
                                                <a class="btn btn-view" asp-action="Details" asp-route-id="@item.Id" title="Details"><i class="bi bi-eye"></i></a>
                                                <a class="btn btn-print" asp-controller="Payslips" asp-action="Print" asp-route-id="@item.Id" target="_blank" title="Print"><i class="bi bi-printer"></i></a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
