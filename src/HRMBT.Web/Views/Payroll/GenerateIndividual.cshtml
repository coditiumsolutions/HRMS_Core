@model HRMBT.Web.Models.ViewModels.GenerateIndividualVM

@{
    ViewData["Title"] = "Generate Individual Payroll";
    ViewData["Module"] = "Payroll";
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" crossorigin="anonymous" />
    <link rel="stylesheet" href="~/css/payslips.css" asp-append-version="true" />
}

<div class="payslip-page py-4">
    <div class="container-fluid px-3 px-lg-4">

        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
                <li class="breadcrumb-item"><a asp-action="Index">Payroll</a></li>
                <li class="breadcrumb-item active" aria-current="page">Generate Individual</li>
            </ol>
        </nav>

        <div class="page-header-card p-4 mb-4">
            <div class="row align-items-center g-3">
                <div class="col-lg">
                    <h1 class="h2 mb-1 fw-bold text-dark">
                        <i class="bi bi-person-badge text-primary me-2"></i>Generate Individual Payroll
                    </h1>
                    <p class="text-muted mb-0">Generate a single payslip for a specific employee using the configured allowances and deductions.</p>
                </div>
                <div class="col-lg-auto d-none d-lg-block">
                    <span class="badge rounded-pill text-bg-light border px-3 py-2 text-secondary">
                        <i class="bi bi-1-circle me-1 text-success"></i> Single run
                    </span>
                </div>
            </div>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success d-flex align-items-center gap-2 mb-4">
                <i class="bi bi-check-circle-fill"></i>
                <div>@TempData["SuccessMessage"]</div>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger d-flex align-items-center gap-2 mb-4">
                <i class="bi bi-exclamation-triangle-fill"></i>
                <div>@TempData["ErrorMessage"]</div>
            </div>
        }

        <form asp-action="GenerateIndividual" method="post" id="individualPayrollForm">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>

            <div class="row g-4">
                <div class="col-lg-8">
                    <div class="section-card mb-4">
                        <div class="card-header"><i class="bi bi-funnel"></i>Employee &amp; period</div>
                        <div class="card-body p-3 p-lg-4">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label asp-for="EmployeeID" class="form-label">Employee ID <span class="text-danger">*</span></label>
                                    <input asp-for="EmployeeID" class="form-control" placeholder="e.g. EMP-1024" autocomplete="off" />
                                    <span asp-validation-for="EmployeeID" class="field-validation-error"></span>
                                </div>
                                <div class="col-md-3">
                                    <label asp-for="Month" class="form-label">Month <span class="text-danger">*</span></label>
                                    @{
                                        ViewData["MonthFieldName"] = "Month";
                                        ViewData["MonthFieldId"] = "Month";
                                        ViewData["SelectedMonth"] = Model.Month;
                                        ViewData["MonthRequired"] = true;
                                    }
                                    <partial name="_PayrollMonthSelect" />
                                    <span asp-validation-for="Month" class="field-validation-error"></span>
                                </div>
                                <div class="col-md-3">
                                    <label asp-for="Year" class="form-label">Year <span class="text-danger">*</span></label>
                                    <input asp-for="Year" class="form-control" type="number" min="2000" max="2100" />
                                    <span asp-validation-for="Year" class="field-validation-error"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="section-card sticky-lg-top mb-4" style="top: 1rem;">
                        <div class="card-header"><i class="bi bi-info-circle"></i>How it works</div>
                        <div class="card-body p-3 p-lg-4 small text-muted">
                            <p class="mb-2"><strong class="text-dark">Lookup:</strong> Employee is matched by Employee ID (case-insensitive).</p>
                            <p class="mb-2"><strong class="text-dark">Status:</strong> Only active employees can be processed.</p>
                            <p class="mb-2"><strong class="text-dark">Calculation:</strong> Uses configured allowances, deductions, and tax rules.</p>
                            <p class="mb-0"><strong class="text-dark">Duplicate:</strong> Will be rejected if a payslip already exists for the same period.</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="payslip-actions">
                <div class="container-fluid px-3 px-lg-4">
                    <div class="d-flex flex-wrap align-items-center justify-content-between gap-2">
                        <div class="small text-muted d-none d-md-block"><i class="bi bi-save me-1"></i>Payslip will be saved and you'll be redirected to the list.</div>
                        <div class="d-flex flex-wrap align-items-center gap-2 ms-md-auto">
                            <a asp-action="Index" class="btn btn-action-outline">
                                <i class="bi bi-arrow-left-short me-1"></i>Cancel
                            </a>
                            <a asp-action="GeneratePayslips" class="btn btn-action-secondary">
                                <i class="bi bi-stack me-1"></i>Run bulk
                            </a>
                            <button type="submit" class="btn btn-action-primary" id="individualSubmit">
                                <span class="spinner-border spinner-border-sm me-2 d-none" id="individualSpinner" role="status"></span>
                                <i class="bi bi-play-fill me-1" id="individualIcon"></i>Generate payroll
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        (function () {
            var form = document.getElementById('individualPayrollForm');
            var btn = document.getElementById('individualSubmit');
            var spin = document.getElementById('individualSpinner');
            var icon = document.getElementById('individualIcon');
            if (!form || !window.jQuery) return;
            window.jQuery(function ($) {
                $(form).on('submit', function () {
                    if (!$(this).valid()) return;
                    spin.classList.remove('d-none');
                    icon.classList.add('d-none');
                    btn.disabled = true;
                });
            });
        })();
    </script>
}
