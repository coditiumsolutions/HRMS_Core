@model HRMBT.Web.Models.ViewModels.GeneratePayslipsVM

@{
    ViewData["Title"] = "Generate Payslips";
    ViewData["Module"] = "Payroll";
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" crossorigin="anonymous" />
    <link rel="stylesheet" href="~/css/payslips.css" asp-append-version="true" />
}

<div class="payslip-page py-4">
    <div class="container-fluid px-3 px-lg-4">

        <!-- Breadcrumb -->
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
                <li class="breadcrumb-item"><a asp-action="Index">Payroll</a></li>
                <li class="breadcrumb-item active" aria-current="page">Generate Payslips</li>
            </ol>
        </nav>

        <!-- Header -->
        <div class="page-header-card p-4 mb-4">
            <div class="row align-items-center g-3">
                <div class="col-lg">
                    <h1 class="h2 mb-1 fw-bold text-dark">
                        <i class="bi bi-cash-coin text-primary me-2"></i>Generate Payslips (Bulk)
                    </h1>
                    <p class="text-muted mb-0">Run payroll for an entire department or the whole organization for the selected month and year.</p>
                </div>
                <div class="col-lg-auto d-none d-lg-block">
                    <span class="badge rounded-pill text-bg-light border px-3 py-2 text-secondary">
                        <i class="bi bi-stack me-1 text-success"></i> Bulk run
                    </span>
                </div>
            </div>
        </div>

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger d-flex align-items-center gap-2 mb-4">
                <i class="bi bi-exclamation-triangle-fill"></i>
                <div>@TempData["ErrorMessage"]</div>
            </div>
        }
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success d-flex align-items-center gap-2 mb-4">
                <i class="bi bi-check-circle-fill"></i>
                <div>@TempData["SuccessMessage"]</div>
            </div>
        }

        <form asp-action="GeneratePayslips" method="post" id="bulkPayrollForm">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>

            <div class="row g-4">
                <div class="col-lg-8">
                    <div class="section-card mb-4">
                        <div class="card-header"><i class="bi bi-funnel"></i>Pay run filters</div>
                        <div class="card-body p-3 p-lg-4">
                            <div class="row g-3">
                                <div class="col-12 col-md-6">
                                    <label asp-for="Department" class="form-label">Department</label>
                                    <select asp-for="Department" class="form-select">
                                        <option value="">All Departments</option>
                                        @if (ViewBag.Departments != null)
                                        {
                                            foreach (var dept in ViewBag.Departments)
                                            {
                                                <option value="@dept">@dept</option>
                                            }
                                        }
                                    </select>
                                    <span asp-validation-for="Department" class="field-validation-error"></span>
                                </div>
                                <div class="col-6 col-md-3">
                                    <label asp-for="Month" class="form-label">Month</label>
                                    @{
                                        ViewData["MonthFieldName"] = "Month";
                                        ViewData["MonthFieldId"] = "Month";
                                        ViewData["SelectedMonth"] = Model.Month;
                                        ViewData["MonthRequired"] = true;
                                    }
                                    <partial name="_PayrollMonthSelect" />
                                    <span asp-validation-for="Month" class="field-validation-error"></span>
                                </div>
                                <div class="col-6 col-md-3">
                                    <label asp-for="Year" class="form-label">Year</label>
                                    <input asp-for="Year" class="form-control" type="number" min="2000" max="2100" />
                                    <span asp-validation-for="Year" class="field-validation-error"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="section-card sticky-lg-top mb-4" style="top: 1rem;">
                        <div class="card-header"><i class="bi bi-info-circle"></i>What this does</div>
                        <div class="card-body p-3 p-lg-4 small text-muted">
                            <p class="mb-2"><strong class="text-dark">Scope:</strong> Active employees in the selected department (or all departments).</p>
                            <p class="mb-2"><strong class="text-dark">Period:</strong> Month and year selected.</p>
                            <p class="mb-2"><strong class="text-dark">Skips:</strong> Employees that already have a payslip for the period.</p>
                            <p class="mb-0"><strong class="text-dark">Lock:</strong> Will not generate if the period is already locked.</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="payslip-actions">
                <div class="container-fluid px-3 px-lg-4">
                    <div class="d-flex flex-wrap align-items-center justify-content-between gap-2">
                        <div class="small text-muted d-none d-md-block">
                            <i class="bi bi-shield-lock me-1"></i>This is a privileged action. Run only when payroll is ready.
                        </div>
                        <div class="d-flex flex-wrap align-items-center gap-2 ms-md-auto">
                            <a asp-action="Index" class="btn btn-action-outline">
                                <i class="bi bi-arrow-left-short me-1"></i>Cancel
                            </a>
                            <a asp-action="GenerateIndividual" class="btn btn-action-secondary">
                                <i class="bi bi-person me-1"></i>Run single employee
                            </a>
                            <button type="submit" class="btn btn-action-primary" id="bulkPayrollSubmit">
                                <span class="spinner-border spinner-border-sm me-2 d-none" id="bulkPayrollSpinner" role="status"></span>
                                <i class="bi bi-play-fill me-1" id="bulkPayrollIcon"></i>Generate payslips
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        (function () {
            var form = document.getElementById('bulkPayrollForm');
            var btn = document.getElementById('bulkPayrollSubmit');
            var spin = document.getElementById('bulkPayrollSpinner');
            var icon = document.getElementById('bulkPayrollIcon');
            if (!form) return;
            form.addEventListener('submit', function () {
                spin.classList.remove('d-none');
                icon.classList.add('d-none');
                btn.disabled = true;
            });
        })();
    </script>
}
