@using HRMBT.Web.Infrastructure
@model HRMBT.Web.Models.PaginatedList<HRMBT.Web.Models.Payslip>

@{
    ViewData["Title"] = "Payroll";
    ViewData["Module"] = "Payroll";
    var selectedMonthFilter = ViewBag.Month as string;

    string Initials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0].Substring(0, Math.Min(2, parts[0].Length)).ToUpperInvariant();
        return (parts[0][0].ToString() + parts[^1][0].ToString()).ToUpperInvariant();
    }
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" crossorigin="anonymous" />
    <link rel="stylesheet" href="~/css/payslips.css" asp-append-version="true" />
}

<div class="payslip-page py-4">
    <div class="container-fluid px-3 px-lg-4">

        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
                <li class="breadcrumb-item active" aria-current="page">Payroll</li>
            </ol>
        </nav>

        @if (TempData["Message"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show d-flex align-items-center gap-2 mb-4" role="alert">
                <i class="bi bi-check-circle-fill"></i>
                <div>@TempData["Message"]</div>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show d-flex align-items-center gap-2 mb-4" role="alert">
                <i class="bi bi-check-circle-fill"></i>
                <div>@TempData["SuccessMessage"]</div>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <div>@TempData["ErrorMessage"]</div>
                    <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
                </div>
            </div>
        }

        <div class="filter-card mb-4">
            <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-2">
                <span><i class="bi bi-funnel"></i>Search payslips</span>
                @if (Model != null)
                {
                    <span class="small text-secondary"><i class="bi bi-collection me-1 text-primary"></i>Total: <span class="fw-semibold text-dark">@Model.TotalCount</span></span>
                }
            </div>
            <div class="card-body p-3 p-lg-4">
                <form asp-action="Index" method="get" class="row g-3" onsubmit="document.getElementById('pageInput').value = '1';">
                    <input type="hidden" name="page" id="pageInput" value="1" />
                    <input type="hidden" name="pageSize" value="@(ViewBag.CurrentPageSize ?? 20)" />
                    <div class="col-md-3">
                        <label for="month" class="form-label">Month</label>
                        <select name="month" id="month" class="form-select">
                            <option value="">All Months</option>
                            @foreach (var monthName in PayrollMonthHelper.AllMonthNames)
                            {
                                <option value="@monthName" selected="@(string.Equals(selectedMonthFilter, monthName, StringComparison.OrdinalIgnoreCase))">@monthName</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label for="year" class="form-label">Year</label>
                        <input type="number" name="year" id="year" class="form-control"
                               value="@ViewBag.Year" min="2000" max="2100" placeholder="Enter Year" />
                    </div>
                    <div class="col-md-3">
                        <label for="employeeId" class="form-label">Employee ID</label>
                        <input type="text" name="employeeId" id="employeeId" class="form-control"
                               value="@ViewBag.EmployeeId" placeholder="e.g., 806" />
                    </div>
                    <div class="col-md-3">
                        <label for="employeeName" class="form-label">Employee Name</label>
                        <input type="text" name="employeeName" id="employeeName" class="form-control"
                               value="@ViewBag.EmployeeName" placeholder="e.g., Shahid Ghaur" />
                    </div>
                    <div class="col-12 d-flex flex-wrap gap-2">
                        <button type="submit" class="btn btn-action-primary">
                            <i class="bi bi-search me-1"></i>Search
                        </button>
                        <a asp-action="Index" class="btn btn-action-secondary">
                            <i class="bi bi-x-lg me-1"></i>Clear
                        </a>
                    </div>
                </form>
            </div>
        </div>

        <div class="grid-card mb-4">
            <div class="card-header d-flex align-items-center justify-content-between">
                <span><i class="bi bi-table"></i>Payslips</span>
                @if (Model != null && Model.Any())
                {
                    <span class="small">@Model.StartRecord–@Model.EndRecord of @Model.TotalCount</span>
                }
            </div>
            <div class="card-body">
                @if (Model != null && Model.Any())
                {
                    <div class="table-wrap table-responsive">
                        <table class="payslip-grid">
                            <thead>
                                <tr>
                                    <th style="width:56px;">&nbsp;</th>
                                    <th>Employee</th>
                                    <th class="text-nowrap">Period</th>
                                    <th class="text-end">Basic</th>
                                    <th class="text-end">Net</th>
                                    <th>Status</th>
                                    <th class="text-end" style="min-width:140px;">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>
                                            <span class="d-inline-flex align-items-center justify-content-center rounded-circle text-white fw-bold"
                                                  style="width:36px;height:36px;font-size:.85rem;background:linear-gradient(135deg,#336b87 0%,#00203f 100%);">
                                                @Initials(item.Employee?.EmployeeName)
                                            </span>
                                        </td>
                                        <td>
                                            <div class="fw-semibold">@(item.Employee?.EmployeeName ?? "—")</div>
                                            <div class="text-muted small">
                                                @(item.Employee?.EmployeeID ?? ("#" + item.EmployeeId))
                                            </div>
                                        </td>
                                        <td class="text-nowrap">@item.Month @item.Year</td>
                                        <td class="text-end salary">@item.BasicSalary.ToString("N2")</td>
                                        <td class="text-end salary">@item.NetSalary.ToString("N2")</td>
                                        <td>
                                            @if (item.IsLocked)
                                            {
                                                <span class="status-pill status-locked">Locked</span>
                                            }
                                            else
                                            {
                                                <span class="status-pill status-unlocked">Open</span>
                                            }
                                        </td>
                                        <td class="text-end">
                                            <div class="row-actions">
                                                <a class="btn btn-view" asp-action="Details" asp-route-id="@item.Id" title="Details"><i class="bi bi-eye"></i></a>
                                                @if (!item.IsLocked)
                                                {
                                                    <a class="btn btn-edit" asp-action="Edit" asp-route-id="@item.Id" title="Edit"><i class="bi bi-pencil"></i></a>
                                                    <a class="btn btn-delete" asp-action="Delete" asp-route-id="@item.Id" title="Delete"><i class="bi bi-trash"></i></a>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <p class="text-muted small px-3 py-2 mb-0 border-top">
                        Showing @Model.StartRecord to @Model.EndRecord of @Model.TotalCount payslip(s)
                        @{
                            var filters = new List<string>();
                            if (!string.IsNullOrWhiteSpace(selectedMonthFilter))
                            {
                                filters.Add(selectedMonthFilter);
                            }
                            if (ViewBag.Year != null)
                            {
                                filters.Add(ViewBag.Year.ToString());
                            }
                            if (ViewBag.EmployeeId != null)
                            {
                                filters.Add($"Employee ID: {ViewBag.EmployeeId}");
                            }
                            if (ViewBag.EmployeeName != null)
                            {
                                filters.Add($"Employee Name: {ViewBag.EmployeeName}");
                            }
                        }
                        @if (filters.Any())
                        {
                            <span> — @string.Join(", ", filters)</span>
                        }
                    </p>

                    @if (Model.TotalPages > 1)
                    {
                        <nav aria-label="Payslip pagination" class="mt-2 px-3 pb-3">
                            <ul class="pagination justify-content-center mb-2">
                                @{
                                    var prevDisabled = !Model.HasPreviousPage ? "disabled" : "";
                                    var nextDisabled = !Model.HasNextPage ? "disabled" : "";
                                    int startPage = Math.Max(1, Model.PageIndex - 2);
                                    int endPage = Math.Min(Model.TotalPages, Model.PageIndex + 2);
                                    if (endPage - startPage < 4)
                                    {
                                        if (startPage == 1) { endPage = Math.Min(Model.TotalPages, startPage + 4); }
                                        else if (endPage == Model.TotalPages) { startPage = Math.Max(1, endPage - 4); }
                                    }
                                }

                                <li class="page-item @prevDisabled">
                                    <a class="page-link" asp-action="Index"
                                       asp-route-page="1"
                                       asp-route-pageSize="@ViewBag.CurrentPageSize"
                                       asp-route-month="@ViewBag.Month"
                                       asp-route-year="@ViewBag.Year"
                                       asp-route-employeeId="@ViewBag.EmployeeId"
                                       asp-route-employeeName="@ViewBag.EmployeeName">&laquo;&laquo;</a>
                                </li>

                                <li class="page-item @prevDisabled">
                                    <a class="page-link" asp-action="Index"
                                       asp-route-page="@(Model.PageIndex - 1)"
                                       asp-route-pageSize="@ViewBag.CurrentPageSize"
                                       asp-route-month="@ViewBag.Month"
                                       asp-route-year="@ViewBag.Year"
                                       asp-route-employeeId="@ViewBag.EmployeeId"
                                       asp-route-employeeName="@ViewBag.EmployeeName">&laquo;</a>
                                </li>

                                @for (int i = startPage; i <= endPage; i++)
                                {
                                    var active = i == Model.PageIndex ? "active" : "";
                                    <li class="page-item @active">
                                        <a class="page-link" asp-action="Index"
                                           asp-route-page="@i"
                                           asp-route-pageSize="@ViewBag.CurrentPageSize"
                                           asp-route-month="@ViewBag.Month"
                                           asp-route-year="@ViewBag.Year"
                                           asp-route-employeeId="@ViewBag.EmployeeId"
                                           asp-route-employeeName="@ViewBag.EmployeeName">@i</a>
                                    </li>
                                }

                                <li class="page-item @nextDisabled">
                                    <a class="page-link" asp-action="Index"
                                       asp-route-page="@(Model.PageIndex + 1)"
                                       asp-route-pageSize="@ViewBag.CurrentPageSize"
                                       asp-route-month="@ViewBag.Month"
                                       asp-route-year="@ViewBag.Year"
                                       asp-route-employeeId="@ViewBag.EmployeeId"
                                       asp-route-employeeName="@ViewBag.EmployeeName">&raquo;</a>
                                </li>

                                <li class="page-item @nextDisabled">
                                    <a class="page-link" asp-action="Index"
                                       asp-route-page="@Model.TotalPages"
                                       asp-route-pageSize="@ViewBag.CurrentPageSize"
                                       asp-route-month="@ViewBag.Month"
                                       asp-route-year="@ViewBag.Year"
                                       asp-route-employeeId="@ViewBag.EmployeeId"
                                       asp-route-employeeName="@ViewBag.EmployeeName">&raquo;&raquo;</a>
                                </li>
                            </ul>
                            <div class="text-center text-muted small">
                                Page @Model.PageIndex of @Model.TotalPages (Total: @Model.TotalCount records)
                            </div>
                        </nav>
                    }
                }
                else
                {
                    <div class="empty-state">
                        <i class="bi bi-inboxes"></i>
                        @if (ViewBag.Month != null || ViewBag.Year != null || ViewBag.EmployeeId != null || ViewBag.EmployeeName != null)
                        {
                            <h5 class="mb-1">No payroll records found</h5>
                            <p class="mb-3">No payslips match the selected filters.</p>
                        }
                        else
                        {
                            <h5 class="mb-1">No payroll records yet</h5>
                            <p class="mb-3">Use the filters above to search, or go to Employee detail to generate payroll.</p>
                            <a asp-action="EmployeeDetail" class="btn btn-action-primary"><i class="bi bi-people me-1"></i>Employee detail</a>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>
