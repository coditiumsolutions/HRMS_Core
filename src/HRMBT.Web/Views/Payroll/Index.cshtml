@model HRMBT.Web.Models.PaginatedList<HRMBT.Web.Models.Payslip>

@{
    ViewData["Title"] = "Payroll";
    ViewData["Module"] = "Payroll";
}

<div class="container">
    <!-- Success message -->
    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success">
            @TempData["Message"]
        </div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">
            @TempData["ErrorMessage"]
        </div>
    }

    <!-- Search Filter -->
    <div class="row mb-3">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Search Payslips</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Index" method="get" class="row g-3" onsubmit="document.getElementById('pageInput').value = '1';">
                        <input type="hidden" name="page" id="pageInput" value="1" />
                        <input type="hidden" name="pageSize" value="@(ViewBag.CurrentPageSize ?? 20)" />
                        <div class="col-md-3">
                            <label for="month" class="form-label">Month</label>
                            <select name="month" id="month" class="form-control">
                                <option value="">All Months</option>
                                @for (int i = 1; i <= 12; i++)
                                {
                                    var monthName = System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i);
                                    if (ViewBag.Month != null && (int)ViewBag.Month == i)
                                    {
                                        <option value="@i" selected>@monthName</option>
                                    }
                                    else
                                    {
                                        <option value="@i">@monthName</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label for="year" class="form-label">Year</label>
                            <input type="number" name="year" id="year" class="form-control" 
                                   value="@ViewBag.Year" min="2000" max="2100" placeholder="Enter Year" />
                        </div>
                        <div class="col-md-3">
                            <label for="employeeId" class="form-label">Employee ID</label>
                            <input type="text" name="employeeId" id="employeeId" class="form-control" 
                                   value="@ViewBag.EmployeeId" placeholder="e.g., 806" />
                        </div>
                        <div class="col-md-3">
                            <label for="employeeName" class="form-label">Employee Name</label>
                            <input type="text" name="employeeName" id="employeeName" class="form-control" 
                                   value="@ViewBag.EmployeeName" placeholder="e.g., Shahid Ghaur" />
                        </div>
                        <div class="col-md-12">
                            <button type="submit" class="btn btn-primary me-2">Search</button>
                            <a asp-action="Index" class="btn btn-secondary">Clear</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Payroll table -->
    <div class="row">
        <div class="col-md-12">
            @if (Model != null && Model.Any())
            {
                <table class="table table-striped table-bordered table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Employee ID</th>
                            <th>Basic Salary</th>
                            <th>Month</th>
                            <th>Year</th>
                            <th>Net Salary</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@Html.DisplayFor(modelItem => item.Id)</td>
                                <td>@Html.DisplayFor(modelItem => item.EmployeeId)</td>
                                <td>@item.BasicSalary.ToString("N2")</td>
                                <td>@item.Month</td>
                                <td>@item.Year</td>
                                <td>@item.NetSalary.ToString("N2")</td>
                                <td>
                                    @if (item.IsLocked)
                                    {
                                        <span class="badge bg-danger">Locked</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Open</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                                    @if (!item.IsLocked)
                                    {
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                
                <p class="text-muted mt-2">
                    Showing @Model.StartRecord to @Model.EndRecord of @Model.TotalCount payslip(s)
                    @{
                        var filters = new List<string>();
                        if (ViewBag.Month != null)
                        {
                            filters.Add(System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName((int)ViewBag.Month));
                        }
                        if (ViewBag.Year != null)
                        {
                            filters.Add(ViewBag.Year.ToString());
                        }
                        if (ViewBag.EmployeeId != null)
                        {
                            filters.Add($"Employee ID: {ViewBag.EmployeeId}");
                        }
                        if (ViewBag.EmployeeName != null)
                        {
                            filters.Add($"Employee Name: {ViewBag.EmployeeName}");
                        }
                    }
                    @if (filters.Any())
                    {
                        <span> - @string.Join(", ", filters)</span>
                    }
                </p>

                <!-- Pagination -->
                @if (Model.TotalPages > 1)
                {
                    <nav aria-label="Payslip pagination" class="mt-3">
                        <ul class="pagination justify-content-center">
                            @{
                                var prevDisabled = !Model.HasPreviousPage ? "disabled" : "";
                                var nextDisabled = !Model.HasNextPage ? "disabled" : "";
                                int startPage = Math.Max(1, Model.PageIndex - 2);
                                int endPage = Math.Min(Model.TotalPages, Model.PageIndex + 2);
                                if (endPage - startPage < 4)
                                {
                                    if (startPage == 1) { endPage = Math.Min(Model.TotalPages, startPage + 4); }
                                    else if (endPage == Model.TotalPages) { startPage = Math.Max(1, endPage - 4); }
                                }
                            }
                            
                            <li class="page-item @prevDisabled">
                                <a class="page-link" asp-action="Index" 
                                   asp-route-page="1" 
                                   asp-route-pageSize="@ViewBag.CurrentPageSize"
                                   asp-route-month="@ViewBag.Month"
                                   asp-route-year="@ViewBag.Year"
                                   asp-route-employeeId="@ViewBag.EmployeeId"
                                   asp-route-employeeName="@ViewBag.EmployeeName">&laquo;&laquo;</a>
                            </li>
                            
                            <li class="page-item @prevDisabled">
                                <a class="page-link" asp-action="Index" 
                                   asp-route-page="@(Model.PageIndex - 1)" 
                                   asp-route-pageSize="@ViewBag.CurrentPageSize"
                                   asp-route-month="@ViewBag.Month"
                                   asp-route-year="@ViewBag.Year"
                                   asp-route-employeeId="@ViewBag.EmployeeId"
                                   asp-route-employeeName="@ViewBag.EmployeeName">&laquo;</a>
                            </li>
                            
                            @for (int i = startPage; i <= endPage; i++)
                            {
                                var active = i == Model.PageIndex ? "active" : "";
                                <li class="page-item @active">
                                    <a class="page-link" asp-action="Index" 
                                       asp-route-page="@i" 
                                       asp-route-pageSize="@ViewBag.CurrentPageSize"
                                       asp-route-month="@ViewBag.Month"
                                       asp-route-year="@ViewBag.Year"
                                       asp-route-employeeId="@ViewBag.EmployeeId"
                                       asp-route-employeeName="@ViewBag.EmployeeName">@i</a>
                                </li>
                            }
                            
                            <li class="page-item @nextDisabled">
                                <a class="page-link" asp-action="Index" 
                                   asp-route-page="@(Model.PageIndex + 1)" 
                                   asp-route-pageSize="@ViewBag.CurrentPageSize"
                                   asp-route-month="@ViewBag.Month"
                                   asp-route-year="@ViewBag.Year"
                                   asp-route-employeeId="@ViewBag.EmployeeId"
                                   asp-route-employeeName="@ViewBag.EmployeeName">&raquo;</a>
                            </li>
                            
                            <li class="page-item @nextDisabled">
                                <a class="page-link" asp-action="Index" 
                                   asp-route-page="@Model.TotalPages" 
                                   asp-route-pageSize="@ViewBag.CurrentPageSize"
                                   asp-route-month="@ViewBag.Month"
                                   asp-route-year="@ViewBag.Year"
                                   asp-route-employeeId="@ViewBag.EmployeeId"
                                   asp-route-employeeName="@ViewBag.EmployeeName">&raquo;&raquo;</a>
                            </li>
                        </ul>
                    </nav>
                    
                    <div class="text-center text-muted mb-3">
                        Page @Model.PageIndex of @Model.TotalPages (Total: @Model.TotalCount records)
                    </div>
                }
            }
            else
            {
                <div class="alert alert-info">
                    @if (ViewBag.Month != null || ViewBag.Year != null || ViewBag.EmployeeId != null || ViewBag.EmployeeName != null)
                    {
                        <text>No payroll records found for the selected filters.</text>
                    }
                    else
                    {
                        <text>No payroll records found. Use the search filters above to find payroll records.</text>
                    }
                </div>
            }
        </div>
    </div>
</div>
