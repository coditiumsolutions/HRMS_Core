@{
    ViewData["Title"] = "Create Payroll";
    ViewData["Module"] = "Payroll";
}

<h1>Create Payroll</h1>

<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            @if (ViewData.ModelState.ErrorCount > 0)
            {
                <div class="alert alert-danger">
                    <h5>Please fix the following errors:</h5>
                    <ul class="mb-0">
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <li>@error.ErrorMessage</li>
                        }
                    </ul>
                </div>
            }
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success">
                    @TempData["SuccessMessage"]
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger">
                    @TempData["ErrorMessage"]
                </div>
            }
            <div class="form-group mb-3">
                <label for="employeeId" class="control-label">Employee ID <span class="text-danger">*</span></label>
                @{
                    var employeeIdValue = ViewData["EmployeeId"] as string ?? string.Empty;
                }
                <input type="text" id="employeeId" name="employeeId" class="form-control" placeholder="Enter Employee ID" value="@employeeIdValue" required />
                <small class="form-text text-muted">Enter the Employee ID (e.g., EMP001)</small>
                @if (ViewData.ModelState["EmployeeId"]?.Errors?.Count > 0)
                {
                    <span class="text-danger">@ViewData.ModelState["EmployeeId"].Errors[0].ErrorMessage</span>
                }
            </div>
            <div class="form-group mb-3">
                <label for="month" class="control-label">Month <span class="text-danger">*</span></label>
                @{
                    var selectedMonth = ViewData["Month"] as string ?? HRMBT.Web.Infrastructure.PayrollMonthHelper.CurrentMonthName();
                    ViewData["MonthFieldName"] = "month";
                    ViewData["MonthFieldId"] = "month";
                    ViewData["SelectedMonth"] = selectedMonth;
                    ViewData["MonthIncludeEmpty"] = true;
                    ViewData["MonthRequired"] = true;
                }
                <partial name="_PayrollMonthSelect" />
                @if (ViewData.ModelState["Month"]?.Errors?.Count > 0)
                {
                    <span class="text-danger">@ViewData.ModelState["Month"].Errors[0].ErrorMessage</span>
                }
            </div>
            <div class="form-group mb-3">
                <label for="year" class="control-label">Year <span class="text-danger">*</span></label>
                @{
                    var selectedYear = ViewData["Year"] != null ? Convert.ToInt32(ViewData["Year"]) : DateTime.Now.Year;
                }
                <input id="year" name="year" class="form-control" type="number" min="2000" max="2100" value="@selectedYear" required />
                @if (ViewData.ModelState["Year"]?.Errors?.Count > 0)
                {
                    <span class="text-danger">@ViewData.ModelState["Year"].Errors[0].ErrorMessage</span>
                }
            </div>
            <div class="form-group mb-3">
                <button type="submit" class="btn btn-primary">Generate Payslip</button>
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
    <div class="col-md-6">
        <div class="alert alert-info">
            <h5>Note:</h5>
            <p>The payslip will be automatically generated based on:</p>
            <ul>
                <li>Employee's basic salary</li>
                <li>Active allowances for the employee</li>
                <li>Active deductions for the employee</li>
            </ul>
            <p class="mb-0"><strong>Note:</strong> A payslip can only be generated once per employee per month/year.</p>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Set default values if not already set
            var monthVal = $('#month').val();
            if (!monthVal || monthVal === '') {
                $('#month').val('@HRMBT.Web.Infrastructure.PayrollMonthHelper.CurrentMonthName()');
            }
            var yearVal = $('#year').val();
            if (!yearVal || yearVal === '') {
                $('#year').val('@DateTime.Now.Year');
            }
            
            // Handle form submission
            $('form').on('submit', function(e) {
                // Basic client-side validation
                var employeeId = $('#employeeId').val().trim();
                var month = $('#month').val();
                var year = $('#year').val();
                
                if (!employeeId) {
                    alert('Please enter an Employee ID');
                    e.preventDefault();
                    return false;
                }
                
                if (!month || month === '') {
                    alert('Please select a month');
                    e.preventDefault();
                    return false;
                }
                
                if (!year || year === '') {
                    alert('Please enter a year');
                    e.preventDefault();
                    return false;
                }
            });
        });
    </script>
}

