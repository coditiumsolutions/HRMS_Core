@model HRMBT.Web.Models.PaginatedList<HRMBT.Web.Models.Employee>

@{
    ViewData["Title"] = "Employee Detail";
    ViewData["Module"] = "Payroll";

    string MonthName(int m) => m >= 1 && m <= 12 ? System.Globalization.CultureInfo.InvariantCulture.DateTimeFormat.GetMonthName(m) : m.ToString();

    string Initials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0].Substring(0, Math.Min(2, parts[0].Length)).ToUpperInvariant();
        return (parts[0][0].ToString() + parts[^1][0].ToString()).ToUpperInvariant();
    }

    int activeCount = Model?.Count(e => e.EmployeeStatus == "Active") ?? 0;
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" crossorigin="anonymous" />
    <link rel="stylesheet" href="~/css/payslips.css" asp-append-version="true" />
}

<div class="payslip-page py-4">
    <div class="container-fluid px-3 px-lg-4">

        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
                <li class="breadcrumb-item"><a asp-action="Index">Payroll</a></li>
                <li class="breadcrumb-item active" aria-current="page">Employee Detail</li>
            </ol>
        </nav>

        <div class="page-header-card p-4 mb-4">
            <div class="row align-items-center g-3">
                <div class="col-lg">
                    <h1 class="h2 mb-1 fw-bold text-dark">
                        <i class="bi bi-people text-primary me-2"></i>Employees for Payroll
                    </h1>
                    <p class="text-muted mb-0">Filter employees, select the active ones to include, and generate payroll for the chosen month and year.</p>
                </div>
                <div class="col-lg-auto">
                    <div class="d-flex flex-wrap align-items-center gap-2">
                        <a asp-action="Index" class="btn btn-action-outline">
                            <i class="bi bi-arrow-left-short me-1"></i>Back to Payroll
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Stats pills -->
        <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
            <span class="badge rounded-pill text-bg-light border px-3 py-2 text-secondary">
                <i class="bi bi-people me-1 text-primary"></i>Total: <span class="fw-bold ms-1">@(Model?.TotalCount ?? 0)</span>
            </span>
            <span class="badge rounded-pill text-bg-light border px-3 py-2 text-secondary">
                <i class="bi bi-eye me-1 text-info"></i>Showing: <span class="fw-bold ms-1">@(Model?.Count ?? 0)</span>
            </span>
            <span class="badge rounded-pill text-bg-light border px-3 py-2 text-secondary">
                <i class="bi bi-check2-circle me-1 text-success"></i>Active on page: <span class="fw-bold ms-1">@activeCount</span>
            </span>
            <span class="badge rounded-pill text-bg-light border px-3 py-2 text-secondary">
                <i class="bi bi-ui-checks me-1 text-warning"></i>Selected: <span class="fw-bold ms-1" id="selectedCount">0</span>
            </span>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show d-flex align-items-center gap-2 mb-4" role="alert">
                <i class="bi bi-check-circle-fill"></i>
                <div>@Html.Raw(TempData["SuccessMessage"])</div>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <div>@Html.Raw(TempData["ErrorMessage"])</div>
                    <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
                </div>
                @if (TempData["ErrorDetails"] != null)
                {
                    <hr class="my-2" />
                    <div class="small text-muted">@Html.Raw(TempData["ErrorDetails"])</div>
                }
            </div>
        }

        <!-- Department filter -->
        <div class="filter-card mb-4">
            <div class="card-header"><i class="bi bi-funnel"></i>Filter employees</div>
            <div class="card-body p-3 p-lg-4">
                <form asp-action="EmployeeDetail" method="get" class="row g-3" onsubmit="document.getElementById('deptPageInput').value = '1';">
                    <input type="hidden" name="page" id="deptPageInput" value="1" />
                    <input type="hidden" name="pageSize" value="@(ViewBag.CurrentPageSize ?? 20)" />
                    <div class="col-md-4">
                        <label for="department" class="form-label">Department</label>
                        <select name="department" id="department" class="form-select"
                                onchange="document.getElementById('deptPageInput').value = '1'; this.form.submit();">
                            <option value="">All Departments</option>
                            @if (ViewBag.Departments != null)
                            {
                                foreach (var dept in ViewBag.Departments)
                                {
                                    var selected = ViewBag.SelectedDepartment != null && ViewBag.SelectedDepartment.ToString() == dept;
                                    <option value="@dept" selected="@selected">@dept</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-4 d-flex align-items-end gap-2">
                        <button type="submit" class="btn btn-action-primary">
                            <i class="bi bi-search me-1"></i>Apply
                        </button>
                        <a asp-action="EmployeeDetail" class="btn btn-action-secondary">
                            <i class="bi bi-x-lg me-1"></i>Clear
                        </a>
                    </div>
                </form>
            </div>
        </div>

        <!-- Pay-run controls -->
        <form asp-action="GeneratePayrollForSelected" method="post" id="generatePayrollForm">
            @Html.AntiForgeryToken()

            <div class="section-card mb-4">
                <div class="card-header"><i class="bi bi-cash-coin"></i>Run payroll for selected</div>
                <div class="card-body p-3 p-lg-4">
                    <div class="row g-3 align-items-end">
                        <div class="col-md-3">
                            <label for="month" class="form-label">Month</label>
                            <select name="month" id="month" class="form-select" required>
                                @for (int i = 1; i <= 12; i++)
                                {
                                    <option value="@i" selected="@(DateTime.Now.Month == i)">@i - @MonthName(i)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label for="year" class="form-label">Year</label>
                            <input type="number" name="year" id="year" class="form-control"
                                   value="@DateTime.Now.Year" min="2000" max="2100" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label invisible d-none d-md-block">Bulk actions</label>
                            <div class="d-flex flex-wrap gap-2">
                                <button type="button" class="btn btn-action-secondary" onclick="selectAll()">
                                    <i class="bi bi-check2-all me-1"></i>Select all
                                </button>
                                <button type="button" class="btn btn-action-outline" onclick="deselectAll()">
                                    <i class="bi bi-x-lg me-1"></i>Deselect all
                                </button>
                                <button type="submit" class="btn btn-action-primary ms-auto" onclick="return confirmGenerate()">
                                    <span class="spinner-border spinner-border-sm me-2 d-none" id="genSpinner" role="status"></span>
                                    <i class="bi bi-play-fill me-1" id="genIcon"></i>Generate payroll
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </form>

        <!-- Employee Grid -->
        <div class="grid-card mb-4">
            <div class="card-header d-flex align-items-center justify-content-between">
                <span><i class="bi bi-table"></i>Employees</span>
                @if (Model != null && Model.Any())
                {
                    <span class="small">@Model.StartRecord–@Model.EndRecord of @Model.TotalCount</span>
                }
            </div>
            <div class="card-body">
                @if (Model == null || !Model.Any())
                {
                    <div class="empty-state">
                        <i class="bi bi-person-x"></i>
                        <h5 class="mb-1">No employees found</h5>
                        <p class="mb-3">Try a different department filter.</p>
                    </div>
                }
                else
                {
                    <div class="table-wrap table-responsive">
                        <table class="payslip-grid">
                            <thead>
                                <tr>
                                    <th style="width: 56px;">
                                        <input type="checkbox" id="selectAllCheckbox" class="form-check-input" onclick="toggleAll(this)" title="Select all on this page" />
                                    </th>
                                    <th style="width: 56px;">&nbsp;</th>
                                    <th>Employee</th>
                                    <th>Department</th>
                                    <th>Designation</th>
                                    <th>Mobile</th>
                                    <th>Joining Date</th>
                                    <th>Status</th>
                                    <th class="text-end">Basic Salary</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    var isActive = string.Equals(item.EmployeeStatus, "Active", StringComparison.OrdinalIgnoreCase);
                                    <tr>
                                        <td>
                                            @if (isActive)
                                            {
                                                <input type="checkbox" form="generatePayrollForm" name="selectedEmployeeIds" value="@item.uid" class="employee-checkbox form-check-input" />
                                            }
                                            else
                                            {
                                                <span class="text-muted" title="Employee is not active">—</span>
                                            }
                                        </td>
                                        <td>
                                            <span class="d-inline-flex align-items-center justify-content-center rounded-circle text-white fw-bold"
                                                  style="width:36px;height:36px;font-size:.85rem;background:linear-gradient(135deg,#336b87 0%,#00203f 100%);">
                                                @Initials(item.EmployeeName)
                                            </span>
                                        </td>
                                        <td>
                                            <div class="fw-semibold">@item.EmployeeName</div>
                                            <div class="text-muted small">@item.EmployeeID</div>
                                        </td>
                                        <td>@item.Department</td>
                                        <td>@item.Designation</td>
                                        <td class="text-nowrap">
                                            @if (!string.IsNullOrWhiteSpace(item.MobileNo))
                                            {
                                                <i class="bi bi-telephone text-muted me-1"></i>@item.MobileNo
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </td>
                                        <td class="text-nowrap">
                                            @(item.DateOfJoining.HasValue ? item.DateOfJoining.Value.ToString("yyyy-MM-dd") : "—")
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(item.EmployeeStatus))
                                            {
                                                if (isActive)
                                                {
                                                    <span class="status-pill status-locked">@item.EmployeeStatus</span>
                                                }
                                                else
                                                {
                                                    <span class="status-pill status-unlocked">@item.EmployeeStatus</span>
                                                }
                                            }
                                        </td>
                                        <td class="text-end salary">
                                            @(item.BasicSalary.HasValue ? item.BasicSalary.Value.ToString("N2") : "—")
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <!-- Pagination -->
        @if (Model != null && Model.TotalPages > 1)
        {
            var prevDisabled = !Model.HasPreviousPage ? "disabled" : "";
            var nextDisabled = !Model.HasNextPage ? "disabled" : "";
            int startPage = Math.Max(1, Model.PageIndex - 2);
            int endPage = Math.Min(Model.TotalPages, Model.PageIndex + 2);
            if (endPage - startPage < 4)
            {
                if (startPage == 1) { endPage = Math.Min(Model.TotalPages, startPage + 4); }
                else if (endPage == Model.TotalPages) { startPage = Math.Max(1, endPage - 4); }
            }
            <nav aria-label="Employee pagination" class="mt-2">
                <ul class="pagination justify-content-center">
                    <li class="page-item @prevDisabled">
                        <a class="page-link" asp-action="EmployeeDetail"
                           asp-route-page="1"
                           asp-route-pageSize="@ViewBag.CurrentPageSize"
                           asp-route-department="@ViewBag.SelectedDepartment"
                           aria-label="First">&laquo;&laquo;</a>
                    </li>
                    <li class="page-item @prevDisabled">
                        <a class="page-link" asp-action="EmployeeDetail"
                           asp-route-page="@(Model.PageIndex - 1)"
                           asp-route-pageSize="@ViewBag.CurrentPageSize"
                           asp-route-department="@ViewBag.SelectedDepartment"
                           aria-label="Previous">&laquo;</a>
                    </li>
                    @for (int i = startPage; i <= endPage; i++)
                    {
                        var active = i == Model.PageIndex ? "active" : "";
                        <li class="page-item @active">
                            <a class="page-link" asp-action="EmployeeDetail"
                               asp-route-page="@i"
                               asp-route-pageSize="@ViewBag.CurrentPageSize"
                               asp-route-department="@ViewBag.SelectedDepartment">@i</a>
                        </li>
                    }
                    <li class="page-item @nextDisabled">
                        <a class="page-link" asp-action="EmployeeDetail"
                           asp-route-page="@(Model.PageIndex + 1)"
                           asp-route-pageSize="@ViewBag.CurrentPageSize"
                           asp-route-department="@ViewBag.SelectedDepartment"
                           aria-label="Next">&raquo;</a>
                    </li>
                    <li class="page-item @nextDisabled">
                        <a class="page-link" asp-action="EmployeeDetail"
                           asp-route-page="@Model.TotalPages"
                           asp-route-pageSize="@ViewBag.CurrentPageSize"
                           asp-route-department="@ViewBag.SelectedDepartment"
                           aria-label="Last">&raquo;&raquo;</a>
                    </li>
                </ul>
                <div class="text-center text-muted small mb-3">
                    Page @Model.PageIndex of @Model.TotalPages — Total @Model.TotalCount records
                </div>
            </nav>
        }
    </div>
</div>

@section Scripts {
    <script>
        function toggleAll(checkbox) {
            document.querySelectorAll('.employee-checkbox').forEach(cb => cb.checked = checkbox.checked);
            updateSelectedCount();
        }
        function selectAll() {
            document.querySelectorAll('.employee-checkbox').forEach(cb => cb.checked = true);
            var sa = document.getElementById('selectAllCheckbox'); if (sa) sa.checked = true;
            updateSelectedCount();
        }
        function deselectAll() {
            document.querySelectorAll('.employee-checkbox').forEach(cb => cb.checked = false);
            var sa = document.getElementById('selectAllCheckbox'); if (sa) sa.checked = false;
            updateSelectedCount();
        }
        function updateSelectedCount() {
            var n = document.querySelectorAll('.employee-checkbox:checked').length;
            var el = document.getElementById('selectedCount');
            if (el) el.textContent = n;
        }
        function confirmGenerate() {
            var selected = document.querySelectorAll('.employee-checkbox:checked').length;
            if (selected === 0) {
                alert('Please select at least one employee.');
                return false;
            }
            if (!confirm('Generate payroll for ' + selected + ' selected employee(s)?')) {
                return false;
            }
            var spin = document.getElementById('genSpinner');
            var icon = document.getElementById('genIcon');
            if (spin) spin.classList.remove('d-none');
            if (icon) icon.classList.add('d-none');
            return true;
        }
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.employee-checkbox').forEach(cb => {
                cb.addEventListener('change', function () {
                    updateSelectedCount();
                    var allChecked = document.querySelectorAll('.employee-checkbox:checked').length;
                    var total = document.querySelectorAll('.employee-checkbox').length;
                    var sa = document.getElementById('selectAllCheckbox');
                    if (sa) sa.checked = allChecked === total && total > 0;
                });
            });
            updateSelectedCount();
        });
    </script>
}
