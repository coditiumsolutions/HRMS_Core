@model HRMBT.Web.Models.Payslip


@{
    ViewData["Title"] = "Payroll Details";
}

<h1>Payroll Details</h1>

<hr />

<dl class="row">
    <dt class="col-sm-3">Payslip ID</dt>
    <dd class="col-sm-9">@Model.Id</dd>

    <dt class="col-sm-3">Employee ID</dt>
    <dd class="col-sm-9">@Model.EmployeeId</dd>

    <dt class="col-sm-3">Month / Year</dt>
    <dd class="col-sm-9">@Model.Month / @Model.Year</dd>

    <dt class="col-sm-3">Basic Salary</dt>
    <dd class="col-sm-9">@Model.BasicSalary.ToString("N2")</dd>

    <dt class="col-sm-3">Gross Salary</dt>
    <dd class="col-sm-9">@Model.GrossSalary.ToString("N2")</dd>

    <dt class="col-sm-3">Total Deductions</dt>
    <dd class="col-sm-9">@Model.TotalDeductions.ToString("N2")</dd>

    <dt class="col-sm-3">Net Salary</dt>
    <dd class="col-sm-9 fw-bold text-success">
        @Model.NetSalary.ToString("N2")
    </dd>

    <dt class="col-sm-3">Generated Date</dt>
    <dd class="col-sm-9">@Model.GeneratedDate</dd>

    <dt class="col-sm-3">Generated By</dt>
    <dd class="col-sm-9">@Model.GeneratedBy</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">
        @if (Model.IsLocked)
        {
            <span class="badge bg-danger">Locked</span>
        }
        else
        {
            <span class="badge bg-success">Open</span>
        }
    </dd>
</dl>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="mt-3">
    @if (!Model.IsLocked)
    {
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
            Edit
        </a>

        <form asp-action="Lock" asp-route-id="@Model.Id" method="post" style="display: inline;">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to lock this payslip? Once locked, it cannot be edited.');">
                Lock Payslip
            </button>
        </form>
    }
    else
    {
        <form asp-action="Unlock" asp-route-id="@Model.Id" method="post" style="display: inline;">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-warning" onclick="return confirm('Are you sure you want to unlock this payslip?');">
                Unlock Payslip
            </button>
        </form>
    }

    <a asp-action="Index" class="btn btn-secondary">
        Back to List
    </a>
</div>
