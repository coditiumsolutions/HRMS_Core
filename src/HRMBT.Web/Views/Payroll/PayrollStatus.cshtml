@model HRMBT.Web.Models.PaginatedList<HRMBT.Web.Models.Employee>

@{
    ViewData["Title"] = "Payroll Status";
    ViewData["Module"] = "Payroll";
    var payslipLookup = ViewBag.PayslipLookup as Dictionary<int, HRMBT.Web.Models.Payslip> ?? new Dictionary<int, HRMBT.Web.Models.Payslip>();
    var actualYear = ViewBag.ActualYear as int?;
    var hasSearched = ViewBag.HasSearched as bool? ?? false;
}

<div class="container">
    <!-- Header -->
    <div class="row mb-3">
        <div class="col-md-12">
            <h1>Payroll Status Report</h1>
            <p class="text-muted">Identify employees by their payroll generation status for a selected month and year.</p>
        </div>
    </div>

    <!-- Success/Error Messages -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @Html.Raw(TempData["SuccessMessage"])
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @Html.Raw(TempData["ErrorMessage"])
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Filter Form -->
    <div class="row mb-3">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Filter Options</h5>
                </div>
                <div class="card-body">
                    <form asp-action="PayrollStatus" method="get" class="row g-3" onsubmit="document.getElementById('statusPageInput').value = '1';">
                        <input type="hidden" name="page" id="statusPageInput" value="1" />
                        <input type="hidden" name="pageSize" value="@(ViewBag.CurrentPageSize ?? 20)" />
                        
                        <div class="col-md-3">
                            <label for="year" class="form-label">Year</label>
                            <select name="year" id="year" class="form-control">
                                <option value="">-- Select Year --</option>
                                @{
                                    int currentYear = DateTime.Now.Year;
                                    int previousYear = currentYear - 1;
                                    string selectedYear = ViewBag.Year?.ToString();
                                }
                                <option value="@previousYear" selected="@(selectedYear != null && selectedYear == previousYear.ToString())">@previousYear</option>
                                <option value="@currentYear" selected="@(selectedYear == null || selectedYear == currentYear.ToString())">@currentYear</option>
                            </select>
                        </div>

                        <div class="col-md-3">
                            <label for="month" class="form-label">Month</label>
                            @{
                                var selectedMonthFilter = ViewBag.Month as string;
                            }
                            <select name="month" id="month" class="form-control">
                                <option value="">-- Select Month --</option>
                                @foreach (var monthName in HRMBT.Web.Infrastructure.PayrollMonthHelper.AllMonthNames)
                                {
                                    <option value="@monthName" selected="@(string.Equals(selectedMonthFilter, monthName, StringComparison.OrdinalIgnoreCase))">@monthName</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-3">
                            <label for="department" class="form-label">Department</label>
                            <select name="department" id="department" class="form-control">
                                <option value="">All Departments</option>
                                @if (ViewBag.Departments != null)
                                {
                                    foreach (var dept in ViewBag.Departments)
                                    {
                                        var isSelected = ViewBag.Department != null && ViewBag.Department.ToString() == dept;
                                        <option value="@dept" selected="@isSelected">@dept</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="col-md-3">
                            <label for="payrollStatus" class="form-label">Payroll Status</label>
                            <select name="payrollStatus" id="payrollStatus" class="form-control">
                                <option value="Payroll Not Generated" selected="@(ViewBag.PayrollStatus?.ToString() == "Payroll Not Generated" || ViewBag.PayrollStatus == null)">Payroll Not Generated</option>
                                <option value="Payroll Generated" selected="@(ViewBag.PayrollStatus?.ToString() == "Payroll Generated")">Payroll Generated</option>
                                <option value="Payroll Pending" selected="@(ViewBag.PayrollStatus?.ToString() == "Payroll Pending")">Payroll Pending</option>
                            </select>
                        </div>

                        <div class="col-12">
                            <button type="submit" class="btn btn-primary me-2">Search</button>
                            <a asp-action="PayrollStatus" class="btn btn-secondary">Reset</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Results Table -->
    <div class="row">
        <div class="col-md-12">
            @if (Model != null && Model.Any())
            {
                <div class="card">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">
                            @if (hasSearched && actualYear.HasValue && ViewBag.Month != null)
                            {
                                <text>Results for @ViewBag.Month @actualYear</text>
                                @if (!string.IsNullOrWhiteSpace(ViewBag.Department?.ToString()))
                                {
                                    <span>- @ViewBag.Department</span>
                                }
                                <span class="badge bg-info ms-2">@ViewBag.PayrollStatus</span>
                            }
                            else
                            {
                                <text>Search Results</text>
                            }
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-striped table-bordered table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Employee ID</th>
                                        <th>Employee Name</th>
                                        <th>Department</th>
                                        <th>Designation</th>
                                        <th>Basic Salary</th>
                                        <th>Payroll Status</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        var hasPayslip = payslipLookup.ContainsKey(item.uid);
                                        var statusBadge = "";
                                        var statusText = "";
                                        
                                        if (!hasPayslip)
                                        {
                                            statusBadge = "bg-danger";
                                            statusText = "Not Generated";
                                        }
                                        else if (payslipLookup[item.uid].IsLocked)
                                        {
                                            statusBadge = "bg-success";
                                            statusText = "Generated";
                                        }
                                        else
                                        {
                                            statusBadge = "bg-warning";
                                            statusText = "Pending";
                                        }

                                        <tr>
                                            <td>@Html.DisplayFor(modelItem => item.EmployeeID)</td>
                                            <td>@Html.DisplayFor(modelItem => item.EmployeeName)</td>
                                            <td>@Html.DisplayFor(modelItem => item.Department)</td>
                                            <td>@Html.DisplayFor(modelItem => item.Designation)</td>
                                            <td>
                                                @if (item.BasicSalary.HasValue)
                                                {
                                                    @item.BasicSalary.Value.ToString("N2")
                                                }
                                            </td>
                                            <td>
                                                <span class="badge @statusBadge">@statusText</span>
                                            </td>
                                            <td>
                                                @if (hasPayslip)
                                                {
                                                    <a asp-action="Details" asp-route-id="@payslipLookup[item.uid].Id" class="btn btn-sm btn-info">View Payslip</a>
                                                }
                                                else
                                                {
                                                    <a asp-action="GenerateIndividual" class="btn btn-sm btn-success">Generate Payroll</a>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <p class="text-muted mt-2">
                            Showing @Model.StartRecord to @Model.EndRecord of @Model.TotalCount employee(s)
                        </p>

                        <!-- Pagination -->
                        @if (Model.TotalPages > 1)
                        {
                            <nav aria-label="Payroll status pagination" class="mt-3">
                                <ul class="pagination justify-content-center">
                                    @{
                                        var prevDisabled = !Model.HasPreviousPage ? "disabled" : "";
                                        var nextDisabled = !Model.HasNextPage ? "disabled" : "";
                                        int startPage = Math.Max(1, Model.PageIndex - 2);
                                        int endPage = Math.Min(Model.TotalPages, Model.PageIndex + 2);
                                        if (endPage - startPage < 4)
                                        {
                                            if (startPage == 1) { endPage = Math.Min(Model.TotalPages, startPage + 4); }
                                            else if (endPage == Model.TotalPages) { startPage = Math.Max(1, endPage - 4); }
                                        }
                                    }
                                    
                                    <li class="page-item @prevDisabled">
                                        <a class="page-link" asp-action="PayrollStatus" 
                                           asp-route-page="1" 
                                           asp-route-pageSize="@ViewBag.CurrentPageSize"
                                           asp-route-year="@ViewBag.Year"
                                           asp-route-month="@ViewBag.Month"
                                           asp-route-department="@ViewBag.Department"
                                           asp-route-payrollStatus="@ViewBag.PayrollStatus">&laquo;&laquo;</a>
                                    </li>
                                    
                                    <li class="page-item @prevDisabled">
                                        <a class="page-link" asp-action="PayrollStatus" 
                                           asp-route-page="@(Model.PageIndex - 1)" 
                                           asp-route-pageSize="@ViewBag.CurrentPageSize"
                                           asp-route-year="@ViewBag.Year"
                                           asp-route-month="@ViewBag.Month"
                                           asp-route-department="@ViewBag.Department"
                                           asp-route-payrollStatus="@ViewBag.PayrollStatus">&laquo;</a>
                                    </li>
                                    
                                    @for (int i = startPage; i <= endPage; i++)
                                    {
                                        var active = i == Model.PageIndex ? "active" : "";
                                        <li class="page-item @active">
                                            <a class="page-link" asp-action="PayrollStatus" 
                                               asp-route-page="@i" 
                                               asp-route-pageSize="@ViewBag.CurrentPageSize"
                                               asp-route-year="@ViewBag.Year"
                                               asp-route-month="@ViewBag.Month"
                                               asp-route-department="@ViewBag.Department"
                                               asp-route-payrollStatus="@ViewBag.PayrollStatus">@i</a>
                                        </li>
                                    }
                                    
                                    <li class="page-item @nextDisabled">
                                        <a class="page-link" asp-action="PayrollStatus" 
                                           asp-route-page="@(Model.PageIndex + 1)" 
                                           asp-route-pageSize="@ViewBag.CurrentPageSize"
                                           asp-route-year="@ViewBag.Year"
                                           asp-route-month="@ViewBag.Month"
                                           asp-route-department="@ViewBag.Department"
                                           asp-route-payrollStatus="@ViewBag.PayrollStatus">&raquo;</a>
                                    </li>
                                    
                                    <li class="page-item @nextDisabled">
                                        <a class="page-link" asp-action="PayrollStatus" 
                                           asp-route-page="@Model.TotalPages" 
                                           asp-route-pageSize="@ViewBag.CurrentPageSize"
                                           asp-route-year="@ViewBag.Year"
                                           asp-route-month="@ViewBag.Month"
                                           asp-route-department="@ViewBag.Department"
                                           asp-route-payrollStatus="@ViewBag.PayrollStatus">&raquo;&raquo;</a>
                                    </li>
                                </ul>
                            </nav>
                            
                            <div class="text-center text-muted mb-3">
                                Page @Model.PageIndex of @Model.TotalPages (Total: @Model.TotalCount records)
                            </div>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    @if (!hasSearched)
                    {
                        <text>Please select Year and Month, then click Search to view payroll status.</text>
                    }
                    else
                    {
                        <text>No employees found matching the selected criteria.</text>
                    }
                </div>
            }
        </div>
    </div>
</div>

