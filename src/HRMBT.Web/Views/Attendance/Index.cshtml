@model IEnumerable<HRMBT.Web.Models.Attendance>

@{
    ViewData["Title"] = "Attendance Management";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-12">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h1>Attendance Management</h1>
                <div>
                    <a asp-action="Create" class="btn btn-primary">Create New</a>
                    <a asp-action="Upload" class="btn btn-success">Upload CSV</a>
                    <a asp-action="MonthlyReport" class="btn btn-info">Monthly Report</a>
                </div>
            </div>

            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-bordered table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>@Html.DisplayNameFor(model => model.AttendanceID)</th>
                                <th>@Html.DisplayNameFor(model => model.EmployeeID)</th>
                                <th>@Html.DisplayNameFor(model => model.EmployeeName)</th>
                                <th>@Html.DisplayNameFor(model => model.DepartmentName)</th>
                                <th>@Html.DisplayNameFor(model => model.AttendanceDate)</th>
                                <th>@Html.DisplayNameFor(model => model.TimeIn)</th>
                                <th>@Html.DisplayNameFor(model => model.TimeOut)</th>
                                <th>@Html.DisplayNameFor(model => model.Status)</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.AttendanceID</td>
                                    <td>@item.EmployeeID</td>
                                    <td>@item.EmployeeName</td>
                                    <td>@item.DepartmentName</td>
                                    <td>@item.AttendanceDate.ToString("yyyy-MM-dd")</td>
                                    <td>@(item.TimeIn?.ToString(@"hh\:mm\:ss") ?? "-")</td>
                                    <td>@(item.TimeOut?.ToString(@"hh\:mm\:ss") ?? "-")</td>
                                    <td>
                                        @if (item.Status == "P")
                                        {
                                            <span class="badge bg-success">Present</span>
                                        }
                                        else if (item.Status == "A")
                                        {
                                            <span class="badge bg-danger">Absent</span>
                                        }
                                        else if (item.Status == "L")
                                        {
                                            <span class="badge bg-warning">Late</span>
                                        }
                                        else if (item.Status == "H")
                                        {
                                            <span class="badge bg-info">Holiday</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">@item.Status</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            <a asp-action="Details" asp-route-id="@item.AttendanceID" class="btn btn-info">Details</a>
                                            <a asp-action="Edit" asp-route-id="@item.AttendanceID" class="btn btn-warning">Edit</a>
                                            <a asp-action="Delete" asp-route-id="@item.AttendanceID" class="btn btn-danger">Delete</a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    No attendance records found. <a asp-action="Create">Create a new attendance record</a> to get started.
                </div>
            }
        </div>
    </div>
</div>
