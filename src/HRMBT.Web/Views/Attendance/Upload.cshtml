@{
    ViewData["Title"] = "Upload Attendance Excel";
}

<div class="container">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h1>Upload Attendance Excel</h1>
            
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">
                    @ViewBag.Error
                </div>
            }

            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Excel File Format</h5>
                    <p class="card-text">
                        Please upload an Excel file (.xlsx or .xls) with the following <strong>fixed column structure and order</strong>:
                    </p>
                    <div class="table-responsive">
                        <table class="table table-bordered table-sm">
                            <thead class="table-light">
                                <tr>
                                    <th>Column</th>
                                    <th>Header Name</th>
                                    <th>Required</th>
                                    <th>Format/Notes</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>1</td>
                                    <td><strong>Employee ID</strong></td>
                                    <td><span class="badge bg-danger">Required</span></td>
                                    <td>Text (e.g., E001)</td>
                                </tr>
                                <tr>
                                    <td>2</td>
                                    <td><strong>Employee Name</strong></td>
                                    <td><span class="badge bg-danger">Required</span></td>
                                    <td>Text (e.g., Ali Khan)</td>
                                </tr>
                                <tr>
                                    <td>3</td>
                                    <td><strong>Department</strong></td>
                                    <td><span class="badge bg-danger">Required</span></td>
                                    <td>Text (e.g., HR, Finance, IT)</td>
                                </tr>
                                <tr>
                                    <td>4</td>
                                    <td><strong>Date</strong></td>
                                    <td><span class="badge bg-danger">Required</span></td>
                                    <td>Date (e.g., 1-Jan-26 or 2026-01-01)</td>
                                </tr>
                                <tr>
                                    <td>5</td>
                                    <td><strong>TimeIn</strong></td>
                                    <td><span class="badge bg-secondary">Optional</span></td>
                                    <td>Time (e.g., 9:00 or 09:00:00)</td>
                                </tr>
                                <tr>
                                    <td>6</td>
                                    <td><strong>TimeOut</strong></td>
                                    <td><span class="badge bg-secondary">Optional</span></td>
                                    <td>Time (e.g., 17:00 or 17:00:00)</td>
                                </tr>
                                <tr>
                                    <td>7</td>
                                    <td><strong>Status</strong></td>
                                    <td><span class="badge bg-secondary">Optional</span></td>
                                    <td>P (Present), A (Absent), L (Late), H (Holiday)</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <div class="alert alert-info mt-3">
                        <h6 class="alert-heading">Sample Data:</h6>
                        <table class="table table-sm table-bordered mb-0">
                            <thead>
                                <tr>
                                    <th>Employee ID</th>
                                    <th>Employee Name</th>
                                    <th>Department</th>
                                    <th>Date</th>
                                    <th>TimeIn</th>
                                    <th>TimeOut</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>E001</td>
                                    <td>Ali Khan</td>
                                    <td>HR</td>
                                    <td>1-Jan-26</td>
                                    <td>9:00</td>
                                    <td>17:00</td>
                                    <td>P</td>
                                </tr>
                                <tr>
                                    <td>E002</td>
                                    <td>Sara Ahmed</td>
                                    <td>Finance</td>
                                    <td>1-Jan-26</td>
                                    <td>9:00</td>
                                    <td>17:00</td>
                                    <td>P</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <div class="alert alert-warning mt-3">
                        <strong>Important Notes:</strong>
                        <ul class="mb-0">
                            <li>The system will automatically find the header row (searches first 10 rows)</li>
                            <li>You can have metadata or empty rows before the header row - they will be skipped</li>
                            <li>The header row must contain the exact header names as shown above</li>
                            <li>Columns must be in the exact order specified</li>
                            <li>If a record for the same Employee ID and Date already exists, it will be updated (upsert behavior)</li>
                            <li>Invalid rows will be skipped with error messages displayed</li>
                        </ul>
                    </div>
                </div>
            </div>

            <form asp-action="Upload" method="post" enctype="multipart/form-data" class="mt-4">
                @Html.AntiForgeryToken()
                <div class="form-group mb-3">
                    <label for="excelFile" class="form-label">Select Excel File</label>
                    <input type="file" name="excelFile" id="excelFile" class="form-control" accept=".xlsx,.xls" required />
                    <small class="form-text text-muted">Accepted formats: .xlsx, .xls</small>
                </div>
                <button type="submit" class="btn btn-primary">Upload and Process</button>
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </form>
        </div>
    </div>
</div>

