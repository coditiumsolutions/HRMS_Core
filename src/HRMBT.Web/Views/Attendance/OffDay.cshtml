@model HRMBT.Web.Models.PaginatedList<HRMBT.Web.Models.Employee>

@{
    ViewData["Title"] = "Off-Day";
    ViewData["Module"] = "Attendance";
    var leaveTypeOptions = ViewBag.LeaveTypeOptions as IList<string>
        ?? (ViewBag.LeaveTypeOptions as IEnumerable<string>)?.ToList()
        ?? new List<string>();
    var hasLeaveTypes = leaveTypeOptions.Count > 0;
    // Read each TempData key once — a second indexer read returns null (flash is consumed on first read).
    var flashSuccess = TempData["SuccessMessage"] as string;
    var flashError = TempData["ErrorMessage"] as string;
    var flashErrorDetails = TempData["ErrorDetails"] as string;
}

<div class="container">
    <div class="row mb-3">
        <div class="col-md-12 d-flex justify-content-between align-items-center">
            <h1>Off-Day</h1>
            <div>
                <a asp-action="Index" class="btn btn-secondary">Back to attendance</a>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(flashSuccess))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @Html.Raw(flashSuccess)
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (!string.IsNullOrWhiteSpace(flashError))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @Html.Raw(flashError)
            @if (!string.IsNullOrWhiteSpace(flashErrorDetails))
            {
                <hr />
                <small>@Html.Raw(flashErrorDetails)</small>
            }
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!hasLeaveTypes)
    {
        <div class="alert alert-warning">
            No leave types are available. Add <code>dbo.Configuration</code> rows with <code>ConfigKey = LeaveTypes</code> and comma-separated values (e.g. <em>Unpaid Leave, Casual Leave</em>), or define types in <code>LeaveQuota</code>.
        </div>
    }

    <div class="row mb-3">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Filter by department &amp; create off-day (LeaveRequests)</h5>
                </div>
                <div class="card-body">
                    <form asp-action="OffDay" method="get" class="row g-2 mb-2" onsubmit="document.getElementById('offDayDeptPageInput').value = '1';">
                        <input type="hidden" name="page" id="offDayDeptPageInput" value="1" />
                        <input type="hidden" name="pageSize" value="@(ViewBag.CurrentPageSize ?? 20)" />
                        <div class="col-md-3">
                            <label for="department" class="form-label small">Department</label>
                            <select name="department" id="department" class="form-control form-control-sm" onchange="document.getElementById('offDayDeptPageInput').value = '1'; this.form.submit();">
                                <option value="">All Departments</option>
                                @if (ViewBag.Departments != null)
                                {
                                    foreach (var dept in ViewBag.Departments)
                                    {
                                        if (ViewBag.SelectedDepartment != null && ViewBag.SelectedDepartment.ToString() == dept)
                                        {
                                            <option value="@dept" selected>@dept</option>
                                        }
                                        else
                                        {
                                            <option value="@dept">@dept</option>
                                        }
                                    }
                                }
                            </select>
                        </div>
                    </form>

                    <form asp-action="OffDay" method="post" id="offDayForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="department" value="@ViewBag.SelectedDepartment" />
                        <input type="hidden" name="page" value="@(Model?.PageIndex ?? 1)" />
                        <input type="hidden" name="pageSize" value="@(ViewBag.CurrentPageSize ?? 20)" />
                        <div class="row g-2">
                            <div class="col-md-4">
                                <label for="leaveType" class="form-label small">Leave type <span class="text-danger">*</span></label>
                                <select name="leaveType" id="leaveType" class="form-control form-control-sm" required @(hasLeaveTypes ? "" : "disabled")>
                                    <option value="">-- Select --</option>
                                    @foreach (var name in leaveTypeOptions)
                                    {
                                        <option value="@name">@name</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label for="offDayDate" class="form-label small">Date <span class="text-danger">*</span></label>
                                <input type="date" name="offDayDate" id="offDayDate" class="form-control form-control-sm"
                                       value="@DateTime.Now.ToString("yyyy-MM-dd")" required />
                            </div>
                        </div>
                        <div class="row g-2 mt-2">
                            <div class="col-md-12">
                                <button type="button" class="btn btn-sm btn-primary me-2" onclick="selectAll()">Select All</button>
                                <button type="button" class="btn btn-sm btn-secondary me-2" onclick="deselectAll()">Deselect All</button>
                                <button type="submit" class="btn btn-sm btn-success" onclick="return confirmOffDay()" @(hasLeaveTypes ? "" : "disabled")>
                                    Create off-day records
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <form id="employeeSelectionForm">
                        <table class="table table-striped table-bordered table-hover">
                            <thead class="table-dark">
                                <tr>
                                    <th style="width: 40px;">
                                        <input type="checkbox" id="selectAllCheckbox" onclick="toggleAll(this)" />
                                    </th>
                                    <th>Employee ID</th>
                                    <th>Employee Name</th>
                                    <th>Department</th>
                                    <th>Designation</th>
                                    <th>Mobile No</th>
                                    <th>Date of Joining</th>
                                    <th>Status</th>
                                    <th>Basic Salary</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>
                                            @if (string.Equals(item.EmployeeStatus, "Active", StringComparison.OrdinalIgnoreCase))
                                            {
                                                <input type="checkbox" name="selectedEmployeeIds" value="@item.EmployeeID" class="employee-checkbox" />
                                            }
                                            else
                                            {
                                                <span class="text-muted" title="Employee is not active">-</span>
                                            }
                                        </td>
                                        <td>@Html.DisplayFor(modelItem => item.EmployeeID)</td>
                                        <td>@Html.DisplayFor(modelItem => item.EmployeeName)</td>
                                        <td>@Html.DisplayFor(modelItem => item.Department)</td>
                                        <td>@Html.DisplayFor(modelItem => item.Designation)</td>
                                        <td>@Html.DisplayFor(modelItem => item.MobileNo)</td>
                                        <td>
                                            @if (item.DateOfJoining.HasValue)
                                            {
                                                @item.DateOfJoining.Value.ToString("yyyy-MM-dd")
                                            }
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(item.EmployeeStatus))
                                            {
                                                @if (item.EmployeeStatus.ToLower() == "active")
                                                {
                                                    <span class="badge bg-success">@item.EmployeeStatus</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">@item.EmployeeStatus</span>
                                                }
                                            }
                                        </td>
                                        <td>
                                            @if (item.BasicSalary.HasValue)
                                            {
                                                @item.BasicSalary.Value.ToString("N2")
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </form>
                </div>
                <p class="text-muted mt-2">
                    Showing @Model.StartRecord to @Model.EndRecord of @Model.TotalCount employee(s) |
                    Active: @Model.Count(e => string.Equals(e.EmployeeStatus, "Active", StringComparison.OrdinalIgnoreCase)) |
                    Selected: <span id="selectedCount">0</span>
                </p>

                @if (Model.TotalPages > 1)
                {
                    <nav aria-label="Employee pagination" class="mt-3">
                        <ul class="pagination justify-content-center">
                            @{
                                var prevDisabled = !Model.HasPreviousPage ? "disabled" : "";
                                var nextDisabled = !Model.HasNextPage ? "disabled" : "";
                                int startPage = Math.Max(1, Model.PageIndex - 2);
                                int endPage = Math.Min(Model.TotalPages, Model.PageIndex + 2);
                                if (endPage - startPage < 4)
                                {
                                    if (startPage == 1) { endPage = Math.Min(Model.TotalPages, startPage + 4); }
                                    else if (endPage == Model.TotalPages) { startPage = Math.Max(1, endPage - 4); }
                                }
                            }

                            <li class="page-item @prevDisabled">
                                <a class="page-link" asp-action="OffDay"
                                   asp-route-page="1"
                                   asp-route-pageSize="@ViewBag.CurrentPageSize"
                                   asp-route-department="@ViewBag.SelectedDepartment">&laquo;&laquo;</a>
                            </li>

                            <li class="page-item @prevDisabled">
                                <a class="page-link" asp-action="OffDay"
                                   asp-route-page="@(Model.PageIndex - 1)"
                                   asp-route-pageSize="@ViewBag.CurrentPageSize"
                                   asp-route-department="@ViewBag.SelectedDepartment">&laquo;</a>
                            </li>

                            @for (int i = startPage; i <= endPage; i++)
                            {
                                var active = i == Model.PageIndex ? "active" : "";
                                <li class="page-item @active">
                                    <a class="page-link" asp-action="OffDay"
                                       asp-route-page="@i"
                                       asp-route-pageSize="@ViewBag.CurrentPageSize"
                                       asp-route-department="@ViewBag.SelectedDepartment">@i</a>
                                </li>
                            }

                            <li class="page-item @nextDisabled">
                                <a class="page-link" asp-action="OffDay"
                                   asp-route-page="@(Model.PageIndex + 1)"
                                   asp-route-pageSize="@ViewBag.CurrentPageSize"
                                   asp-route-department="@ViewBag.SelectedDepartment">&raquo;</a>
                            </li>

                            <li class="page-item @nextDisabled">
                                <a class="page-link" asp-action="OffDay"
                                   asp-route-page="@Model.TotalPages"
                                   asp-route-pageSize="@ViewBag.CurrentPageSize"
                                   asp-route-department="@ViewBag.SelectedDepartment">&raquo;&raquo;</a>
                            </li>
                        </ul>
                    </nav>

                    <div class="text-center text-muted mb-3">
                        Page @Model.PageIndex of @Model.TotalPages (Total: @Model.TotalCount records)
                    </div>
                }
            }
            else
            {
                <div class="alert alert-info">
                    No employee records found.
                </div>
            }
        </div>
    </div>
</div>

<script>
    function toggleAll(checkbox) {
        const checkboxes = document.querySelectorAll('.employee-checkbox');
        checkboxes.forEach(cb => cb.checked = checkbox.checked);
        updateSelectedCount();
    }

    function selectAll() {
        const checkboxes = document.querySelectorAll('.employee-checkbox');
        checkboxes.forEach(cb => cb.checked = true);
        document.getElementById('selectAllCheckbox').checked = true;
        updateSelectedCount();
    }

    function deselectAll() {
        const checkboxes = document.querySelectorAll('.employee-checkbox');
        checkboxes.forEach(cb => cb.checked = false);
        document.getElementById('selectAllCheckbox').checked = false;
        updateSelectedCount();
    }

    function updateSelectedCount() {
        const selected = document.querySelectorAll('.employee-checkbox:checked').length;
        document.getElementById('selectedCount').textContent = selected;
    }

    function confirmOffDay() {
        const selected = document.querySelectorAll('.employee-checkbox:checked').length;
        if (selected === 0) {
            alert('Please select at least one employee.');
            return false;
        }

        const leaveType = document.getElementById('leaveType').value;
        if (!leaveType) {
            alert('Please select a leave type.');
            return false;
        }

        const offDayDate = document.getElementById('offDayDate').value;
        if (!offDayDate) {
            alert('Please select a date.');
            return false;
        }

        if (!confirm(`Create off-day in LeaveRequests for ${selected} employee(s) on ${offDayDate} (${leaveType})?`)) {
            return false;
        }

        const selectedIds = Array.from(document.querySelectorAll('.employee-checkbox:checked'))
            .map(cb => cb.value);

        const form = document.getElementById('offDayForm');
        form.querySelectorAll('input[name="selectedEmployeeIds"]').forEach(n => n.remove());
        selectedIds.forEach(id => {
            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = 'selectedEmployeeIds';
            input.value = id;
            form.appendChild(input);
        });

        return true;
    }

    document.addEventListener('DOMContentLoaded', function() {
        const checkboxes = document.querySelectorAll('.employee-checkbox');
        checkboxes.forEach(cb => {
            cb.addEventListener('change', function() {
                updateSelectedCount();
                const allChecked = document.querySelectorAll('.employee-checkbox:checked').length;
                const totalCheckboxes = document.querySelectorAll('.employee-checkbox').length;
                document.getElementById('selectAllCheckbox').checked = allChecked === totalCheckboxes && totalCheckboxes > 0;
            });
        });
        updateSelectedCount();
    });
</script>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
